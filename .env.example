# Modern Classic — local environment variables.
# Copy this file to .env (also gitignored) and fill in real values.

# Square personal access token for the Modern Classic shop. Production scope:
# APPOINTMENTS_ALL_READ, APPOINTMENTS_WRITE, CUSTOMERS_READ, CUSTOMERS_WRITE,
# ITEMS_READ, EMPLOYEES_READ, MERCHANT_PROFILE_READ, PAYMENTS_WRITE,
# PAYMENTS_READ (Payments scopes are needed for the new-customer card-on-file
# late-cancel / no-show charge flow).
SQUARE_ACCESS_TOKEN=

# Public Square Application ID (sq0idp-... in prod, sandbox-sq0idb-... in
# sandbox). Used by the Square Web Payments SDK card form on the booking
# wizard's card-capture step. Safe to expose to the browser. Exposed under
# PUBLIC_SQUARE_APPLICATION_ID at build time so Astro will ship it client-side.
PUBLIC_SQUARE_APPLICATION_ID=

# Square location ID (also exposed to the browser for the Web Payments SDK).
# Already hardcoded on the server in src/lib/square/locations.ts; this PUBLIC_
# variant is what the card form needs.
PUBLIC_SQUARE_LOCATION_ID=523GMGEC1FY0Z

# "sandbox" or "production". Selects which Square Web Payments SDK URL the
# card form loads in the browser. Defaults to "production" if unset.
PUBLIC_SQUARE_ENVIRONMENT=production

# Password for the /admin/bookings dashboard (HTTP Basic Auth, username
# "admin"). Without it, the page returns 503. Use a strong random string.
ADMIN_PASSWORD=

# Phase 5 — customer auth + transactional email.
# Resend API key for sending magic-link sign-in emails.
RESEND_API_KEY=

# From: header for every outbound transactional email. Must use a verified
# Resend sending domain. Include a display name in the standard format:
#   "Modern Classic Barbershop <bookings@mail.mdrnclassic.com>"
# Server throws on first send if unset — no silent hardcoded fallback.
RESEND_FROM_ADDRESS=

# Reply-To: header for every outbound email + the mailto: target in the
# List-Unsubscribe header. Bare email address (no display name). This is
# the inbox a customer reaches when they hit "reply" on a sign-in or
# review-request email. Server throws on first send if unset.
RESEND_REPLY_TO=

# 32+ char random hex string used to HMAC-sign session cookies and magic
# links. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Phase 6 — Vercel Cron + deploy hook. CRON_SECRET is what Vercel sends
# in the Authorization header on the daily catalog rebuild trigger.
CRON_SECRET=
VERCEL_DEPLOY_HOOK_URL=

# Phase 7 — marketing consent + automated review requests.
# Modern Classic's Google Business review URL — destination of the CTA
# button in every review-request email.
GOOGLE_REVIEW_URL=

# 32+ char random string used to HMAC-sign unsubscribe + click-tracking
# tokens (shared secret, different purpose tags). No expiry on tokens.
UNSUBSCRIBE_SECRET=

# Auth-gate for the daily review-request cron. Separate from CRON_SECRET
# so the two cron jobs can be rotated/disabled independently.
REVIEW_CRON_SECRET=

# Upstash Redis connection — Vercel injects these automatically when an
# Upstash KV store is connected to the project. Used by the review-log
# helpers in src/lib/marketing/reviewLog.ts.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=
