# Modern Classic — local environment variables.
# Copy this file to .env (also gitignored) and fill in real values.

# Square personal access token for the Modern Classic shop. Production scope:
# APPOINTMENTS_ALL_READ, APPOINTMENTS_WRITE, CUSTOMERS_READ, CUSTOMERS_WRITE,
# ITEMS_READ, EMPLOYEES_READ, MERCHANT_PROFILE_READ.
SQUARE_ACCESS_TOKEN=

# Password for the /admin/bookings dashboard (HTTP Basic Auth, username
# "admin"). Without it, the page returns 503. Use a strong random string.
ADMIN_PASSWORD=

# Phase 5 — customer auth + transactional email.
# Resend API key for sending magic-link sign-in emails. Sender is
# bookings@designedtoelevate.co (the verified Resend domain).
RESEND_API_KEY=

# 32+ char random hex string used to HMAC-sign session cookies and magic
# links. Generate with: openssl rand -hex 32
AUTH_SECRET=
