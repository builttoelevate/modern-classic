# Modern Classic — local environment variables.
# Copy this file to .env (also gitignored) and fill in real values.

# Square personal access token for the Modern Classic shop. Production scope:
# APPOINTMENTS_ALL_READ, APPOINTMENTS_WRITE, CUSTOMERS_READ, CUSTOMERS_WRITE,
# ITEMS_READ, EMPLOYEES_READ, MERCHANT_PROFILE_READ.
SQUARE_ACCESS_TOKEN=

# Password for the /admin/bookings dashboard (HTTP Basic Auth, username
# "admin"). Without it, the page returns 503. Use a strong random string.
ADMIN_PASSWORD=

# Phase 5 — customer auth + transactional email.
# Resend API key for sending magic-link sign-in emails. Sender is
# bookings@designedtoelevate.co (the verified Resend domain).
RESEND_API_KEY=

# 32+ char random hex string used to HMAC-sign session cookies and magic
# links. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Phase 6 — Vercel Cron + deploy hook. CRON_SECRET is what Vercel sends
# in the Authorization header on the daily catalog rebuild trigger.
CRON_SECRET=
VERCEL_DEPLOY_HOOK_URL=

# Phase 7 — marketing consent + automated review requests.
# Modern Classic's Google Business review URL — destination of the CTA
# button in every review-request email.
GOOGLE_REVIEW_URL=

# 32+ char random string used to HMAC-sign unsubscribe + click-tracking
# tokens (shared secret, different purpose tags). No expiry on tokens.
UNSUBSCRIBE_SECRET=

# Auth-gate for the daily review-request cron. Separate from CRON_SECRET
# so the two cron jobs can be rotated/disabled independently.
REVIEW_CRON_SECRET=

# Upstash Redis connection — Vercel injects these automatically when an
# Upstash KV store is connected to the project. Used by the review-log
# helpers in src/lib/marketing/reviewLog.ts.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=
