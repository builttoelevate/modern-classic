---
const bookUrl = 'https://modern-classic.square.site';
---
<a class="mob-cta" href={bookUrl} target="_blank" rel="noopener" aria-label="Book a visit">
  Book Now
  <span class="arrow" aria-hidden="true">→</span>
</a>

<style>
  .mob-cta {
    display: none;
    position: fixed;
    bottom: 12px;
    left: 12px;
    right: 12px;
    z-index: 60;
    padding: 1rem 1.25rem;
    background: var(--color-gold);
    color: var(--color-text-on-gold);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    border-radius: 2px;
    box-shadow: 0 10px 30px -8px rgba(0,0,0,0.6),
                0 0 0 1px var(--color-gold-dark);
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .mob-cta:hover { background: var(--color-gold-light); }
  .mob-cta .arrow { transition: transform var(--dur) var(--ease); }
  .mob-cta:hover .arrow { transform: translateX(3px); }

  @media (max-width: 720px) {
    .mob-cta { display: inline-flex; }
  }
</style>
