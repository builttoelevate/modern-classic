---
const directionsUrl = 'https://www.google.com/maps/search/?api=1&query=819+Linden+Avenue+Zanesville+OH+43701';
const bookUrl = 'https://modern-classic.square.site';
---
<section id="location" class="loc" aria-labelledby="loc-heading">
  <div class="container loc__grid">
    <div class="loc__copy">
      <span class="eyebrow">Find the Shop</span>
      <h2 id="loc-heading">
        819 Linden Ave, <span class="italic-accent">Zanesville.</span>
      </h2>

      <dl class="loc__details">
        <div>
          <dt>Address</dt>
          <dd>
            819 Linden Avenue<br/>
            Zanesville, OH 43701
          </dd>
        </div>
        <div>
          <dt>Hours</dt>
          <dd>
            Opening at 9:00 AM
            <span class="loc__todo">{/* TODO: full weekly hours pending owner confirmation */}— full schedule coming soon.</span>
          </dd>
        </div>
        <div>
          <dt>Booking</dt>
          <dd>
            <a href="mailto:modernclassicbarbershop@protonmail.com">modernclassicbarbershop@protonmail.com</a>
          </dd>
        </div>
        <div>
          <dt>Support</dt>
          <dd>
            <a href="mailto:support@mdrnclassic.com">support@mdrnclassic.com</a>
          </dd>
        </div>
        <div>
          <dt>Phone</dt>
          <dd class="loc__todo">Coming soon.</dd>
        </div>
      </dl>

      <div class="loc__ctas">
        <a class="btn" href={bookUrl} target="_blank" rel="noopener">
          Book Now <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn btn--ghost" href={directionsUrl} target="_blank" rel="noopener">
          Get Directions
        </a>
      </div>
    </div>

    <!-- TODO: phase 2 — replace stylized map placeholder with real Google Maps embed -->
    <div class="loc__map" aria-hidden="true">
      <svg class="loc__map-svg" viewBox="0 0 400 460" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="map-bg" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#1a1612"/>
            <stop offset="100%" stop-color="#0b0a08"/>
          </linearGradient>
          <linearGradient id="map-pin" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%"  stop-color="#e6c785"/>
            <stop offset="100%" stop-color="#8a6e35"/>
          </linearGradient>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#2a2520" stroke-width="0.4"/>
          </pattern>
        </defs>
        <rect width="400" height="460" fill="url(#map-bg)"/>
        <rect width="400" height="460" fill="url(#grid)" opacity="0.7"/>

        <!-- Suggestive street network -->
        <g stroke="#3a342c" stroke-width="0.8" fill="none" opacity="0.85">
          <path d="M 0 110 Q 200 90 400 130"/>
          <path d="M 0 230 L 400 220"/>
          <path d="M 0 360 Q 220 380 400 340"/>
          <path d="M 90 0 L 80 460"/>
          <path d="M 220 0 L 230 460"/>
          <path d="M 320 0 L 310 460"/>
        </g>

        <!-- Linden Ave highlighted -->
        <path d="M 220 0 L 230 460" stroke="#c9a35c" stroke-width="1.4" opacity="0.7" fill="none"/>
        <text x="240" y="200" font-family="Manrope, sans-serif" font-size="9" letter-spacing="2" fill="#c9a35c" opacity="0.7" font-weight="600">LINDEN AVE</text>

        <!-- Pin -->
        <g transform="translate(225 225)">
          <circle r="34" fill="rgba(201,163,92,0.18)"/>
          <circle r="22" fill="rgba(201,163,92,0.28)"/>
          <circle r="10" fill="url(#map-pin)"/>
          <circle r="3.5" fill="#0b0a08"/>
        </g>

        <!-- Compass mark -->
        <g transform="translate(360 60)" stroke="#c9a35c" stroke-width="0.8" fill="none" opacity="0.7">
          <circle r="14"/>
          <path d="M 0 -10 L 4 0 L 0 10 L -4 0 Z" fill="#c9a35c"/>
          <text x="0" y="-18" text-anchor="middle" font-family="Manrope, sans-serif" font-size="7" fill="#c9a35c">N</text>
        </g>

        <!-- Caption -->
        <g transform="translate(20 432)">
          <text font-family="Manrope, sans-serif" font-size="9" letter-spacing="3" fill="#c9a35c" font-weight="600">MODERN CLASSIC · 819 LINDEN AVE · ZANESVILLE, OH</text>
        </g>
      </svg>
    </div>
  </div>
</section>

<style>
  .loc { background: var(--color-bg); }
  .loc__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .loc__copy { display: grid; gap: 1.25rem; }
  .loc__details {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem 2rem;
    margin-top: 0.5rem;
  }
  .loc__details > div {
    display: grid;
    gap: 0.25rem;
    border-top: 1px solid var(--color-border-soft);
    padding-top: 0.75rem;
  }
  .loc__details dt {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
  }
  .loc__details dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.98rem;
    line-height: 1.5;
  }
  .loc__details a { color: var(--color-text); border-bottom: 1px solid var(--color-rule); padding-bottom: 1px; }
  .loc__details a:hover { color: var(--color-gold-light); border-bottom-color: var(--color-gold-light); }
  .loc__todo {
    display: block;
    color: var(--color-text-dim);
    font-size: 0.86rem;
    margin-top: 0.2rem;
  }

  .loc__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .loc__map {
    position: relative;
    aspect-ratio: 4 / 4.6;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    overflow: hidden;
    background: var(--color-bg-soft);
  }
  .loc__map::before {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px solid var(--color-rule-soft);
    pointer-events: none;
    z-index: 2;
  }
  .loc__map-svg { width: 100%; height: 100%; display: block; }

  @media (max-width: 860px) {
    .loc__grid { grid-template-columns: 1fr; }
    .loc__details { grid-template-columns: 1fr; }
    .loc__map { max-width: 28rem; margin-inline: auto; }
  }
</style>
