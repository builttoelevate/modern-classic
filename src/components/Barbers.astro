---
// Barber roster sourced from Square. The "from" price comes from the live
// catalog (Men's Haircut variation per barber); falls back to $30 if the
// catalog fetch fails so the homepage still renders.
import { getServicesCached, slugForService } from '../lib/catalog/liveServices';
import NextAvailableLine from './availability/NextAvailableLine.astro';
import { getNextAvailability, HAIRCUT_SLUGS, type NextAvailability } from '../lib/availability/nextAvailable';

const SQUARE_BARBER_IDS = {
  Michael: '523GMGEC1FY0Z',
  Rick: 'TMZ4GRNFpRhnzLbv',
  Clayton: 'TMwUNkXCCC_i3vyZ',
} as const;

interface BarberTile {
  name: string;
  initial: string;
  id: string;
  from: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isGhPages = Boolean(import.meta.env.BASE_URL && import.meta.env.BASE_URL !== '/');
const bookTarget = isGhPages ? '_blank' : '_self';
const bookRel = isGhPages ? 'noopener' : '';
const FALLBACK_BOOK = 'https://modern-classic.square.site';

function priceFor(services: Awaited<ReturnType<typeof getServicesCached>>, barberId: string): string {
  // Find the cheapest fixed-price variation that includes this barber, but
  // only across haircut-style services — otherwise a $15 Shampoo + Style
  // surfaces as "Cuts from $15", which is misleading. Same allowlist used
  // by the homepage hero + barber-card "Next available" filter, minus
  // kids-haircut so the under-10 rate doesn't undercut the adult floor on
  // a card that adults are reading.
  const PRICE_SKIP = new Set(['kids-haircut']);
  let best: number | null = null;
  for (const s of services) {
    const slug = slugForService(s).slug;
    if (!HAIRCUT_SLUGS.has(slug)) continue;
    if (PRICE_SKIP.has(slug)) continue;
    for (const v of s.variations) {
      if (v.priceCents === null) continue;
      if (!v.eligibleTeamMemberIds.includes(barberId)) continue;
      if (best === null || v.priceCents < best) best = v.priceCents;
    }
  }
  if (best === null) return '$30';
  return `$${(best / 100).toFixed(0)}`;
}

let priceMichael = '$30';
let priceRick = '$30';
let priceClayton = '$30';
try {
  const services = await getServicesCached();
  priceMichael = priceFor(services, SQUARE_BARBER_IDS.Michael);
  priceRick = priceFor(services, SQUARE_BARBER_IDS.Rick);
  priceClayton = priceFor(services, SQUARE_BARBER_IDS.Clayton);
} catch {
  // Silent — already initialized to $30 fallback.
}

const barbers: BarberTile[] = [
  { name: 'Michael', initial: 'M', id: SQUARE_BARBER_IDS.Michael, from: priceMichael },
  { name: 'Rick', initial: 'R', id: SQUARE_BARBER_IDS.Rick, from: priceRick },
  { name: 'Clayton', initial: 'C', id: SQUARE_BARBER_IDS.Clayton, from: priceClayton },
];

// Live availability per barber (10-min cache).
const NO_AVAIL: NextAvailability = { slot: null, withinSevenDays: false };
const availLookups = await Promise.all(
  barbers.map(async (b) => {
    try {
      return await getNextAvailability(b.id, { kind: 'haircut' });
    } catch {
      return NO_AVAIL;
    }
  }),
);

function barberBookUrl(id: string): string {
  if (isGhPages) return FALLBACK_BOOK;
  return `${base}/book?barber=${encodeURIComponent(id)}`;
}
---
<section id="barbers" class="barbers" aria-labelledby="barbers-heading">
  <div class="container">
    <header class="section-head section-head--center" data-reveal>
      <h2 id="barbers-heading">
        Meet the <span class="italic-accent">barbers.</span>
      </h2>
      <p class="lede" style="text-align:center; margin-inline:auto;">
        Three chairs, three styles, one standard. Pick your barber when you book.
      </p>
    </header>

    <div class="barbers__grid">
      {barbers.map((b, i) => (
        <article class="barber" data-reveal>
          <div class="barber__crest" aria-hidden="true">
            <svg viewBox="0 0 120 120" class="barber__svg">
              <defs>
                <linearGradient id={`grad-${b.initial}`} x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%"  stop-color="#e6c785"/>
                  <stop offset="55%" stop-color="#c9a35c"/>
                  <stop offset="100%" stop-color="#8a6e35"/>
                </linearGradient>
              </defs>
              <circle cx="60" cy="60" r="56" stroke={`url(#grad-${b.initial})`} stroke-width="0.8" fill="none"/>
              <circle cx="60" cy="60" r="50" stroke={`url(#grad-${b.initial})`} stroke-width="0.4" opacity="0.45" fill="none"/>
              <text x="60" y="78" text-anchor="middle"
                    font-family="Fraunces, Georgia, serif"
                    font-size="68" font-weight="500"
                    fill={`url(#grad-${b.initial})`}>{b.initial}</text>
              <line x1="60" y1="6" x2="60" y2="14" stroke={`url(#grad-${b.initial})`} stroke-width="0.6"/>
              <line x1="60" y1="106" x2="60" y2="114" stroke={`url(#grad-${b.initial})`} stroke-width="0.6"/>
            </svg>
          </div>
          <h3 class="barber__name">{b.name}</h3>
          <p class="barber__role">Barber</p>
          <p class="barber__rate">Haircuts start at <span>{b.from}</span></p>
          <NextAvailableLine
            slot={availLookups[i].slot}
            size="sm"
          />
          <a class="barber__cta" href={barberBookUrl(b.id)} target={bookTarget} rel={bookRel}>
            Book with {b.name} <span class="arrow" aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .barbers {
    background:
      linear-gradient(180deg, var(--color-bg-soft), var(--color-bg));
  }
  .barbers__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .barber {
    position: relative;
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 0.55rem;
    padding: 2.25rem 1.5rem 1.75rem;
    background: linear-gradient(180deg, var(--color-surface), var(--color-bg-soft));
    border: 1px solid var(--color-border);
    border-radius: 2px;
    transition: border-color var(--dur) var(--ease),
                transform var(--dur) var(--ease),
                box-shadow var(--dur) var(--ease);
  }
  .barber::after {
    /* hairline frame */
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid var(--color-rule-soft);
    pointer-events: none;
  }
  .barber:hover {
    border-color: rgba(201,163,92,0.4);
    transform: translateY(-2px);
    box-shadow: 0 14px 40px -22px rgba(0,0,0,0.7);
  }

  .barber__crest {
    width: clamp(110px, 14vw, 150px);
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    margin-bottom: 0.5rem;
  }
  .barber__svg { width: 100%; height: 100%; }

  .barber__name {
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 500;
    letter-spacing: 0.005em;
    line-height: 1.1;
    font-variation-settings: 'opsz' 144;
  }
  .barber__role {
    color: var(--color-gold);
    font-size: 0.74rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
  }
  .barber__rate {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    margin-top: 0.1rem;
  }
  .barber__rate span {
    /* Body sans, semibold, brighter gold — matches the price treatment
       used on service cards and the Shop The Essentials products. */
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-gold-light);
    font-size: 1.05rem;
    letter-spacing: 0.005em;
    margin-left: 0.25rem;
  }
  .barber__cta {
    margin-top: 0.6rem;
    color: var(--color-gold);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 3px;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .barber__cta:hover {
    color: var(--color-gold-light);
    border-bottom-color: var(--color-gold-light);
  }
  .barber__cta .arrow { transition: transform var(--dur) var(--ease); }
  .barber__cta:hover .arrow { transform: translateX(3px); }

  @media (max-width: 880px) {
    .barbers__grid { grid-template-columns: 1fr; max-width: 28rem; margin-inline: auto; }
  }
</style>
