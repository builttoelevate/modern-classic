---
import { Image } from 'astro:assets';
import logo from '../assets/logo-vintage-lettering.png';
import shopInterior from '../assets/shop-interior.jpg';
import HeroAvailability from './home/HeroAvailability.astro';
import { HeroWaitlistTrigger } from './home/HeroWaitlistTrigger';
import type { AvailabilitySlot } from '../lib/square/types';

interface Props {
  availability?: {
    mode: 'personalized' | 'soonest' | 'fallback';
    slot?: AvailabilitySlot | null;
    barberName?: string;
    teamMemberId?: string;
  };
  /** Roster passed to the hero waitlist trigger so the sheet can show a
   * "pick a barber" dropdown (defaults to Any barber). Empty array
   * hides the dropdown — the sheet falls back to the prop barberName. */
  waitlistBarberOptions?: Array<{ id: string; displayName: string }>;
  /** Service catalog passed to the hero waitlist trigger so the sheet
   * can render a required service select. Empty array falls back to the
   * "Any service" sentinel (which means the cron will skip the entry —
   * we want this list populated whenever Square is reachable). */
  waitlistServiceOptions?: Array<{ id: string; name: string }>;
}
const {
  availability,
  waitlistBarberOptions = [],
  waitlistServiceOptions = [],
} = Astro.props as Props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isGhPages = Boolean(import.meta.env.BASE_URL && import.meta.env.BASE_URL !== '/');
const bookUrl = isGhPages ? 'https://modern-classic.square.site' : `${base}/book`;
const bookTarget = isGhPages ? '_blank' : '_self';
const bookRel = isGhPages ? 'noopener' : '';
---
<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__bg-sticky" aria-hidden="true">
    <Image
      src={shopInterior}
      alt=""
      widths={[720, 1080, 1440, 1920]}
      sizes="100vw"
      loading="eager"
      class="hero__bg-img"
    />
    <div class="hero__bg-overlay"></div>
  </div>
  <div class="hero__ornaments" aria-hidden="true">
    <div class="hero__glow"></div>
    <svg class="hero__corner hero__corner--tl" viewBox="0 0 80 80" fill="none">
      <path d="M2 40 V2 H40" stroke="currentColor" stroke-width="1"/>
      <circle cx="2" cy="2" r="2" fill="currentColor"/>
    </svg>
    <svg class="hero__corner hero__corner--tr" viewBox="0 0 80 80" fill="none">
      <path d="M40 2 H78 V40" stroke="currentColor" stroke-width="1"/>
      <circle cx="78" cy="2" r="2" fill="currentColor"/>
    </svg>
    <svg class="hero__corner hero__corner--bl" viewBox="0 0 80 80" fill="none">
      <path d="M2 40 V78 H40" stroke="currentColor" stroke-width="1"/>
      <circle cx="2" cy="78" r="2" fill="currentColor"/>
    </svg>
    <svg class="hero__corner hero__corner--br" viewBox="0 0 80 80" fill="none">
      <path d="M40 78 H78 V40" stroke="currentColor" stroke-width="1"/>
      <circle cx="78" cy="78" r="2" fill="currentColor"/>
    </svg>
  </div>

  <div class="container hero__inner">
    <div class="hero__logo-wrap">
      <Image
        src={logo}
        alt="Modern Classic Barbershop & Shave Parlor emblem"
        widths={[360, 480, 640, 820]}
        sizes="(min-width: 720px) 480px, 78vw"
        loading="eager"
        class="hero__logo"
      />
    </div>

    <h1 id="hero-heading" class="hero__h1">
      <span class="hero__h1-line">Get the Cut.</span>
      <span class="hero__h1-line italic-accent">Keep the Style.</span>
    </h1>

    <p class="hero__lede">
      A Zanesville barbershop and a grooming line in one.
      The cut happens here. <span class="hero__lede-accent">The style goes with you.</span>
    </p>

    <div class="hero__ctas">
      <a class="btn hero__cta-primary" href={bookUrl} target={bookTarget} rel={bookRel}>
        Book an Appointment <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a class="btn btn--ghost hero__cta-secondary" href={`${base}/shop`}>
        Shop Our Products
      </a>
    </div>

    {availability && (
      <div class="hero__avail-row">
        <HeroAvailability
          mode={availability.mode}
          slot={availability.slot}
          barberName={availability.barberName}
          teamMemberId={availability.teamMemberId}
          basePath={base}
          isGhPages={isGhPages}
        />
        {/* Tertiary waitlist CTA — sits inline with the availability pill
            on wide screens, drops below it on narrow. Stays visually
            subordinate to the green pill and to the two hero buttons
            above. Hidden on the gh-pages preview where there's no API. */}
        {!isGhPages && (
          <HeroWaitlistTrigger
            client:load
            barberName={availability.barberName}
            teamMemberId={availability.teamMemberId}
            barberOptions={waitlistBarberOptions}
            serviceOptions={waitlistServiceOptions}
          />
        )}
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    text-align: center;
    /* Override the global `section { padding-block }` rule. */
    padding-block: 0;
    /* Explicit background so any moment where sticky might briefly
       paint outside its track gets covered by the section itself. */
    background-color: var(--color-bg);
    /* overflow: clip is sticky-safe (unlike overflow: hidden which
       breaks position:sticky on iOS) — clips children to the section
       bounds without creating a scroll container. Hard guarantee that
       the sticky photo can't paint past the hero. */
    overflow: clip;
    isolation: isolate;
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    /* Tighter vertical rhythm on mobile so eyebrow + logo + headline +
       paragraph + both CTAs all read above the fold (~110svh). The
       desktop max stays roomy. */
    padding-block: clamp(2.25rem, 7vw, 6rem) clamp(2.5rem, 8vw, 7rem);
    display: grid;
    justify-items: center;
    gap: clamp(0.6rem, 1.4vw, 1.5rem);
  }

  /* Sticky backdrop: stays put while the hero is on screen, then
     scrolls away with the hero when the next section comes up.
     The negative margin makes the sticky element take up zero
     vertical layout space, so hero content flows over it naturally. */
  .hero__bg-sticky {
    position: sticky;
    /* Pin at the bottom edge of the sticky header. Without this,
       sticky's threshold is at viewport top:0, but the photo's
       natural position in the document is one header-height below
       viewport top — so for the first ~68px of scroll the photo
       moves with the content before it reaches the threshold and
       pins. Using top: var(--header-h) means the threshold matches
       the photo's natural position, so it pins from scroll 0. */
    top: var(--header-h);
    left: 0;
    width: 100%;
    /* Use small viewport height so the sticky element is never taller
       than the parent (min-height: 100svh). On iOS, 100vh > 100svh due
       to the address bar, which would exceed parent and kill the track. */
    height: calc(100svh - var(--header-h));
    margin-bottom: calc((100svh - var(--header-h)) * -1);
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background-color: var(--color-bg);
  }
  .hero__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
    filter: saturate(0.85) contrast(1.08) brightness(0.78);
  }
  /* Three-layer overlay:
     1. A subtle warm gold halo behind the emblem (~32% Y) so the logo
        sits in a pool of light instead of fighting the photo.
     2. Edge vignette darker than centre so the chairs/brick at the
        edges fade and the centre band reads through.
     3. A vertical gradient that's heaviest at the very top and very
        bottom (header + CTA legibility) and lightest through the H1
        + lede band, so the text always has enough contrast.
     Compared to the previous overlay this is ~17% lighter overall —
     the photo breathes more, but text contrast stays AA. */
  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      /* Soft gold halo behind the emblem */
      radial-gradient(34% 26% at 50% 32%,
        rgba(201, 163, 92, 0.10),
        transparent 72%),
      /* Edge vignette */
      radial-gradient(125% 85% at 50% 50%,
        transparent 30%,
        rgba(11, 10, 8, 0.50) 75%,
        rgba(11, 10, 8, 0.78) 100%),
      /* Vertical contrast band */
      linear-gradient(180deg,
        rgba(11, 10, 8, 0.80) 0%,
        rgba(11, 10, 8, 0.65) 18%,
        rgba(11, 10, 8, 0.55) 45%,
        rgba(11, 10, 8, 0.70) 80%,
        rgba(11, 10, 8, 0.85) 100%);
  }

  /* Ornaments */
  .hero__ornaments {
    position: absolute;
    inset: clamp(1rem, 3vw, 2.5rem);
    pointer-events: none;
    color: var(--color-gold);
    opacity: 0.55;
    z-index: 1;
  }
  .hero__corner {
    position: absolute;
    width: clamp(36px, 5vw, 60px);
    height: clamp(36px, 5vw, 60px);
    filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.85));
  }
  .hero__corner--tl { top: 0; left: 0; }
  .hero__corner--tr { top: 0; right: 0; }
  .hero__corner--bl { bottom: 0; left: 0; }
  .hero__corner--br { bottom: 0; right: 0; }
  .hero__glow {
    position: absolute;
    top: 18%;
    left: 50%;
    transform: translateX(-50%);
    width: min(640px, 80%);
    height: 280px;
    background: radial-gradient(ellipse at center,
      rgba(201, 163, 92, 0.22), transparent 65%);
    filter: blur(20px);
  }

  .hero__logo-wrap {
    display: grid;
    place-items: center;
    /* Tightened — was clamp(0.75rem ...) clamp(0.25rem ...). The grid
       gap on .hero__inner already provides breathing room. */
    margin-block: clamp(0.25rem, 0.8vw, 0.75rem) 0;
    position: relative;
  }
  .hero__logo {
    width: clamp(280px, 50vw, 480px);
    height: auto;
    filter:
      drop-shadow(0 0 36px rgba(201, 163, 92, 0.4))
      drop-shadow(0 10px 28px rgba(0, 0, 0, 0.65));
    animation: logo-fade 900ms var(--ease) both;
  }
  @keyframes logo-fade {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__h1 {
    display: grid;
    gap: 0.05em;
    margin-top: 0;
  }
  .hero__h1-line {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.55);
  }
  .hero__h1 .italic-accent {
    font-style: italic;
    font-weight: 300;
    color: var(--color-gold-light);
    letter-spacing: -0.015em;
  }

  .hero__lede {
    max-width: 36ch;
    color: var(--color-text);
    /* Display serif at lede size — mirrors the H1 rhythm. */
    font-family: var(--font-display);
    font-size: var(--fs-lede);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.005em;
    font-variation-settings: 'opsz' 100, 'SOFT' 50;
    margin-top: 0;
    opacity: 0.92;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }
  .hero__lede-accent {
    font-style: italic;
    color: var(--color-gold-light);
    font-variation-settings: 'opsz' 100, 'SOFT' 80;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
    margin-top: clamp(0.25rem, 1vw, 0.75rem);
  }
  /* Primary keeps the default .btn treatment (gold fill, weight 600) —
     just guaranteed not to be shrunk by .hero__cta-secondary's overrides. */
  .hero__cta-primary { font-weight: 600; }

  /* Secondary CTA — ghost, ~75% the visual weight of the primary,
     darker gold border, lighter font weight. Reads clearly as
     'optional alternate path' next to the primary. */
  .hero__cta-secondary {
    padding: 0.72em 1.2em;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.10em;
    border-color: var(--color-gold-deep);
    color: var(--color-gold-soft);
  }
  .hero__cta-secondary:hover {
    border-color: var(--color-gold);
    color: var(--color-gold-light);
    background: rgba(201, 163, 92, 0.06);
  }

  /* On the narrowest viewports, stack the CTAs so the primary stands
     alone first and the secondary sits underneath it. */
  @media (max-width: 480px) {
    .hero__ctas {
      flex-direction: column;
      gap: 0.6rem;
      width: 100%;
      max-width: 20rem;
      margin-inline: auto;
    }
    .hero__cta-primary,
    .hero__cta-secondary { width: 100%; }
  }

  @media (max-width: 480px) {
    .hero__corner { width: 28px; height: 28px; }
  }

  /* ---------- Availability row: pill + waitlist trigger ----------
     Wide screens: pill on the left, "Need it sooner?" trigger inline
     to its right with a thin gold separator. Narrow screens stack
     trigger below pill. */
  .hero__avail-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.85rem;
    margin-top: clamp(0.6rem, 1.5vw, 1rem);
  }
  .hero__avail-row :global(.hero-avail) {
    /* HeroAvailability already has its own margin-top; the row owns
       vertical spacing now, so neutralize the child's. */
    margin-top: 0;
  }

  /* ---------- Tertiary waitlist trigger ----------
     Filled gold pill — sits inline with the green availability pill on
     wide screens, stacks below it on narrow. Smaller than the primary
     "Book an Appointment" button so it doesn't compete, but visually
     loud enough that customers can't scroll past it. */
  :global(.hero-waitlist-trigger) {
    appearance: none;
    margin: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.05rem;
    background: var(--color-gold);
    border: 1px solid var(--color-gold);
    border-radius: 999px;
    color: #0b0a08;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.2;
    text-align: left;
    box-shadow: 0 6px 18px -10px rgba(201, 163, 92, 0.55);
    transition:
      background-color var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }
  :global(.hero-waitlist-trigger__icon) {
    flex: 0 0 auto;
    color: #0b0a08;
  }
  :global(.hero-waitlist-trigger__lead) {
    color: rgba(11, 10, 8, 0.78);
    font-weight: 500;
  }
  :global(.hero-waitlist-trigger__cta) {
    color: #0b0a08;
    font-weight: 700;
  }
  :global(.hero-waitlist-trigger__arrow) {
    margin-left: 0.25rem;
    transition: transform var(--dur) var(--ease);
    display: inline-block;
  }
  :global(.hero-waitlist-trigger:hover),
  :global(.hero-waitlist-trigger:focus-visible) {
    background: var(--color-gold-light);
    border-color: var(--color-gold-light);
    box-shadow: 0 10px 26px -12px rgba(232, 196, 122, 0.7);
    transform: translateY(-1px);
  }
  :global(.hero-waitlist-trigger:hover .hero-waitlist-trigger__arrow),
  :global(.hero-waitlist-trigger:focus-visible .hero-waitlist-trigger__arrow) {
    transform: translateX(3px);
  }
  :global(.hero-waitlist-trigger:focus-visible) {
    outline: 2px solid #0b0a08;
    outline-offset: 2px;
  }
  @media (max-width: 480px) {
    :global(.hero-waitlist-trigger) {
      width: 100%;
      justify-content: center;
    }
  }
</style>
