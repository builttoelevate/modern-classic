---
import { Image } from 'astro:assets';
import logo from '../assets/logo-light.png';
import shopInterior from '../assets/shop-interior.jpg';
---
<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__bg-sticky" aria-hidden="true">
    <Image
      src={shopInterior}
      alt=""
      widths={[720, 1080, 1440, 1920]}
      sizes="100vw"
      loading="eager"
      class="hero__bg-img"
    />
    <div class="hero__bg-overlay"></div>
  </div>
  <div class="hero__ornaments" aria-hidden="true">
    <div class="hero__glow"></div>
    <svg class="hero__corner hero__corner--tl" viewBox="0 0 80 80" fill="none">
      <path d="M2 40 V2 H40" stroke="currentColor" stroke-width="1"/>
      <circle cx="2" cy="2" r="2" fill="currentColor"/>
    </svg>
    <svg class="hero__corner hero__corner--tr" viewBox="0 0 80 80" fill="none">
      <path d="M40 2 H78 V40" stroke="currentColor" stroke-width="1"/>
      <circle cx="78" cy="2" r="2" fill="currentColor"/>
    </svg>
    <svg class="hero__corner hero__corner--bl" viewBox="0 0 80 80" fill="none">
      <path d="M2 40 V78 H40" stroke="currentColor" stroke-width="1"/>
      <circle cx="2" cy="78" r="2" fill="currentColor"/>
    </svg>
    <svg class="hero__corner hero__corner--br" viewBox="0 0 80 80" fill="none">
      <path d="M40 78 H78 V40" stroke="currentColor" stroke-width="1"/>
      <circle cx="78" cy="78" r="2" fill="currentColor"/>
    </svg>
  </div>

  <div class="container hero__inner">
    <p class="hero__eyebrow">
      <span class="diamond" aria-hidden="true"></span>
      Zanesville, Ohio &nbsp;·&nbsp; Est. by Barbers
      <span class="diamond" aria-hidden="true"></span>
    </p>

    <div class="hero__logo-wrap">
      <Image
        src={logo}
        alt="Modern Classic Barbershop & Shave Parlor emblem"
        widths={[360, 480, 640, 820]}
        sizes="(min-width: 720px) 480px, 78vw"
        loading="eager"
        class="hero__logo"
      />
    </div>

    <h1 id="hero-heading" class="hero__h1">
      <span class="hero__h1-line">Get the Cut.</span>
      <span class="hero__h1-line italic-accent">Keep the Style.</span>
    </h1>

    <p class="hero__lede">
      Premium haircuts, beard work, and traditional hot-towel shaves —
      paired with the grooming products our barbers actually use in the chair.
    </p>

    <div class="hero__ctas">
      <a class="btn" href="https://modern-classic.square.site" target="_blank" rel="noopener">
        Book a Visit <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a class="btn btn--ghost" href="#products">
        Shop Grooming
      </a>
    </div>

    <ul class="hero__meta" aria-label="What we do">
      <li>Haircuts</li>
      <li aria-hidden="true">·</li>
      <li>Beard Work</li>
      <li aria-hidden="true">·</li>
      <li>Hot Towel Shaves</li>
      <li aria-hidden="true">·</li>
      <li>Premium Products</li>
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    text-align: center;
    /* Padding lives on .hero__inner so .hero__bg-sticky can start at
       section top (otherwise sticky's natural top is offset and pinning
       leaves a padding-sized gap above the photo on initial load). */
    /* No overflow:hidden — breaks position:sticky on iOS Safari. */
    isolation: isolate;
    /* Section sizes to its natural content height. Earlier we used
       min-height: 100svh to guarantee a sticky track, but that left a
       photo-only strip at the section bottom on viewports where svh
       exceeds the content height. Content is naturally taller than the
       sticky child (100svh - header), so the track exists on its own. */
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    padding-block: clamp(4.5rem, 8vw, 7rem) clamp(4.5rem, 9vw, 8rem);
    display: grid;
    justify-items: center;
    gap: clamp(1.25rem, 2vw, 1.75rem);
  }

  /* Sticky backdrop: stays put while the hero is on screen, then
     scrolls away with the hero when the next section comes up.
     The negative margin makes the sticky element take up zero
     vertical layout space, so hero content flows over it naturally. */
  .hero__bg-sticky {
    position: sticky;
    /* Pin at the bottom edge of the sticky header. Without this,
       sticky's threshold is at viewport top:0, but the photo's
       natural position in the document is one header-height below
       viewport top — so for the first ~68px of scroll the photo
       moves with the content before it reaches the threshold and
       pins. Using top: var(--header-h) means the threshold matches
       the photo's natural position, so it pins from scroll 0. */
    top: var(--header-h);
    left: 0;
    width: 100%;
    /* Use small viewport height so the sticky element is never taller
       than the parent (min-height: 100svh). On iOS, 100vh > 100svh due
       to the address bar, which would exceed parent and kill the track. */
    height: calc(100svh - var(--header-h));
    margin-bottom: calc((100svh - var(--header-h)) * -1);
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background-color: var(--color-bg);
  }
  .hero__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
    filter: saturate(0.85) contrast(1.08) brightness(0.78);
  }
  /* Three-layer overlay:
     1. Soft warm spotlight behind the emblem so the gold rings pop
     2. Vignette darker at edges than at center
     3. Top-and-bottom heavier gradient for header / CTA legibility */
  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(30% 24% at 50% 32%,
        rgba(11, 10, 8, 0.65),
        transparent 70%),
      radial-gradient(120% 80% at 50% 50%,
        transparent 25%,
        rgba(11, 10, 8, 0.65) 75%,
        rgba(11, 10, 8, 0.92) 100%),
      linear-gradient(180deg,
        rgba(11, 10, 8, 0.95) 0%,
        rgba(11, 10, 8, 0.80) 18%,
        rgba(11, 10, 8, 0.72) 45%,
        rgba(11, 10, 8, 0.85) 80%,
        rgba(11, 10, 8, 0.97) 100%);
  }

  /* Ornaments */
  .hero__ornaments {
    position: absolute;
    inset: clamp(1rem, 3vw, 2.5rem);
    pointer-events: none;
    color: var(--color-gold);
    opacity: 0.55;
    z-index: 1;
  }
  .hero__corner {
    position: absolute;
    width: clamp(36px, 5vw, 60px);
    height: clamp(36px, 5vw, 60px);
    filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.85));
  }
  .hero__corner--tl { top: 0; left: 0; }
  .hero__corner--tr { top: 0; right: 0; }
  .hero__corner--bl { bottom: 0; left: 0; }
  .hero__corner--br { bottom: 0; right: 0; }
  .hero__glow {
    position: absolute;
    top: 18%;
    left: 50%;
    transform: translateX(-50%);
    width: min(640px, 80%);
    height: 280px;
    background: radial-gradient(ellipse at center,
      rgba(201, 163, 92, 0.22), transparent 65%);
    filter: blur(20px);
  }

  .hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0;
  }
  .hero__eyebrow .diamond { background: var(--color-gold); opacity: 0.8; }

  .hero__logo-wrap {
    display: grid;
    place-items: center;
    margin-block: clamp(0.75rem, 2vw, 1.5rem) clamp(0.25rem, 1vw, 0.5rem);
    position: relative;
  }
  .hero__logo {
    width: clamp(280px, 50vw, 480px);
    height: auto;
    filter:
      drop-shadow(0 0 36px rgba(201, 163, 92, 0.4))
      drop-shadow(0 10px 28px rgba(0, 0, 0, 0.65));
    animation: logo-fade 900ms var(--ease) both;
  }
  @keyframes logo-fade {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__h1 {
    display: grid;
    gap: 0.05em;
    margin-top: 0.25rem;
  }
  .hero__h1-line {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.55);
  }
  .hero__h1 .italic-accent {
    font-style: italic;
    font-weight: 300;
    color: var(--color-gold-light);
    letter-spacing: -0.015em;
  }

  .hero__lede {
    max-width: 44ch;
    color: var(--color-text);
    font-size: var(--fs-lede);
    line-height: 1.55;
    margin-top: 0.25rem;
    opacity: 0.88;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }

  .hero__meta {
    list-style: none;
    padding: 0;
    margin-top: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 0.85rem;
    color: var(--color-text-dim);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .hero__meta li[aria-hidden='true'] { color: var(--color-gold); opacity: 0.6; }

  @media (max-width: 480px) {
    .hero__corner { width: 28px; height: 28px; }
  }
</style>
