---
// Homepage shop CTA — single button under the "Shop the Essentials"
// heading that takes visitors to the live Shopify store. Replaces the
// previous 4-up product grid (clay / powder / spray / oil) per the
// shop owner's request. Anchor id `#products` is preserved so existing
// nav and in-hero CTAs continue to scroll here.

const SHOP_URL = 'https://mdrnclassic.com';
---
<section id="products" class="shop-ess" aria-labelledby="shop-ess-heading">
  <div class="container">
    <header class="section-head section-head--center" data-reveal>
      <h2 id="shop-ess-heading">
        Shop the <span class="italic-accent">Essentials.</span>
      </h2>
    </header>
    <div class="shop-ess__cta-wrap" data-reveal>
      <a class="btn shop-ess__cta" href={SHOP_URL} target="_blank" rel="noopener noreferrer">
        Shop the Store <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .shop-ess {
    background:
      radial-gradient(900px 400px at 50% 0%, rgba(201,163,92,0.06), transparent 70%),
      var(--color-bg);
  }
  .shop-ess__cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: clamp(1.25rem, 3vw, 2rem);
  }
  /* The section CTA scales a bit larger than the default .btn so it
     reads as the section's primary action without the visual noise
     of the prior product grid. */
  .shop-ess__cta {
    padding: 1rem 2rem;
    font-size: 0.95rem;
    letter-spacing: 0.16em;
  }
</style>
