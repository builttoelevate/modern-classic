---
// Sticky aside next to the founder story is a featured product card —
// surfaces a single product (Salt Spray) tied directly to the "made by
// barbers, used in our shop" copy. Replaces the prior decorative MC
// monogram panel.

const SALT_SPRAY = {
  name: 'Salt Spray',
  category: 'Texture & Finish',
  size: '250ml',
  price: '$24',
  description: 'Designs raw, beach-textured hair. A messy, undone look — volume, texture, and control. Great at thickening fine hair.',
  imageUrl: 'https://mdrnclassic.com/cdn/shop/files/2_14233aba-bfed-4b86-8ff6-30a2c9ec6ac0.png?width=1445',
  productUrl: 'https://mdrnclassic.com/products/mdrn%E2%84%A2-classic-250ml-salt-spray',
  alt: 'MDRN Classic 250ml salt spray bottle',
};
---
<section id="about" class="story" aria-labelledby="story-heading">
  <div class="container story__grid">
    <div class="story__copy" data-reveal>
      <span class="eyebrow">The Founder's Shop</span>
      <h2 id="story-heading">
        A brand built <span class="italic-accent">by barbers.</span>
      </h2>

      <p>
        As seasoned barbers, we understand the confidence you gain after a
        fresh haircut. We aim to equip modern gentlemen with grooming
        essentials that ensure they feel and look their best — every single day.
      </p>

      <p>
        Modern Classic started in the chair. After more than ten years of
        cutting hair and watching clients struggle to recreate the style at
        home, our founder set out to build the products he wished his
        customers had: premium grooming essentials with no residue, no
        buildup, and a scent worth wearing.
      </p>

      <blockquote class="story__quote">
        <span class="story__quote-mark" aria-hidden="true">“</span>
        A great haircut should do more than look good for one day.
      </blockquote>

      <p>
        Today, MDRN Classic products are made by barbers, used in our shop,
        and shipped to clients across the country. The cut happens in
        Zanesville. The style stays with you wherever you go.
      </p>
    </div>

    <aside class="story__visual" data-reveal style="--reveal-delay: 80ms">
      <a class="story__panel story__panel--product"
         href={SALT_SPRAY.productUrl}
         target="_blank"
         rel="noopener noreferrer"
         aria-label={`Shop ${SALT_SPRAY.name} on the MDRN Classic store`}>
        <span class="story__product-eyebrow">Featured Product</span>
        <div class="story__product-media">
          <img src={SALT_SPRAY.imageUrl} alt={SALT_SPRAY.alt} loading="lazy" decoding="async" />
        </div>
        <div class="story__product-body">
          <p class="story__product-category">{SALT_SPRAY.category} · {SALT_SPRAY.size}</p>
          <h3 class="story__product-name">{SALT_SPRAY.name}</h3>
          <p class="story__product-desc">{SALT_SPRAY.description}</p>
          <div class="story__product-foot">
            <span class="story__product-price">{SALT_SPRAY.price}</span>
            <span class="story__product-cta">
              Shop Now <span class="arrow" aria-hidden="true">→</span>
            </span>
          </div>
        </div>
      </a>
    </aside>
  </div>
</section>

<style>
  .story { background: var(--color-bg); }
  .story__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  .story__copy { display: grid; gap: 1.1rem; max-width: 36rem; }
  .story__copy h2 { margin-bottom: 0.4rem; }
  .story__copy p {
    color: var(--color-text-muted);
    font-size: 1.06rem;
    line-height: 1.7;
  }

  .story__quote {
    position: relative;
    margin: 1.25rem 0;
    padding: 1.25rem 1.5rem 1.25rem 2.5rem;
    border-left: 1px solid var(--color-rule);
    background: linear-gradient(90deg, rgba(201,163,92,0.05), transparent 60%);
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-style: italic;
    line-height: 1.3;
    color: var(--color-text);
    font-variation-settings: 'opsz' 144, 'SOFT' 80;
  }
  .story__quote-mark {
    position: absolute;
    top: 0.4rem;
    left: 0.5rem;
    font-family: var(--font-display);
    font-size: 3rem;
    line-height: 1;
    color: var(--color-gold);
    font-style: normal;
  }

  .story__visual { position: sticky; top: calc(var(--header-h) + 1.5rem); }
  .story__panel {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 0;
    padding: 0;
    background:
      radial-gradient(circle at 50% 35%, rgba(201,163,92,0.10), transparent 65%),
      linear-gradient(180deg, var(--color-surface-2), var(--color-bg));
    border: 1px solid var(--color-border);
    border-radius: 2px;
    overflow: hidden;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color var(--dur) var(--ease),
                transform var(--dur) var(--ease),
                box-shadow var(--dur) var(--ease);
  }
  .story__panel--product:hover,
  .story__panel--product:focus-visible {
    border-color: rgba(201, 163, 92, 0.55);
    transform: translateY(-3px);
    box-shadow: 0 18px 50px -25px rgba(0, 0, 0, 0.7);
  }
  .story__panel::before {
    /* hairline frame */
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid var(--color-rule);
    pointer-events: none;
    z-index: 1;
  }
  .story__panel::after {
    /* corner accent */
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(201,163,92,0.06), transparent 35%),
      linear-gradient(-45deg, rgba(201,163,92,0.04), transparent 35%);
    pointer-events: none;
  }

  /* "Featured Product" eyebrow pinned to the top of the panel,
     inside the hairline frame. */
  .story__product-eyebrow {
    z-index: 2;
    align-self: start;
    justify-self: center;
    margin-top: 1.4rem;
    padding: 0.25rem 0.7rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-text-on-gold, #1a140a);
    background: var(--color-gold);
    border-radius: 999px;
  }

  /* Bottle floats on the same warm-gold-halo plate the product cards
     elsewhere on the site use — keeps cross-section visual rhythm. */
  .story__product-media {
    position: relative;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    margin: 0.4rem 1.4rem 0;
    overflow: hidden;
  }
  .story__product-media img {
    max-width: 70%;
    max-height: 86%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: transform var(--dur-slow) var(--ease);
    filter: drop-shadow(0 18px 32px rgba(0, 0, 0, 0.6));
  }
  .story__panel--product:hover .story__product-media img {
    transform: scale(1.04);
  }

  .story__product-body {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0.4rem;
    padding: 0 1.6rem 1.5rem;
    text-align: center;
  }
  .story__product-category {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-gold-deep);
    margin: 0;
  }
  .story__product-name {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.005em;
    margin: 0;
    color: var(--color-text);
  }
  .story__product-desc {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.5;
    margin: 0;
    max-width: 28rem;
    margin-inline: auto;
  }
  .story__product-foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.5rem;
    padding-top: 0.6rem;
    border-top: 1px solid var(--color-rule);
  }
  .story__product-price {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-gold-light);
  }
  .story__product-cta {
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .story__product-cta .arrow { transition: transform var(--dur) var(--ease); }
  .story__panel--product:hover .story__product-cta { color: var(--color-gold-light); }
  .story__panel--product:hover .story__product-cta .arrow { transform: translateX(3px); }

  @media (max-width: 860px) {
    .story__grid { grid-template-columns: 1fr; }
    .story__visual { position: static; max-width: 28rem; margin-inline: auto; }
  }
</style>
