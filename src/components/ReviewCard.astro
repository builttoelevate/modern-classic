---
interface Props {
  product: string;
  body: string;
  attribution: string;
  rating?: number;
}
const { product, body, attribution, rating = 5 } = Astro.props;
const stars = '★'.repeat(rating) + '☆'.repeat(5 - rating);
---
<figure class="rev">
  <div class="rev__rating" aria-label={`${rating} out of 5 stars`}>
    {stars.split('').map((s) => (
      <span class={s === '★' ? 'rev__star rev__star--on' : 'rev__star'} aria-hidden="true">{s}</span>
    ))}
  </div>
  <p class="rev__product">on {product}</p>
  <blockquote class="rev__body">
    <span class="rev__mark" aria-hidden="true">“</span>
    {body}
  </blockquote>
  <figcaption class="rev__cite">— {attribution}</figcaption>
</figure>

<style>
  .rev {
    position: relative;
    display: grid;
    gap: 0.85rem;
    padding: clamp(1.5rem, 2.4vw, 2rem);
    background: linear-gradient(180deg, var(--color-surface), var(--color-bg-soft));
    border: 1px solid var(--color-border);
    border-radius: 2px;
  }
  .rev__rating { display: flex; gap: 2px; color: var(--color-gold-dark); font-size: 1rem; }
  .rev__star--on { color: var(--color-gold); }

  .rev__product {
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .rev__body {
    position: relative;
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1.45;
    color: var(--color-text);
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    padding-left: 1.5rem;
  }
  .rev__mark {
    position: absolute;
    left: 0;
    top: -0.3rem;
    color: var(--color-gold);
    font-size: 2rem;
    line-height: 1;
  }
  .rev__cite {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 0.95rem;
  }
</style>
