---
// Phase 6 Part D — homepage service tiles read from Square's catalog
// (cached 30 min). Falls back to the content collection if the live
// fetch fails so the page never renders blank.
import { getCollection } from 'astro:content';
import ServiceCard from './ServiceCard.astro';
import { getServicesCached, toLiveServiceCards } from '../lib/catalog/liveServices';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isGhPages = import.meta.env.BASE_URL && import.meta.env.BASE_URL !== '/';
const bookUrl = isGhPages ? 'https://modern-classic.square.site' : `${base}/book`;

interface FeaturedCard {
  name: string;
  price: string;
  duration: string;
  audience: string | null;
  description: string;
  /**
   * Square variation ID used to deep-link this card straight into the
   * /book wizard's Step 2 (Choose your barber). Null when we're on the
   * content-collection fallback path — those entries have no variation
   * IDs, so the card falls through to the bare /book URL and the user
   * picks the service in Step 1.
   */
  variationId: string | null;
}

// The homepage carries 3 headline services. The slug list mirrors what's
// `featured: true` in the content collection, so the visual layout
// matches whether we hit the live catalog or the fallback.
const FEATURED_SLUGS = ['mens-haircut', 'haircut-beard', 'straight-razor-shave'];

let cards: FeaturedCard[] = [];
try {
  const live = await getServicesCached();
  const liveCards = toLiveServiceCards(live);
  cards = FEATURED_SLUGS.map((slug) => liveCards.find((c) => c.slug === slug))
    .filter((c): c is NonNullable<typeof c> => Boolean(c))
    .map((c) => ({
      name: c.name,
      price: c.priceLabel,
      duration: c.durationLabel,
      audience: c.audience,
      description: c.description,
      variationId: c.primaryVariationId,
    }));
  if (cards.length === 0) throw new Error('no featured services in live catalog');
} catch (err) {
  // eslint-disable-next-line no-console
  console.log(
    `[CATALOG] homepage live fetch failed, using content fallback: ${err instanceof Error ? err.message : String(err)}`,
  );
  const fallback = (await getCollection('services'))
    .filter((s) => s.data.featured)
    .sort((a, b) => a.data.order - b.data.order)
    .slice(0, 3)
    .map((s) => s.data);
  cards = fallback.map((s) => ({
    name: s.name,
    price: s.price,
    duration: s.duration,
    audience: s.audience,
    description: s.description,
    variationId: null,
  }));
}

function bookHrefFor(variationId: string | null): string {
  if (isGhPages) return bookUrl;
  return variationId ? `${bookUrl}?service=${encodeURIComponent(variationId)}` : bookUrl;
}
---
<section id="services" class="services" aria-labelledby="services-heading">
  <div class="container">
    <header class="section-head" data-reveal>
      <span class="eyebrow">In the Chair</span>
      <h2 id="services-heading">
        Services, <span class="italic-accent">tailored sharp.</span>
      </h2>
      <p class="lede">
        Every service finishes the same way — clean lines, confident style, and
        a take-home recommendation if you want to keep it that way at home.
      </p>
    </header>

    <div class="services__grid">
      {cards.map((s) => (
        <ServiceCard
          name={s.name}
          price={s.price}
          duration={s.duration}
          audience={s.audience}
          description={s.description}
          bookingUrl={bookHrefFor(s.variationId)}
        />
      ))}
    </div>

    <div class="services__foot">
      <a class="link-gold" href={`${base}/services`}>
        See full service menu &amp; pricing →
      </a>
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-bg);
    background-image: linear-gradient(180deg, var(--color-bg), var(--color-bg-soft));
    position: relative;
  }
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .services__foot {
    margin-top: var(--space-7);
    text-align: center;
  }
  @media (max-width: 880px) {
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .services__grid { grid-template-columns: 1fr; }
  }
</style>
