---
// Rotating reviews carousel — replaces the previous static 3-up grid.
// Crossfade transitions, 8s auto-advance, pauses on hover/focus/touch,
// respects prefers-reduced-motion (no auto-advance, manual only).

const reviews = [
  {
    pull: 'I drive nearly 2 hours roundtrip to come visit Mike for the best of cuts and skin fade he has.',
    full: "I started going to Michael over 6 years ago. Since I've moved to Columbus I drive nearly 2 hours roundtrip to come visit Mike for the best of cuts and skin fade he has. It's worth the drive every time.",
    name: 'Eric Locke',
    context: 'Drives nearly 2 hours for his cut',
  },
  {
    pull: "Rick gave me a great haircut and styled my hair using the shop's own line of products!",
    full: "Went in there to get my haircut after a few months of growth. Rick gave me a great haircut and styled my hair using the shop's own line of products! Highly recommend checking out their sea salt spray and cologne. Can't wait to come back!",
    name: 'Hunter Zizak',
    context: 'Recommends the in-house products',
  },
  {
    pull: 'Best barbershop in the area! Their professionalism is second to none.',
    full: 'Best barbershop in the area! Michael, Rick, and Clayton not only do a top notch job, but their professionalism is second to none. It is a clean, family environment. Thanks for all you guys do!',
    name: 'Bruce Trick',
    context: 'Long-time regular',
  },
  {
    pull: 'They paid great attention to detail and made him feel comfortable throughout the process.',
    full: "I had a fantastic experience with my 5-year-old son's haircut! They paid great attention to detail and really took the time to ensure the cut was perfect. Not only that, but they made him feel comfortable throughout the process. Highly recommend.",
    name: 'Vanessa Mineer',
    context: 'Brings her 5-year-old son',
  },
  {
    pull: "My beard hasn't been this sharp in ages!",
    full: "Michael is the best! Very warm and welcoming atmosphere. My beard hasn't been this sharp in ages!",
    name: 'Anthony Vasquez',
    context: 'Beard trim regular',
  },
];

const total = reviews.length;
const reviewsUrl = 'https://maps.app.goo.gl/YfX4xGxFwHc8rJRZ6';
const pad = (n: number) => String(n).padStart(2, '0');
---
<section class="reviews" aria-labelledby="reviews-heading">
  <div class="container">
    <header class="section-head section-head--center" data-reveal>
      <span class="eyebrow">Real Reviews</span>
      <h2 id="reviews-heading">
        From the <span class="italic-accent">Chair.</span>
      </h2>
      <p class="lede" style="text-align:center; margin-inline:auto;">
        From skin fades to beard trims and kids' cuts, our customers come back
        for the detail, the atmosphere, and the way they feel walking out.
      </p>
    </header>

    <div class="reviews__carousel"
         role="region"
         aria-roledescription="carousel"
         aria-label="Customer reviews"
         data-total={total}
         data-reveal
         style="--reveal-delay: 80ms">

      <button class="reviews__nav reviews__nav--prev"
              type="button"
              aria-label="Previous review"
              data-direction="-1">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
             stroke="currentColor" stroke-width="1.4"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15,5 8,12 15,19"/>
        </svg>
      </button>

      <div class="reviews__track" aria-live="polite">
        {reviews.map((r, i) => (
          <blockquote class="reviews__slide"
                      data-active={i === 0 ? 'true' : 'false'}
                      data-index={i}
                      aria-hidden={i === 0 ? 'false' : 'true'}>
            <p class="reviews__stars" aria-label="5 out of 5 stars">
              <span aria-hidden="true">★★★★★</span>
            </p>
            <p class="reviews__pull">&ldquo;{r.pull}&rdquo;</p>
            <p class="reviews__body">{r.full}</p>
            <cite class="reviews__cite">
              <span class="reviews__name">{r.name}</span>
              <span class="reviews__context">{r.context}</span>
              <span class="reviews__source">
                <svg class="g-mark" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Verified Google Review
              </span>
            </cite>
          </blockquote>
        ))}
      </div>

      <button class="reviews__nav reviews__nav--next"
              type="button"
              aria-label="Next review"
              data-direction="1">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
             stroke="currentColor" stroke-width="1.4"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9,5 16,12 9,19"/>
        </svg>
      </button>

      <p class="reviews__counter" aria-hidden="true">
        <span class="reviews__counter-current">{pad(1)}</span>
        <span class="reviews__counter-sep">/</span>
        <span class="reviews__counter-total">{pad(total)}</span>
      </p>
    </div>

    <div class="reviews__foot">
      <a class="reviews__all-link"
         href={reviewsUrl}
         target="_blank"
         rel="noopener noreferrer">
        <svg class="g-mark" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        See all 104 reviews on Google <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const carousel = document.querySelector('.reviews__carousel');
    if (!carousel) return;

    const slides = Array.from(carousel.querySelectorAll('.reviews__slide'));
    const counter = carousel.querySelector('.reviews__counter-current');
    const navButtons = carousel.querySelectorAll('.reviews__nav');
    const total = slides.length;
    const AUTO_MS = 8000;

    let current = 0;
    let timer = null;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const prefersReduced = () => reduceMotion.matches;

    const pad2 = (n) => String(n).padStart(2, '0');

    const show = (index) => {
      const next = ((index % total) + total) % total;
      slides.forEach((slide, i) => {
        const active = i === next;
        slide.dataset.active = active ? 'true' : 'false';
        slide.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      if (counter) counter.textContent = pad2(next + 1);
      current = next;
    };

    const stop = () => {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    };

    const start = () => {
      if (prefersReduced()) return;
      stop();
      timer = setInterval(() => show(current + 1), AUTO_MS);
    };

    navButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = Number(btn.dataset.direction || 1);
        show(current + dir);
        // User interaction restarts the auto-advance window so the next
        // auto-advance is a full 8s away.
        start();
      });
    });

    // Pause on hover, focus-within, and touch.
    ['mouseenter', 'focusin', 'touchstart'].forEach((evt) => {
      carousel.addEventListener(evt, stop, { passive: true });
    });
    ['mouseleave', 'focusout', 'touchend', 'touchcancel'].forEach((evt) => {
      carousel.addEventListener(evt, start, { passive: true });
    });

    // React to user toggling reduced-motion preference at runtime.
    reduceMotion.addEventListener?.('change', () => {
      if (prefersReduced()) stop();
      else start();
    });

    // Kick off (no-op when reduced-motion is on).
    start();
  })();
</script>

<style>
  .reviews {
    background: var(--color-bg-soft);
    /* Extra bottom padding on mobile so the sticky Book Now bar at the
       viewport bottom can never overlap the 'See all reviews' link. */
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }
  @media (max-width: 720px) {
    .reviews {
      padding-bottom: clamp(5rem, 10vw, 7rem);
    }
  }

  /* ---------- Carousel shell ---------- */
  .reviews__carousel {
    position: relative;
    max-width: 60rem;
    margin: 0 auto;
    padding: clamp(1rem, 3vw, 2.5rem) clamp(2.75rem, 5vw, 4rem) 3rem;
    /* Soft warm gold halo behind the card. */
    background:
      radial-gradient(circle at center,
        rgba(212, 175, 55, 0.15) 0%,
        rgba(212, 175, 55, 0.06) 40%,
        transparent 70%);
    border-radius: 4px;
  }

  /* The track lays all slides in the same grid cell so the visible card
     crossfades cleanly without layout shift. The container sizes to the
     tallest slide; shorter slides centre vertically. */
  .reviews__track {
    display: grid;
    grid-template-areas: 'stack';
    align-items: center;
    justify-items: stretch;
  }
  .reviews__slide {
    grid-area: stack;
    margin: 0;
    padding: clamp(1.75rem, 3vw, 2.75rem) clamp(1.25rem, 3vw, 2.5rem);
    background: linear-gradient(180deg, var(--color-surface), var(--color-bg-soft));
    border: 1px solid var(--color-rule);
    border-radius: 2px;
    text-align: center;
    color: var(--color-text);
    display: grid;
    gap: 1.1rem;
    justify-items: center;
    /* All slides occupy the same grid cell at the height of the tallest
       slide. Shorter slides get their content centred vertically so
       they don't sit at the top with empty space below. */
    align-content: center;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 600ms var(--ease), visibility 0s linear 600ms;
  }
  .reviews__slide[data-active='true'] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 600ms var(--ease), visibility 0s linear 0s;
  }

  /* ---------- Slide content ---------- */
  .reviews__stars {
    color: var(--color-gold);
    font-size: 1.05rem;
    letter-spacing: 0.18em;
    margin: 0;
  }
  .reviews__pull {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.25rem, 0.95rem + 1.6vw, 1.85rem);
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: var(--color-text);
    font-variation-settings: 'opsz' 144, 'SOFT' 80;
    max-width: 36ch;
    margin: 0 auto;
  }
  .reviews__body {
    color: var(--color-text-muted);
    font-size: 0.96rem;
    line-height: 1.6;
    max-width: 52ch;
    margin: 0 auto;
  }
  .reviews__cite {
    display: grid;
    gap: 0.3rem;
    font-style: normal;
    margin-top: 0.4rem;
  }
  .reviews__name {
    font-family: var(--font-body);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .reviews__context {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    font-style: italic;
    /* This single line shouldn't wrap aggressively. */
    max-width: 36ch;
    margin: 0 auto;
  }
  .reviews__source {
    color: var(--color-text-dim);
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-top: 0.45rem;
    /* Inline-flex so the Google G sits on the same baseline as the
       'Verified Google Review' caps, not on its own line. */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45em;
  }

  /* Official Google G — multi-color paths inline above. Sized to ≤ surrounding
     text (per brand spec — credibility mark, not design element). Colors must
     not be overridden, so currentColor is never used here. */
  .g-mark {
    width: 1em;
    height: 1em;
    flex: none;
    display: inline-block;
    vertical-align: -0.12em;
  }

  /* ---------- Nav arrows ---------- */
  .reviews__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.4rem;
    height: 2.4rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-rule);
    border-radius: 50%;
    color: var(--color-gold);
    background: rgba(11, 10, 8, 0.55);
    cursor: pointer;
    transition: border-color var(--dur) var(--ease),
                background var(--dur) var(--ease),
                color var(--dur) var(--ease);
    z-index: 2;
  }
  .reviews__nav:hover,
  .reviews__nav:focus-visible {
    border-color: var(--color-gold);
    color: var(--color-gold-light);
    background: rgba(201, 163, 92, 0.08);
  }
  .reviews__nav--prev { left: 0; }
  .reviews__nav--next { right: 0; }
  @media (max-width: 720px) {
    .reviews__nav {
      width: 2.1rem;
      height: 2.1rem;
    }
  }

  /* ---------- Counter ---------- */
  .reviews__counter {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    color: var(--color-gold);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-family: var(--font-body);
    font-weight: 600;
    display: inline-flex;
    gap: 0.4em;
  }
  .reviews__counter-sep { opacity: 0.55; }
  .reviews__counter-total { color: var(--color-text-dim); }

  /* ---------- See all reviews link ---------- */
  .reviews__foot {
    margin-top: var(--space-7);
    text-align: center;
  }
  .reviews__all-link {
    /* Already inline-flex; gap handles spacing between the G mark, the
       text, and the trailing arrow uniformly. */
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 4px;
    transition: color var(--dur) var(--ease),
                border-color var(--dur) var(--ease);
  }
  .reviews__all-link:hover,
  .reviews__all-link:focus-visible {
    color: var(--color-gold-light);
    border-bottom-color: var(--color-gold-light);
  }
  .reviews__all-link .arrow { transition: transform var(--dur) var(--ease); }
  .reviews__all-link:hover .arrow { transform: translateX(3px); }

  /* ---------- Reduced motion: skip the crossfade ---------- */
  @media (prefers-reduced-motion: reduce) {
    .reviews__slide,
    .reviews__slide[data-active='true'] {
      transition: none;
    }
  }
</style>
