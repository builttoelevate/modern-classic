---
// Strip trailing slash so concatenation always lands on a clean form.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isGhPages = import.meta.env.BASE_URL && import.meta.env.BASE_URL !== '/';
const bookHref = isGhPages ? 'https://modern-classic.square.site' : `${base}/book`;
const year = new Date().getFullYear();
const cols = [
  {
    title: 'The Shop',
    links: [
      { label: 'Services & Pricing', href: `${base}/services` },
      { label: 'Barbers', href: `${base}/barbers` },
      { label: 'Gallery', href: `${base}/gallery` },
      { label: 'About', href: `${base}/#about` },
      { label: 'Visit', href: `${base}/visit` },
      { label: 'Book a Visit', href: bookHref, external: isGhPages },
    ],
  },
  {
    title: 'Shop Products',
    links: [
      { label: 'All Products', href: `${base}/shop` },
      { label: 'Styling', href: 'https://mdrnclassic.com/collections/styling', external: true },
      { label: 'Texture & Finish', href: 'https://mdrnclassic.com/collections/texture-finish', external: true },
      { label: 'Shaving', href: 'https://mdrnclassic.com/collections/shaving', external: true },
      { label: 'Beard Care', href: 'https://mdrnclassic.com/collections/beard-care', external: true },
    ],
  },
  {
    title: 'Help',
    links: [
      { label: 'Contact', href: `${base}/visit#contact` },
      { label: 'FAQs', href: 'https://mdrnclassic.com/pages/faqs', external: true },
      { label: 'Shipping', href: 'https://mdrnclassic.com/pages/shipping-information', external: true },
      { label: 'Returns', href: 'https://mdrnclassic.com/pages/returns-exchanges', external: true },
      { label: 'Wholesale', href: 'https://mdrnclassic.com/pages/wholesale', external: true },
      { label: 'Privacy', href: 'https://mdrnclassic.com/policies/privacy-policy', external: true },
      { label: 'Terms', href: 'https://mdrnclassic.com/policies/terms-of-service', external: true },
    ],
  },
];
---
<footer class="footer">
  <hr class="rule" />
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__wordmark">
        <span>Modern</span><span class="footer__sep" aria-hidden="true">·</span><span>Classic</span>
      </p>
      <p class="footer__tag">Get the cut. <em class="italic-accent">Keep the style.</em></p>
      <p class="footer__about">
        Barbershop & Shave Parlor in Zanesville, Ohio. MDRN Classic Grooming
        Essentials LLC — premium grooming products built by barbers, shipped
        nationwide. Free shipping on orders over $60.
      </p>
      <ul class="footer__social" aria-label="Social">
        <li>
          <a href="https://www.instagram.com/modernclassicbarbershop/" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="4"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor"/>
            </svg>
          </a>
        </li>
        <li>
          <a href="https://www.facebook.com/profile.php?id=100090856771819" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 8h2.5V5h-2.5C12.6 5 11 6.3 11 8.2V11H8.5v3H11v7h3v-7h2.5l.5-3H14V8.5c0-.3.2-.5.5-.5z" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <nav class="footer__cols" aria-label="Footer">
      {cols.map((c) => (
        <div class="footer__col">
          <h3 class="footer__col-title">{c.title}</h3>
          <ul>
            {c.links.map((l) => (
              <li>
                <a href={l.href}
                   target={l.external ? '_blank' : undefined}
                   rel={l.external ? 'noopener' : undefined}>
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <div class="footer__bar">
    <div class="container footer__bar-inner">
      <p>© {year} MDRN Classic Grooming Essentials LLC. All rights reserved.</p>
      <p class="footer__bar-locale">819 Linden Ave · Zanesville, OH 43701</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(180deg, var(--color-bg-soft), #050403);
    color: var(--color-text-muted);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-block: clamp(3rem, 6vw, 5rem);
  }
  .footer__brand { max-width: 28rem; }
  .footer__wordmark {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--color-text);
    letter-spacing: 0.01em;
    font-variation-settings: 'opsz' 80;
  }
  .footer__sep { color: var(--color-gold); margin-inline: 0.4em; }
  .footer__tag {
    margin-top: 0.5rem;
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.04em;
  }
  .footer__tag em { color: var(--color-gold-light); font-weight: 300; }
  .footer__about {
    margin-top: 1.25rem;
    font-size: 0.94rem;
    line-height: 1.6;
  }
  .footer__social {
    display: flex;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
  }
  .footer__social a {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-gold);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .footer__social a:hover {
    border-color: var(--color-gold);
    color: var(--color-gold-light);
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  .footer__col-title {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  .footer__col ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem; }
  .footer__col a {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    transition: color var(--dur) var(--ease);
  }
  .footer__col a:hover { color: var(--color-text); }

  .footer__bar {
    border-top: 1px solid var(--color-border-soft);
    padding-block: 1.25rem;
  }
  .footer__bar-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    justify-content: space-between;
    align-items: center;
    font-size: 0.82rem;
    color: var(--color-text-dim);
  }
  .footer__bar-locale { color: var(--color-text-muted); letter-spacing: 0.05em; }

  @media (max-width: 760px) {
    .footer__inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .footer__cols { grid-template-columns: 1fr 1fr; }
  }
</style>
