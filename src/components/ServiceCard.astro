---
interface Props {
  name: string;
  price: string;
  duration: string;
  audience: string | null;
  description: string;
  bookingUrl: string;
}
const { name, price, duration, audience, description, bookingUrl } = Astro.props;
---
<article class="svc" data-reveal>
  <header class="svc__head">
    <h3 class="svc__name">{name}</h3>
    <span class="svc__price" aria-label={`Price ${price}`}>{price}</span>
  </header>
  <p class="svc__meta">
    <span>{duration}</span>
    {audience && <><span aria-hidden="true">·</span><span>{audience}</span></>}
  </p>
  <p class="svc__desc">{description}</p>
  <a class="svc__cta" href={bookingUrl} target="_blank" rel="noopener">
    Book <span class="arrow" aria-hidden="true">→</span>
  </a>
</article>

<style>
  .svc {
    --bd: var(--color-border);
    position: relative;
    display: grid;
    gap: 0.7rem;
    padding: clamp(1.5rem, 2.4vw, 2rem);
    background: linear-gradient(180deg, var(--color-surface), var(--color-bg-soft));
    border: 1px solid var(--bd);
    border-radius: 2px;
    transition: border-color var(--dur) var(--ease),
                transform var(--dur) var(--ease),
                box-shadow var(--dur) var(--ease);
  }
  .svc::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px; right: -1px;
    height: 2px;
    background: linear-gradient(90deg,
      transparent, var(--color-gold), var(--color-gold-dark), transparent);
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .svc:hover {
    border-color: rgba(201, 163, 92, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 14px 40px -20px rgba(0,0,0,0.7);
  }
  .svc:hover::before { opacity: 1; }

  .svc__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .svc__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
    font-variation-settings: 'opsz' 144, 'SOFT' 40;
  }
  .svc__price {
    /* Cleaner sans rather than the decorative display serif used for
       the service name — the numerals (and the dollar sign) need to
       scan instantly at small size. Same family, weight, and colour
       across the whole price string ($30, $30–45, etc). */
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.005em;
    /* One step brighter than --color-gold so the small numerals hold
       contrast against the dark card. Other gold elements unchanged. */
    color: var(--color-gold-light);
    white-space: nowrap;
  }
  .svc__meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    color: var(--color-text-dim);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .svc__meta span[aria-hidden] { color: var(--color-gold); opacity: 0.7; }
  .svc__desc {
    color: var(--color-text-muted);
    font-size: 0.98rem;
    line-height: 1.55;
  }
  .svc__cta {
    margin-top: auto;
    padding-top: 0.5rem;
    color: var(--color-gold);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: start;
  }
  .svc__cta:hover { color: var(--color-gold-light); }
  .svc__cta:hover .arrow { transform: translateX(3px); }
  .svc__cta .arrow { transition: transform var(--dur) var(--ease); }
</style>
