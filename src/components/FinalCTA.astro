---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isGhPages = import.meta.env.BASE_URL && import.meta.env.BASE_URL !== '/';
const bookUrl = isGhPages ? 'https://modern-classic.square.site' : `${base}/book`;
const bookTarget = isGhPages ? '_blank' : '_self';
const bookRel = isGhPages ? 'noopener' : '';
---
<section class="fcta" aria-labelledby="fcta-heading">
  <div class="container fcta__inner" data-reveal>
    <div class="fcta__ornament" aria-hidden="true">
      <span></span><span class="diamond"></span><span></span>
    </div>
    <h2 id="fcta-heading" class="fcta__heading">
      Ready for a <span class="italic-accent">fresh cut?</span>
    </h2>
    <p class="lede" style="text-align:center; margin-inline:auto;">
      Book your chair, then take the style home with you.
    </p>
    <div class="fcta__ctas">
      <a class="btn" href={bookUrl} target={bookTarget} rel={bookRel}>
        Book a Visit <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a class="btn btn--ghost" href="#products">
        Shop Grooming Products
      </a>
    </div>
  </div>
</section>

<style>
  .fcta {
    background:
      radial-gradient(900px 360px at 50% 0%, rgba(201,163,92,0.10), transparent 70%),
      linear-gradient(180deg, var(--color-bg-soft), var(--color-bg));
    border-top: 1px solid var(--color-border-soft);
    border-bottom: 1px solid var(--color-border-soft);
  }
  .fcta__inner {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.25rem;
  }
  .fcta__ornament {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-gold);
  }
  .fcta__ornament span:not(.diamond) {
    display: block;
    width: clamp(48px, 8vw, 96px);
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-gold), transparent);
  }
  .fcta__heading { font-size: clamp(2.25rem, 1.5rem + 4vw, 4rem); }
  .fcta__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
</style>
