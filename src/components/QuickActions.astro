---
import { getServicesCached, toLiveServiceCards } from '../lib/catalog/liveServices';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isGhPages = import.meta.env.BASE_URL && import.meta.env.BASE_URL !== '/';
const bookHref = isGhPages ? 'https://modern-classic.square.site' : `${base}/book`;
const bookExternal = isGhPages;

// Resolve live variation IDs so each modal CTA can deep-link straight into
// Step 2 (Choose your barber) with the service preselected. Falls back to
// the bare /book URL if the live catalog fetch fails.
const NEEDED = ['mens-haircut', 'kids-haircut', 'haircut-beard', 'beard-trim-edge', 'new-customer'] as const;
const slugToVariation: Record<(typeof NEEDED)[number], string | null> = {
  'mens-haircut': null,
  'kids-haircut': null,
  'haircut-beard': null,
  'beard-trim-edge': null,
  'new-customer': null,
};
try {
  const live = await getServicesCached();
  const cards = toLiveServiceCards(live);
  for (const slug of NEEDED) {
    const found = cards.find((c) => c.slug === slug);
    if (found?.primaryVariationId) slugToVariation[slug] = found.primaryVariationId;
  }
} catch {
  // Silent — the fallback href handles missing variations.
}

function deepLink(slug: (typeof NEEDED)[number]): string {
  if (isGhPages) return bookHref;
  const v = slugToVariation[slug];
  return v ? `${bookHref}?service=${encodeURIComponent(v)}` : bookHref;
}
---
<section class="quick" aria-label="Quick actions">
  <hr class="rule" />
  <div class="container quick__grid">
    <button type="button" class="quick__card" data-qa-open="haircut" data-emphasis="primary" aria-haspopup="dialog">
      <span class="quick__glyph" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="6.5" cy="7" r="2.4"/>
          <circle cx="6.5" cy="17" r="2.4"/>
          <path d="M8.6 8.7 L20 18"/>
          <path d="M8.6 15.3 L20 6"/>
          <line x1="11.2" y1="12" x2="13.8" y2="12"/>
        </svg>
      </span>
      <span class="quick__body">
        <span class="quick__label">Book a Haircut</span>
        <span class="quick__sub">In-and-out, sharp.</span>
      </span>
      <span class="quick__pill" aria-hidden="true">
        <span class="quick__pill-text">Book</span>
        <span class="quick__pill-arrow">→</span>
      </span>
    </button>

    <button type="button" class="quick__card" data-qa-open="beard" aria-haspopup="dialog">
      <span class="quick__glyph" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.4" stroke-linejoin="round">
          <path d="M12 3 L21 12 L12 21 L3 12 Z"/>
          <path d="M7.5 12 L12 7.5 L16.5 12 L12 16.5 Z"/>
        </svg>
      </span>
      <span class="quick__body">
        <span class="quick__label">Beard Work</span>
        <span class="quick__sub">The full grooming.</span>
      </span>
      <span class="quick__pill" aria-hidden="true">
        <span class="quick__pill-text">Book</span>
        <span class="quick__pill-arrow">→</span>
      </span>
    </button>

    <a class="quick__card" href={`${base}/shop`}>
      <span class="quick__glyph" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3 L12 13"/>
          <path d="M12 6 C 8 8, 7 11, 7.5 13.5 C 7.8 14.6 8.6 15 9.5 15"/>
          <path d="M12 6 C 16 8, 17 11, 16.5 13.5 C 16.2 14.6 15.4 15 14.5 15"/>
          <line x1="8" y1="16" x2="16" y2="16"/>
          <path d="M12 16 L12 21"/>
          <circle cx="12" cy="6" r="0.7" fill="currentColor"/>
        </svg>
      </span>
      <span class="quick__body">
        <span class="quick__label">Shop Products</span>
        <span class="quick__sub">Built by barbers.</span>
      </span>
      <span class="quick__pill" aria-hidden="true">
        <span class="quick__pill-text">Shop</span>
        <span class="quick__pill-arrow">→</span>
      </span>
    </a>

    <a class="quick__card" href={deepLink('new-customer')}>
      <span class="quick__glyph" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.3" stroke-linejoin="round">
          <polygon points="12,3 14.35,8.76 20.56,9.22 15.8,13.24 17.29,19.28 12,16 6.71,19.28 8.2,13.24 3.44,9.22 9.65,8.76"/>
        </svg>
      </span>
      <span class="quick__body">
        <span class="quick__label">First Visit</span>
        <span class="quick__sub">Start here.</span>
      </span>
      <span class="quick__pill" aria-hidden="true">
        <span class="quick__pill-text">Start Here</span>
        <span class="quick__pill-arrow">→</span>
      </span>
    </a>
  </div>
  <hr class="rule" />
</section>

{/* ---------- Modals ---------- */}

<dialog id="qa-modal-haircut" class="qa-modal" aria-labelledby="qa-haircut-title">
  <div class="qa-modal__panel">
    <header class="qa-modal__head">
      <p class="qa-modal__eyebrow">Choose your cut</p>
      <h3 id="qa-haircut-title">What kind of haircut?</h3>
      <button type="button" class="qa-modal__close" data-qa-close aria-label="Close">×</button>
    </header>
    <ul class="qa-modal__list" role="list">
      <li>
        <a class="qa-option" href={deepLink('mens-haircut')}>
          <span class="qa-option__name">Men's Haircut</span>
          <span class="qa-option__sub">Standard cut. Clean lines, your style.</span>
          <span class="qa-option__arrow" aria-hidden="true">→</span>
        </a>
      </li>
      <li>
        <a class="qa-option" href={deepLink('kids-haircut')}>
          <span class="qa-option__name">Kids' Haircut</span>
          <span class="qa-option__sub">Calm chair, patient cut. 10 &amp; under.</span>
          <span class="qa-option__arrow" aria-hidden="true">→</span>
        </a>
      </li>
      <li>
        <a class="qa-option" href={deepLink('haircut-beard')}>
          <span class="qa-option__name">Haircut &amp; Beard</span>
          <span class="qa-option__sub">Full service — cut, edges, beard sculpt.</span>
          <span class="qa-option__arrow" aria-hidden="true">→</span>
        </a>
      </li>
    </ul>
  </div>
</dialog>

<dialog id="qa-modal-beard" class="qa-modal" aria-labelledby="qa-beard-title">
  <div class="qa-modal__panel">
    <header class="qa-modal__head">
      <p class="qa-modal__eyebrow">Beard work</p>
      <h3 id="qa-beard-title">Just the beard, or the full set?</h3>
      <button type="button" class="qa-modal__close" data-qa-close aria-label="Close">×</button>
    </header>
    <ul class="qa-modal__list" role="list">
      <li>
        <a class="qa-option" href={deepLink('haircut-beard')}>
          <span class="qa-option__name">Haircut &amp; Beard</span>
          <span class="qa-option__sub">Cut, edges, and a full beard sculpt — the works.</span>
          <span class="qa-option__arrow" aria-hidden="true">→</span>
        </a>
      </li>
      <li>
        <a class="qa-option" href={deepLink('beard-trim-edge')}>
          <span class="qa-option__name">Beard Trim &amp; Edge</span>
          <span class="qa-option__sub">Beard only — line, shape, detail.</span>
          <span class="qa-option__arrow" aria-hidden="true">→</span>
        </a>
      </li>
    </ul>
  </div>
</dialog>


<style>
  .quick {
    padding-block: 0;
    background: var(--color-bg);
    position: relative;
    z-index: 2;
  }
  .quick__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    padding: clamp(1rem, 2vw, 1.5rem) 0;
  }
  .quick__card {
    --pad: clamp(1rem, 2.2vw, 1.4rem);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.9rem;
    padding: var(--pad);
    /* Visible thin gold border + dark surface so the cards read as
       proper buttons. The CTA pill on the right is the eye-catcher;
       the border + lift give the whole card click-affordance. */
    background: linear-gradient(180deg, var(--color-surface), var(--color-bg-soft));
    color: var(--color-text);
    border: 1px solid rgba(201, 163, 92, 0.42);
    border-radius: 6px;
    text-align: left;
    cursor: pointer;
    font: inherit;
    box-shadow: 0 6px 18px -12px rgba(0, 0, 0, 0.7);
    transition: background 180ms ease-out,
                border-color 180ms ease-out,
                transform 180ms ease-out,
                box-shadow 180ms ease-out;
    position: relative;
    text-decoration: none;
    width: 100%;
  }
  .quick__card:hover,
  .quick__card:focus-visible {
    border-color: var(--color-gold);
    background: linear-gradient(180deg, var(--color-surface-2), rgba(201, 163, 92, 0.05));
    transform: translateY(-3px);
    box-shadow: 0 14px 32px -14px rgba(0, 0, 0, 0.85);
  }
  .quick__card:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
  }
  .quick__card:active {
    transform: translateY(0);
    box-shadow: 0 0 0 3px rgba(201, 163, 92, 0.18),
                0 6px 18px -12px rgba(0, 0, 0, 0.7);
    transition-duration: 80ms;
  }

  /* Primary emphasis — Book a Haircut. Reads as 'most important'
     without solid-gold filling the card (which would compete with the
     hero's BOOK AN APPOINTMENT button). */
  .quick__card[data-emphasis='primary'] {
    border-color: var(--color-gold);
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(201, 163, 92, 0.10), transparent 70%),
      linear-gradient(180deg, var(--color-surface), var(--color-bg-soft));
    box-shadow: 0 8px 22px -12px rgba(0, 0, 0, 0.75),
                inset 0 0 0 1px rgba(230, 199, 133, 0.08);
  }
  .quick__card[data-emphasis='primary']:hover,
  .quick__card[data-emphasis='primary']:focus-visible {
    border-color: var(--color-gold-light);
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(201, 163, 92, 0.16), transparent 70%),
      linear-gradient(180deg, var(--color-surface-2), rgba(201, 163, 92, 0.07));
  }

  .quick__glyph {
    color: var(--color-gold-light);
    width: 2.6rem;
    height: 2.6rem;
    display: grid;
    place-items: center;
    border: 1px solid rgba(201, 163, 92, 0.45);
    border-radius: 50%;
    transition: border-color 180ms ease-out, background 180ms ease-out;
  }
  .quick__glyph svg {
    width: 1.3rem;
    height: 1.3rem;
    display: block;
  }
  .quick__card:hover .quick__glyph,
  .quick__card:focus-visible .quick__glyph {
    border-color: var(--color-gold);
    background: rgba(201, 163, 92, 0.08);
  }

  .quick__body { display: grid; gap: 0.2rem; min-width: 0; }
  .quick__label {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    color: var(--color-text);
    font-variation-settings: 'opsz' 100;
  }
  .quick__sub {
    font-size: 0.86rem;
    color: var(--color-text);
    opacity: 0.78;
    letter-spacing: 0.04em;
  }

  /* Gold CTA pill on the right of every card. Same gold token as the
     hero "BOOK AN APPOINTMENT" button so the visual language matches. */
  .quick__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    background: var(--color-gold);
    color: var(--color-text-on-gold);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: background 180ms ease-out, color 180ms ease-out, transform 180ms ease-out;
  }
  .quick__pill-arrow {
    display: inline-block;
    transition: transform 180ms ease-out;
  }
  .quick__card:hover .quick__pill,
  .quick__card:focus-visible .quick__pill {
    background: var(--color-gold-light);
  }
  .quick__card:hover .quick__pill-arrow,
  .quick__card:focus-visible .quick__pill-arrow {
    transform: translateX(3px);
  }
  /* Primary card pill is one step brighter at rest already, so it
     leans toward gold-light without going as far as gold-light's
     hover state. Hover lifts it the rest of the way. */
  .quick__card[data-emphasis='primary'] .quick__pill {
    background: var(--color-gold-light);
  }
  .quick__card[data-emphasis='primary']:hover .quick__pill,
  .quick__card[data-emphasis='primary']:focus-visible .quick__pill {
    background: #f1d59b;
  }

  @media (max-width: 880px) {
    .quick__grid { grid-template-columns: repeat(2, 1fr); }
    /* Stack the pill below the body so the title gets the full row.
       At 2-col widths the title was colliding with the pill (e.g.
       'Book a Haircut' overlapping 'BOOK →', 'First Visit'
       overlapping 'START HERE →'). */
    .quick__card {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      row-gap: 0.55rem;
      align-items: start;
    }
    .quick__glyph { grid-row: 1; align-self: center; }
    .quick__body {
      grid-column: 2;
      grid-row: 1;
      align-self: center;
    }
    .quick__pill {
      grid-column: 2;
      grid-row: 2;
      justify-self: end;
    }
  }
  @media (max-width: 520px) {
    .quick__card { gap: 0.7rem; }
    .quick__pill { padding: 0.4rem 0.7rem; font-size: 0.72rem; }
  }
  @media (max-width: 460px) {
    .quick__sub { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .quick__card,
    .quick__pill,
    .quick__pill-arrow,
    .quick__glyph { transition: none; }
    .quick__card:hover,
    .quick__card:focus-visible { transform: none; }
  }

  /* ---------- Modal ---------- */
  .qa-modal {
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--color-text);
    max-width: min(520px, 92vw);
    width: 100%;
    margin: auto;
  }
  .qa-modal::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .qa-modal__panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 12px);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.8);
    display: grid;
    gap: 1rem;
  }
  .qa-modal__head {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 0.5rem;
    align-items: start;
  }
  .qa-modal__eyebrow {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
    margin: 0 0 0.25rem;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .qa-modal__head h3 {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1.1rem + 0.7vw, 1.7rem);
    color: var(--color-text);
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    line-height: 1.2;
  }
  .qa-modal__close {
    grid-column: 2 / 3;
    grid-row: 1 / 3;
    align-self: start;
    background: transparent;
    border: 0;
    color: var(--color-text-muted);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
  }
  .qa-modal__close:hover { color: var(--color-text); }
  .qa-modal__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .qa-option {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    background: var(--color-bg-soft, rgba(255,255,255,0.02));
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .qa-option:hover {
    border-color: var(--color-gold);
    background: rgba(201, 163, 92, 0.05);
    transform: translateY(-1px);
  }
  .qa-option__name {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-text);
  }
  .qa-option__sub {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }
  .qa-option__arrow {
    grid-column: 2 / 3;
    grid-row: 1 / 3;
    color: var(--color-gold);
    align-self: center;
    transition: transform var(--dur) var(--ease);
  }
  .qa-option:hover .qa-option__arrow { transform: translateX(3px); }

  .qa-modal__body { display: grid; gap: 0.85rem; }
  .qa-modal__body p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.55;
    font-size: 0.95rem;
  }
  .qa-tips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }
  .qa-tips li {
    padding-left: 1.25rem;
    position: relative;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .qa-tips li::before {
    content: '·';
    position: absolute;
    left: 0.45rem;
    top: 0;
    color: var(--color-gold);
    font-weight: 700;
  }
  .qa-tips strong { color: var(--color-text); font-weight: 600; }
  .qa-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
    padding: 0.85rem 1.2rem;
    background: var(--color-gold);
    color: var(--color-bg);
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 6px;
    text-decoration: none;
    transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .qa-cta:hover {
    background: var(--color-gold-light);
    transform: translateY(-1px);
  }
</style>

<script is:inline>
  (function () {
    const triggers = document.querySelectorAll('[data-qa-open]');
    triggers.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = `qa-modal-${btn.getAttribute('data-qa-open')}`;
        const dlg = document.getElementById(id);
        if (dlg && typeof dlg.showModal === 'function') {
          dlg.showModal();
        } else if (dlg) {
          // Fallback for browsers without <dialog> support — just fall
          // through to /book on the deep-link the modal would have shown.
          dlg.setAttribute('open', 'open');
        }
      });
    });

    // Close buttons inside any modal.
    document.querySelectorAll('[data-qa-close]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dlg = btn.closest('dialog');
        if (dlg && typeof dlg.close === 'function') dlg.close();
        else if (dlg) dlg.removeAttribute('open');
      });
    });

    // Click on the backdrop (the dialog itself, outside the panel) closes.
    document.querySelectorAll('dialog.qa-modal').forEach((dlg) => {
      dlg.addEventListener('click', (e) => {
        if (e.target === dlg) {
          if (typeof dlg.close === 'function') dlg.close();
          else dlg.removeAttribute('open');
        }
      });
    });
  })();
</script>
