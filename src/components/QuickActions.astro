---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isGhPages = import.meta.env.BASE_URL && import.meta.env.BASE_URL !== '/';
const bookHref = isGhPages ? 'https://modern-classic.square.site' : `${base}/book`;
const bookExternal = isGhPages;

const actions = [
  {
    label: 'Book a Haircut',
    sub: 'In-and-out, sharp.',
    href: bookHref,
    icon: 'scissors',
    external: bookExternal,
  },
  {
    label: 'Cut + Beard',
    sub: 'The full grooming.',
    href: bookHref,
    icon: 'diamond',
    external: bookExternal,
  },
  {
    label: 'Shop Products',
    sub: 'Built by barbers.',
    href: '#products',
    icon: 'fleur',
    external: false,
  },
  {
    label: 'First Visit',
    sub: 'Start here.',
    href: bookHref,
    icon: 'star',
    external: bookExternal,
  },
];
---
<section class="quick" aria-label="Quick actions">
  <hr class="rule" />
  <div class="container quick__grid">
    {actions.map((a) => (
      <a class="quick__card"
         href={a.href}
         target={a.external ? '_blank' : undefined}
         rel={a.external ? 'noopener' : undefined}>
        <span class="quick__glyph" aria-hidden="true">
          {a.icon === 'scissors' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="6.5" cy="7" r="2.4"/>
              <circle cx="6.5" cy="17" r="2.4"/>
              <path d="M8.6 8.7 L20 18"/>
              <path d="M8.6 15.3 L20 6"/>
              <line x1="11.2" y1="12" x2="13.8" y2="12"/>
            </svg>
          )}
          {a.icon === 'diamond' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.4" stroke-linejoin="round">
              <path d="M12 3 L21 12 L12 21 L3 12 Z"/>
              <path d="M7.5 12 L12 7.5 L16.5 12 L12 16.5 Z"/>
            </svg>
          )}
          {a.icon === 'fleur' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3 L12 13"/>
              <path d="M12 6 C 8 8, 7 11, 7.5 13.5 C 7.8 14.6 8.6 15 9.5 15"/>
              <path d="M12 6 C 16 8, 17 11, 16.5 13.5 C 16.2 14.6 15.4 15 14.5 15"/>
              <line x1="8" y1="16" x2="16" y2="16"/>
              <path d="M12 16 L12 21"/>
              <circle cx="12" cy="6" r="0.7" fill="currentColor"/>
            </svg>
          )}
          {a.icon === 'star' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.3" stroke-linejoin="round">
              <polygon points="12,3 14.35,8.76 20.56,9.22 15.8,13.24 17.29,19.28 12,16 6.71,19.28 8.2,13.24 3.44,9.22 9.65,8.76"/>
            </svg>
          )}
        </span>
        <span class="quick__body">
          <span class="quick__label">{a.label}</span>
          <span class="quick__sub">{a.sub}</span>
        </span>
        <span class="quick__arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
  <hr class="rule" />
</section>

<style>
  .quick {
    padding-block: 0;
    background: var(--color-bg);
    position: relative;
    z-index: 2;
  }
  .quick__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .quick__card {
    --pad: clamp(1.1rem, 2.4vw, 1.6rem);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.9rem;
    padding: var(--pad);
    border-right: 1px solid var(--color-border-soft);
    color: var(--color-text);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
    position: relative;
  }
  .quick__card:last-child { border-right: 0; }
  .quick__card::before {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 2px;
    background: var(--color-gold);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur) var(--ease);
  }
  .quick__card:hover { background: rgba(201, 163, 92, 0.04); }
  .quick__card:hover::before { transform: scaleX(1); }

  .quick__glyph {
    color: var(--color-gold);
    width: 2.4rem;
    height: 2.4rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-rule);
    border-radius: 50%;
    transition: border-color var(--dur) var(--ease);
  }
  .quick__glyph svg {
    width: 1.25rem;
    height: 1.25rem;
    display: block;
  }
  .quick__card:hover .quick__glyph { border-color: var(--color-gold); }

  .quick__body { display: grid; gap: 0.15rem; }
  .quick__label {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--color-text);
    font-variation-settings: 'opsz' 100;
  }
  .quick__sub {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .quick__arrow {
    color: var(--color-gold);
    transition: transform var(--dur) var(--ease);
  }
  .quick__card:hover .quick__arrow { transform: translateX(4px); }

  @media (max-width: 880px) {
    .quick__grid { grid-template-columns: repeat(2, 1fr); }
    .quick__card:nth-child(2) { border-right: 0; }
    .quick__card:nth-child(1),
    .quick__card:nth-child(2) { border-bottom: 1px solid var(--color-border-soft); }
  }
  @media (max-width: 460px) {
    .quick__sub { display: none; }
  }
</style>
