---
const nav = [
  { href: '#services', label: 'Services' },
  { href: '#products', label: 'Shop' },
  { href: '#story', label: 'About' },
  { href: '#location', label: 'Visit' },
];
---
<header class="site-header" data-elevated="false">
  <div class="container header-inner">
    <a class="wordmark" href="/" aria-label="Modern Classic — home">
      <span class="wordmark__primary">Modern</span>
      <span class="wordmark__sep" aria-hidden="true">·</span>
      <span class="wordmark__primary">Classic</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <ul>
        {nav.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>

    <a class="btn btn--small book-cta" href="https://modern-classic.square.site"
       target="_blank" rel="noopener">
      Book Now <span class="arrow" aria-hidden="true">→</span>
    </a>
  </div>
  <hr class="rule rule--header" />
</header>

<script is:inline>
  // Add elevation shadow / background after a small scroll
  (function () {
    const header = document.querySelector('.site-header');
    if (!header) return;
    const onScroll = () => {
      header.dataset.elevated = window.scrollY > 8 ? 'true' : 'false';
    };
    document.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 70%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    transition: background var(--dur) var(--ease),
                box-shadow var(--dur) var(--ease);
  }
  .site-header[data-elevated='true'] {
    background: color-mix(in oklab, var(--color-bg) 92%, transparent);
    box-shadow: 0 8px 30px -16px rgba(0,0,0,0.6);
  }
  .header-inner {
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }
  .rule--header {
    margin: 0;
    opacity: 0.55;
  }

  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45em;
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-text);
    font-variation-settings: 'opsz' 60, 'SOFT' 30;
    transition: color var(--dur) var(--ease);
  }
  .wordmark__sep {
    color: var(--color-gold);
    font-size: 1.4em;
    line-height: 0;
    transform: translateY(-0.05em);
  }
  .wordmark:hover { color: var(--color-gold-light); }

  .nav ul {
    display: flex;
    gap: clamp(1rem, 2.4vw, 2.25rem);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav a {
    font-size: 0.86rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0.4rem 0;
    position: relative;
  }
  .nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--color-gold);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur) var(--ease);
  }
  .nav a:hover { color: var(--color-text); }
  .nav a:hover::after { transform: scaleX(1); }

  @media (max-width: 820px) {
    .nav { display: none; }
  }
  @media (max-width: 480px) {
    .wordmark__sep { display: none; }
    .wordmark { gap: 0.25em; }
    .book-cta { padding: 0.55em 0.9em; font-size: 0.78rem; }
  }
</style>
