---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  /** Set true on the home + visit pages to emit the LocalBusiness JSON-LD. */
  includeBusinessSchema?: boolean;
  /** Optional extra JSON-LD object (e.g. ItemList for /services, /shop). */
  extraSchema?: unknown;
}

const {
  title = 'Modern Classic Barbershop & Shave Parlor — Zanesville, OH',
  description = "Modern Classic is a Zanesville barbershop and grooming brand. Premium men's haircuts, fades, beard trims, and straight razor shaves — plus MDRN Classic grooming products built by barbers.",
  ogImage = '/og-image-v5.png',
  canonical,
  includeBusinessSchema = false,
  extraSchema,
} = Astro.props;

// The barbershop website lives at modernclassicbarbershop.com. The
// product Shopify storefront at mdrnclassic.com is a separate site
// (linked from the shop products section) — using it here as the
// canonical host caused every page's og:url + <link rel="canonical">
// to point at the Shopify store, so when a customer pasted the
// barbershop URL into iMessage / Slack / etc., the preview re-routed
// to the storefront. Using the actual barbershop hostname keeps
// shared previews on the right site.
const siteUrl = 'https://modernclassicbarbershop.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
// Cache-busting suffix for the OG image. iMessage / Slack / Discord cache
// preview images by URL forever — bump this version when the artwork
// changes so chat clients refetch instead of showing the old preview.
// We also rename the file (og-image-vN.png) when bumping, since some
// clients (notably iMessage) ignore query strings when caching.
const OG_IMAGE_VERSION = '5';
const ogImageUrl = (() => {
  const url = new URL(ogImage, siteUrl);
  url.searchParams.set('v', OG_IMAGE_VERSION);
  return url.toString();
})();

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'HairSalon',
  '@id': `${siteUrl}/#shop`,
  name: 'Modern Classic Barbershop & Shave Parlor',
  legalName: 'MDRN Classic Grooming Essentials LLC',
  alternateName: 'MDRN Classic',
  description,
  url: siteUrl,
  image: ogImageUrl,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '819 Linden Avenue',
    addressLocality: 'Zanesville',
    addressRegion: 'OH',
    postalCode: '43701',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 39.9534,
    longitude: -82.0177,
  },
  email: 'modernclassicbarbershop@protonmail.com',
  // TODO: replace with real opening hours when owner confirms
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '09:00',
      closes: '18:00',
    },
  ],
  sameAs: [
    'https://www.facebook.com/profile.php?id=100090856771819',
    'https://www.instagram.com/modernclassicbarbershop/',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Barbershop services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: "Men's Haircut" }, price: '30', priceCurrency: 'USD' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Haircut & Beard' }, price: '45', priceCurrency: 'USD' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Straight Razor Shave' }, price: '30', priceCurrency: 'USD' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Beard Trim & Edge' }, price: '25', priceCurrency: 'USD' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Kids Haircut' }, price: '25', priceCurrency: 'USD' },
    ],
  },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#0b0a08" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Modern Classic Barbershop & Shave Parlor — vintage gold badge over the shop interior" />
    <meta property="og:site_name" content="Modern Classic" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Modern Classic Barbershop & Shave Parlor" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-blocking font CSS load: preload as style, then activate. Falls
         back to a regular stylesheet if JS is disabled. font-display: swap
         is already set in the URL so we never get a FOIT. -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,30..100;1,9..144,300..700,30..100&family=Manrope:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,30..100;1,9..144,300..700,30..100&family=Manrope:wght@400;500;600;700&display=swap"
      />
    </noscript>

    {includeBusinessSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
    )}
    {extraSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />
    )}

    <!-- Set the reveal-ready flag on <html> before body parses so reveal
         targets paint at opacity 0 from the very first frame. Without JS,
         this attribute never lands and content shows normally. -->
    <script is:inline>
      document.documentElement.setAttribute('data-reveal-ready', '');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />

    <!-- Scroll-reveal observer. Fires once per target. If prefers-reduced-motion
         is on, every reveal target is marked is-revealed immediately and the
         observer is never created. -->
    <script is:inline>
      (function () {
        var targets = document.querySelectorAll('[data-reveal]');
        if (!targets.length) return;

        var reduceMotion = window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (reduceMotion || !('IntersectionObserver' in window)) {
          targets.forEach(function (el) { el.classList.add('is-revealed'); });
          return;
        }

        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              io.unobserve(entry.target);
            }
          });
        }, {
          // Start the reveal a hair before the element fully enters the
          // viewport — feels more responsive on long scrolls.
          rootMargin: '0px 0px -8% 0px',
          threshold: 0.05,
        });

        targets.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
