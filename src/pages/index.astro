---
// Phase 6 — switched from static prerender to SSR so the hero can show
// live availability tailored to whether the visitor is signed in.
// Behind a 10-min cache, so most renders are sub-100ms.
//
// On the gh-pages preview (output: 'static'), we stay prerendered with
// a build-time snapshot of "soonest across barbers" — no auth, no
// per-request data. The Vercel deploy is the real SSR experience.
export const prerender = process.env.DEPLOY_TARGET === 'gh-pages';

import BaseLayout from '../layouts/BaseLayout.astro';
// The hero's "Join the waitlist" trigger mounts the booking flow's
// WaitlistSheet via portal. Its styles live in booking.css alongside
// the rest of the booking-flow UI; without this import on the
// homepage the sheet would mount into document.body unstyled and
// render invisibly.
import '../styles/booking.css';
import Header from '../components/Header.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Hero from '../components/Hero.astro';
import QuickActions from '../components/QuickActions.astro';
import Barbers from '../components/Barbers.astro';
import GalleryPreview from '../components/GalleryPreview.astro';
import Story from '../components/Story.astro';
import ShopEssentials from '../components/ShopEssentials.astro';
import Reviews from '../components/Reviews.astro';
import Location from '../components/Location.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import MobileBookCTA from '../components/MobileBookCTA.astro';
import {
  getNextAvailability,
  getSoonestAcrossBarbers,
} from '../lib/availability/nextAvailable';
import { getSession } from '../lib/auth/middleware';
import { getCustomerBookings } from '../lib/square/customerBookings';
import { getCustomerById } from '../lib/square/customers';
import { getBarbers } from '../lib/square/team';
import { getServicesCached } from '../lib/catalog/liveServices';
import { findUsualCombo } from '../lib/booking/usual';
import type { AvailabilitySlot } from '../lib/square/types';

interface AvailabilityProps {
  mode: 'personalized' | 'soonest' | 'fallback';
  slot?: AvailabilitySlot | null;
  barberName?: string;
  teamMemberId?: string;
}

let availability: AvailabilityProps = { mode: 'fallback' };
// Active barber roster — passed through to the hero waitlist trigger so
// the WaitlistSheet can render a dropdown defaulting to "Any barber".
// Best-effort: a Square hiccup here just hides the dropdown; the rest
// of the homepage still renders.
let waitlistBarberOptions: Array<{ id: string; displayName: string }> = [];
try {
  const allBarbers = await getBarbers();
  waitlistBarberOptions = allBarbers.map((b) => ({
    id: b.id,
    displayName: b.displayName,
  }));
} catch {
  waitlistBarberOptions = [];
}

// Live service catalog — passed through to the hero waitlist trigger so
// the WaitlistSheet renders a required service <select>. Without a
// concrete serviceVariationId on the entry, the hourly waitlist-notify
// cron has nothing to query Square against and skips the customer as
// `noVariation` — silently breaking the auto-notify promise. Mirrors
// Step1ServicePicker: hides the legacy VIC item id, picks the first
// bookable variation per service. `id` is the bookable
// serviceVariationId (matches the shape /api/waitlist + cron expect).
const HIDDEN_WAITLIST_ITEM_IDS = new Set<string>(['REEU27HVQBIP27KEI47RI73V']);
let waitlistServiceOptions: Array<{ id: string; name: string }> = [];

// Signed-in customers see the hero waitlist sheet pre-filled with the
// name / email / phone we already have on their Square record. Defaults
// to empty strings for guests (the sheet collects them in the form).
let waitlistPrefillName = '';
let waitlistPrefillEmail = '';
let waitlistPrefillPhone = '';
try {
  const services = await getServicesCached();
  for (const s of services) {
    if (HIDDEN_WAITLIST_ITEM_IDS.has(s.id)) continue;
    const v =
      s.variations.find((vv) => vv.availableForBooking) ?? s.variations[0];
    if (v) waitlistServiceOptions.push({ id: v.id, name: s.name });
  }
} catch {
  waitlistServiceOptions = [];
}

try {
  const session = getSession(Astro.request);
  if (session) {
    // Signed-in path: try to find their usual barber and that barber's
    // next slot. If we can't, fall through to the warm CTA — guests are
    // the only audience for the "earliest across barbers" line. Also
    // resolve the customer's contact info so the hero waitlist sheet
    // can pre-fill name / email / phone (parallel with the other
    // lookups — no added round-trip).
    try {
      const [bookings, barbers, customer] = await Promise.all([
        getCustomerBookings(session.customerId),
        getBarbers(),
        getCustomerById(session.customerId).catch(() => null),
      ]);
      if (customer) {
        const givenName = customer.given_name?.trim() ?? '';
        const familyName = customer.family_name?.trim() ?? '';
        waitlistPrefillName = [givenName, familyName].filter(Boolean).join(' ').trim();
        waitlistPrefillEmail = session.email;
        waitlistPrefillPhone = customer.phone_number?.trim() ?? '';
      }
      const activeBarberIds = new Set(barbers.map((b) => b.id));
      const usual = findUsualCombo(
        [...bookings.upcoming, ...bookings.past],
        activeBarberIds,
      );
      if (usual) {
        const next = await getNextAvailability(usual.teamMemberId, { kind: 'haircut' });
        if (next.slot) {
          availability = {
            mode: 'personalized',
            slot: next.slot,
            barberName: usual.barberName,
            teamMemberId: usual.teamMemberId,
          };
        }
      }
    } catch {
      // Stay on fallback for signed-in customers we can't personalize.
    }
  } else {
    // Guest path: earliest opening across all barbers.
    const soonest = await getSoonestAcrossBarbers({ kind: 'haircut' });
    if (soonest && soonest.slot) {
      availability = {
        mode: 'soonest',
        slot: soonest.slot,
        barberName: soonest.barber.displayName,
        teamMemberId: soonest.barber.id,
      };
    }
  }
} catch {
  // If anything goes sideways, fall back to the warm CTA.
  availability = { mode: 'fallback' };
}
---
<BaseLayout includeBusinessSchema={true}>
  <Header />
  <TrustStrip />
  <main id="main">
    <Hero
      availability={availability}
      waitlistBarberOptions={waitlistBarberOptions}
      waitlistServiceOptions={waitlistServiceOptions}
      waitlistPrefillName={waitlistPrefillName}
      waitlistPrefillEmail={waitlistPrefillEmail}
      waitlistPrefillPhone={waitlistPrefillPhone}
    />
    <QuickActions />
    <Barbers />
    <GalleryPreview />
    <Story />
    <ShopEssentials />
    <Reviews />
    <Location />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <MobileBookCTA />
</BaseLayout>
