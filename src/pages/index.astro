---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Hero from '../components/Hero.astro';
import QuickActions from '../components/QuickActions.astro';
import Services from '../components/Services.astro';
import Barbers from '../components/Barbers.astro';
import GalleryPreview from '../components/GalleryPreview.astro';
import Story from '../components/Story.astro';
import ShopEssentials from '../components/ShopEssentials.astro';
import Reviews from '../components/Reviews.astro';
import Location from '../components/Location.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import MobileBookCTA from '../components/MobileBookCTA.astro';
---
<BaseLayout includeBusinessSchema={true}>
  <Header />
  <TrustStrip />
  <main id="main">
    <Hero />
    <QuickActions />
    <Services />
    <Barbers />
    <GalleryPreview />
    <Story />
    <ShopEssentials />
    <Reviews />
    <Location />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <MobileBookCTA />
</BaseLayout>
