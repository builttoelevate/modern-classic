---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MyBookingsList from '../components/bookings/MyBookingsList.tsx';
import RebookUsualCard from '../components/bookings/RebookUsualCard.tsx';
import NewCustomerCard from '../components/bookings/NewCustomerCard.tsx';
import { ProductRecommendations } from '../components/bookings/ProductRecommendations.tsx';
import { getSession, refreshSessionCookie } from '../lib/auth/middleware';
import { isAuthConfigured } from '../lib/auth/session';
import { getCustomerBookings } from '../lib/square/customerBookings';
import { adoptMissingGroupSiblings } from '../lib/customer/groupSelfHeal';
import { getRetailProducts } from '../lib/square/products';
import { getBarbers } from '../lib/square/team';
import { listLinkedPeople } from '../lib/customer/profileLinks';
import { recommendForBooking, generalRecommendations } from '../lib/recommendations/forBooking';
import { findUsualCombo, type UsualCombo } from '../lib/booking/usual';
import { shouldShowRebookCard } from '../lib/booking/rebookEligibility';
import { getNextSlotsForCombo } from '../lib/availability/nextAvailable';
import { isWithinDays } from '../lib/availability/timing';
import type { CustomerBookings } from '../lib/square/customerBookings';
import type { Product } from '../lib/square/products';
import type { AvailabilitySlot } from '../lib/square/types';

import '../styles/booking.css';
import '../styles/portal.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

if (!isAuthConfigured()) {
  return new Response(
    'Customer portal is temporarily unavailable. Please try again shortly.',
    { status: 503, headers: { 'Content-Type': 'text/plain' } },
  );
}

const session = getSession(Astro.request);
if (!session) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: `${base}/sign-in?redirect=${encodeURIComponent(`${base}/my-bookings`)}`,
    },
  });
}

let bookings: CustomerBookings = { upcoming: [], past: [] };
let products: Product[] = [];
let activeBarberIds = new Set<string>();
let loadError: string | null = null;

// One-shot debug overlay. Triggered with ?debug=1 in the URL.
// Surfaces the exact intermediate state of the linked-people fetch
// so we can diagnose "I linked a kid but their booking doesn't
// show" cases without screenshot ping-pong. Includes raw session
// customer id, linked-people list with each kid's customer id and
// booking count, and any errors hit during fetch. Disabled in
// production unless explicitly requested via query param.
const debugMode = new URL(Astro.request.url).searchParams.get('debug') === '1';
interface DebugInfo {
  sessionCustomerId: string;
  linkedPeople: Array<{ customerId: string; displayName: string }>;
  parentBookingsCount: { upcoming: number; past: number };
  kidFetchResults: Array<{
    displayName: string;
    customerId: string;
    upcomingCount: number;
    pastCount: number;
    upcomingSummary: string[];
  }>;
  groupGapsBefore: Array<{ groupId: string; total: number; visible: number }>;
  adoptedFromSelfHeal: number;
}
const debugInfo: DebugInfo | null = debugMode
  ? {
      sessionCustomerId: session.customerId,
      linkedPeople: [],
      parentBookingsCount: { upcoming: 0, past: 0 },
      kidFetchResults: [],
      groupGapsBefore: [],
      adoptedFromSelfHeal: 0,
    }
  : null;

try {
  const linkedPeople = await listLinkedPeople(session.customerId).catch(() => []);
  const [b, p, bs, ...kidBookingResults] = await Promise.all([
    getCustomerBookings(session.customerId),
    getRetailProducts(),
    getBarbers(),
    // Each linked person's bookings, parallel. Failures fall through to
    // empty so one bad lookup doesn't blank the whole page.
    ...linkedPeople.map((lp) =>
      getCustomerBookings(lp.customerId)
        .then((kb) => ({ person: lp, bookings: kb }))
        .catch(() => ({ person: lp, bookings: { upcoming: [], past: [] } })),
    ),
  ]);
  bookings = b;
  products = p;
  activeBarberIds = new Set(bs.map((m) => m.id));

  if (debugInfo) {
    debugInfo.linkedPeople = linkedPeople.map((lp) => ({
      customerId: lp.customerId,
      displayName: lp.displayName,
    }));
    debugInfo.parentBookingsCount = {
      upcoming: b.upcoming.length,
      past: b.past.length,
    };
    for (const r of kidBookingResults as Array<{ person: { displayName: string; customerId: string }; bookings: typeof bookings }>) {
      debugInfo.kidFetchResults.push({
        displayName: r.person.displayName,
        customerId: r.person.customerId,
        upcomingCount: r.bookings.upcoming.length,
        pastCount: r.bookings.past.length,
        upcomingSummary: r.bookings.upcoming.map(
          (bk) => `${bk.startAtLocal} · ${bk.serviceName}${bk.groupId ? ` · group ${bk.groupPosition}/${bk.groupTotal}` : ''}`,
        ),
      });
    }
  }

  // Merge linked-person bookings into the parent's lists, decorating each
  // with the person's name so the BookingCard can show "for Briar".
  for (const result of kidBookingResults as Array<{ person: { displayName: string }; bookings: typeof bookings }>) {
    for (const ub of result.bookings.upcoming) {
      bookings.upcoming.push({ ...ub, bookingFor: result.person.displayName });
    }
    for (const pb of result.bookings.past) {
      bookings.past.push({ ...pb, bookingFor: result.person.displayName });
    }
  }
  // Pull in any group-booking siblings we'd otherwise be missing. Safe
  // when there are no incomplete groups — the helper is a no-op then.
  // Errors are swallowed so the page still renders.
  try {
    const knownIds = new Set<string>([
      session.customerId,
      ...linkedPeople.map((lp) => lp.customerId),
    ]);
    if (debugInfo) {
      // Capture pre-self-heal gaps so the overlay can tell whether
      // the self-heal had work to do at all.
      const gaps = new Map<string, { total: number; visible: number }>();
      for (const bk of [...bookings.upcoming, ...bookings.past]) {
        if (!bk.groupId || !bk.groupTotal) continue;
        const g = gaps.get(bk.groupId) ?? { total: bk.groupTotal, visible: 0 };
        g.visible += 1;
        gaps.set(bk.groupId, g);
      }
      debugInfo.groupGapsBefore = [...gaps.entries()].map(([groupId, v]) => ({
        groupId,
        total: v.total,
        visible: v.visible,
      }));
    }
    const adopted = await adoptMissingGroupSiblings(session.customerId, knownIds, bookings);
    if (debugInfo) debugInfo.adoptedFromSelfHeal = adopted;
    if (adopted > 0) {
      // eslint-disable-next-line no-console
      console.log(
        `[BOOK] ${JSON.stringify({
          ts: new Date().toISOString(),
          phase: 'group-siblings-self-healed',
          customerId: session.customerId,
          adopted,
        })}`,
      );
    }
  } catch (err) {
    // eslint-disable-next-line no-console
    console.log(
      `[BOOK] ${JSON.stringify({
        ts: new Date().toISOString(),
        phase: 'group-self-heal-failed',
        detail: err instanceof Error ? err.message : String(err),
      })}`,
    );
  }

  bookings.upcoming.sort(
    (a, b) => new Date(a.startAtUtc).getTime() - new Date(b.startAtUtc).getTime(),
  );
  bookings.past.sort(
    (a, b) => new Date(b.startAtUtc).getTime() - new Date(a.startAtUtc).getTime(),
  );
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Failed to load.';
  // eslint-disable-next-line no-console
  console.log(
    `[BOOK] ${JSON.stringify({ ts: new Date().toISOString(), phase: 'my-bookings-load-failed', detail: loadError })}`,
  );
}

const allBookings = [...bookings.upcoming, ...bookings.past];
const usualCombo: UsualCombo | null = activeBarberIds.size > 0
  ? findUsualCombo(allBookings, activeBarberIds)
  : null;
const showRebook = shouldShowRebookCard({
  usualCombo,
  upcomingBookings: bookings.upcoming,
});

let quickSlots: AvailabilitySlot[] = [];
let withinSevenDays = false;
if (showRebook && usualCombo) {
  try {
    quickSlots = await getNextSlotsForCombo({
      serviceVariationId: usualCombo.serviceVariationId,
      teamMemberId: usualCombo.teamMemberId,
      count: 3,
    });
    if (quickSlots.length > 0) {
      withinSevenDays = isWithinDays(quickSlots[0].startAtUtc, 7);
    }
  } catch (err) {
    // Best-effort — if availability fails the card just won't render.
    quickSlots = [];
    // eslint-disable-next-line no-console
    console.log(
      `[BOOK] ${JSON.stringify({ ts: new Date().toISOString(), phase: 'rebook-availability-failed', detail: err instanceof Error ? err.message : String(err) })}`,
    );
  }
}

// True new customer = no upcoming AND no past bookings (any status).
const isTrueNewCustomer =
  !showRebook && bookings.upcoming.length === 0 && bookings.past.length === 0;

const seedBooking = bookings.upcoming[0] ?? bookings.past[0];
const recs = seedBooking
  ? recommendForBooking({
      barberId: seedBooking.barberId,
      serviceVariationId: seedBooking.serviceVariationId,
      allProducts: products,
    })
  : generalRecommendations(products);

const customerLabel = session.email;

// Sliding cookie refresh — every authenticated page render extends the
// 90-day window.
Astro.response.headers.append('Set-Cookie', refreshSessionCookie(session));
---
<BaseLayout
  title="My Bookings — Modern Classic Barbershop"
  description="View, reschedule, or cancel your Modern Classic appointments."
>
  <Header />
  <main id="main" class="mb-page">
    <div class="mb-head">
      <div class="mb-head__id">
        <span class="mb-head__eyebrow">Welcome back</span>
        <h1>Your bookings</h1>
        <p class="mb-head__email">{customerLabel}</p>
      </div>
      <div class="mb-head__actions">
        <a class="mb-head__signout" href={`${base}/profile`}>Profile</a>
        <button type="button" class="mb-head__signout" id="signout-btn">Sign out</button>
      </div>
    </div>

    <p class="mb-head__policy">
      Need to cancel or reschedule? See our
      <a class="link-gold" href={`${base}/cancellation-policy`}>
        cancellation &amp; no-show policy
      </a> &mdash; in short, 24-hour notice avoids any charge.
    </p>

    {debugInfo && (
      <pre style="background:#1a1814; border:1px solid #c9a35c; color:#f3ece0; padding:12px; border-radius:6px; font-size:11px; line-height:1.45; overflow:auto; margin:0 0 16px; white-space:pre-wrap; word-break:break-all;">
{JSON.stringify(debugInfo, null, 2)}
      </pre>
    )}

    {loadError ? (
      <div class="mb-empty">
        <p>We couldn't load your bookings right now. Please try again in a moment, or call us at <a class="link-gold" href="tel:+17402974462">740-297-4462</a>.</p>
      </div>
    ) : (
      <>
        {showRebook && usualCombo && quickSlots.length > 0 && (
          <RebookUsualCard
            client:load
            usual={usualCombo}
            quickSlots={quickSlots}
            withinSevenDays={withinSevenDays}
            basePath={base}
          />
        )}
        {isTrueNewCustomer && <NewCustomerCard client:load basePath={base} />}
        <MyBookingsList client:load initial={bookings} basePath={base} />
      </>
    )}

    {recs.length > 0 && <ProductRecommendations products={recs} />}
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('signout-btn');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      btn.disabled = true;
      try {
        await fetch('/api/auth/logout', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
        });
      } catch {
        // best-effort — fall through to redirect
      }
      window.location.href = '/';
    });
  })();
</script>
