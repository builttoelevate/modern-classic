---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileBookCTA from '../components/MobileBookCTA.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Barber roster — pulled from the Square booking flow plus shop reviews.
// TODO: Replace `photo: null` with real headshot paths and `bookingUrl` with
// per-barber Square deep links once the owner provides them. Until then, the
// shared shop URL covers booking and the gold initial monogram covers the
// missing photo gracefully.
// TODO: Replace placeholder Instagram handles below with the real per-barber
// handles once confirmed. The shop's IG (@modernclassicbarbershop) is the
// safe fallback used here.
const SHOP_IG = 'https://www.instagram.com/modernclassicbarbershop/';
const BOOK_URL = 'https://modern-classic.square.site';

const barbers = [
  {
    name: 'Michael',
    initial: 'M',
    role: 'Owner & Master Barber',
    yearsLine: '10+ years in the chair',
    bio:
      "Michael is the founder of Modern Classic and the barber clients drive across state lines for. He specializes in skin fades, sharp line-ups, and the kind of detailed, no-shortcut haircut that still looks right two weeks later.",
    specialties: ['Skin Fades', 'Line-Ups', 'Beard Sculpts', 'Hair Design'],
    bookingUrl: BOOK_URL,
    instagram: SHOP_IG,
  },
  {
    name: 'Rick',
    initial: 'R',
    role: 'Senior Barber',
    yearsLine: 'Cuts, beards & product styling',
    bio:
      "Rick is the barber clients book when they want a clean cut and a styled finish — no guesswork at home afterwards. He'll cut, style with the in-house product line, and send you out knowing exactly how to recreate it.",
    specialties: ['Modern Cuts', 'Texture Styling', 'Beard Trims', 'Product Consults'],
    bookingUrl: BOOK_URL,
    instagram: SHOP_IG,
  },
  {
    name: 'Clayton',
    initial: 'C',
    role: 'Barber',
    yearsLine: 'Classic technique, modern detail',
    bio:
      "Clayton brings traditional barbering technique to every chair — clean clipper work, sharp scissor finishes, and a calm, family-friendly atmosphere whether you're 8 or 80. A favorite for kids' cuts and classic gentlemen's styles.",
    specialties: ['Classic Cuts', "Kids' Cuts", 'Scissor Work', 'Hot Towel Shaves'],
    bookingUrl: BOOK_URL,
    instagram: SHOP_IG,
  },
];
---
<BaseLayout
  title="Our Barbers — Modern Classic Barbershop, Zanesville OH"
  description="Meet the barbers at Modern Classic in Zanesville: Michael, Rick, and Clayton. Skin fades, beard sculpts, classic cuts, and kids' haircuts — book the chair that fits your style."
>
  <Header />
  <main id="main">
    <section class="brbr-hero" aria-labelledby="brbr-hero-heading">
      <div class="brbr-hero__ornaments" aria-hidden="true">
        <div class="brbr-hero__glow"></div>
      </div>
      <div class="container brbr-hero__inner">
        <p class="eyebrow">The Chairs</p>
        <h1 id="brbr-hero-heading" class="brbr-hero__h1">
          <span class="brbr-hero__line">Three chairs.</span>
          <span class="brbr-hero__line italic-accent">One standard.</span>
        </h1>
        <p class="lede">
          Pick your barber when you book. Each of us cuts a little differently,
          but you'll walk out of any chair at Modern Classic with the same
          attention to detail and the same finished feel.
        </p>
      </div>
    </section>

    <section class={`brbr-grid-wrap brbr-grid-wrap--n${barbers.length}`}>
      <div class="container">
        <div class={`brbr-grid brbr-grid--n${barbers.length}`}>
          {barbers.map((b, i) => (
            <article class="brbr" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
              <div class="brbr__photo" aria-hidden="true">
                {/* TODO: Replace this monogram crest with a real headshot for {b.name}. */}
                <svg viewBox="0 0 240 280" class="brbr__svg">
                  <defs>
                    <linearGradient id={`brbr-grad-${b.initial}`} x1="0" y1="0" x2="1" y2="1">
                      <stop offset="0%"  stop-color="#e6c785"/>
                      <stop offset="55%" stop-color="#c9a35c"/>
                      <stop offset="100%" stop-color="#8a6e35"/>
                    </linearGradient>
                  </defs>
                  <rect x="0.5" y="0.5" width="239" height="279" fill="none" stroke={`url(#brbr-grad-${b.initial})`} stroke-width="0.6" opacity="0.4"/>
                  <circle cx="120" cy="138" r="78" stroke={`url(#brbr-grad-${b.initial})`} stroke-width="0.9" fill="none"/>
                  <circle cx="120" cy="138" r="72" stroke={`url(#brbr-grad-${b.initial})`} stroke-width="0.4" opacity="0.5" fill="none"/>
                  <text x="120" y="167" text-anchor="middle"
                        font-family="Fraunces, Georgia, serif"
                        font-size="106" font-weight="500"
                        fill={`url(#brbr-grad-${b.initial})`}>{b.initial}</text>
                  <line x1="120" y1="42" x2="120" y2="56" stroke={`url(#brbr-grad-${b.initial})`} stroke-width="0.6"/>
                  <line x1="120" y1="220" x2="120" y2="234" stroke={`url(#brbr-grad-${b.initial})`} stroke-width="0.6"/>
                  <text x="120" y="252" text-anchor="middle"
                        font-family="Manrope, sans-serif"
                        font-size="9" font-weight="600"
                        letter-spacing="6"
                        fill="#c9a35c" opacity="0.75">MODERN · CLASSIC</text>
                </svg>
              </div>

              <div class="brbr__body">
                <p class="brbr__role">{b.role}</p>
                <h2 class="brbr__name">{b.name}</h2>
                <p class="brbr__years">{b.yearsLine}</p>
                <p class="brbr__bio">{b.bio}</p>

                <ul class="brbr__specs" aria-label={`${b.name}'s specialties`}>
                  {b.specialties.map((s) => <li>{s}</li>)}
                </ul>

                <div class="brbr__ctas">
                  <a class="btn btn--small" href={b.bookingUrl} target="_blank" rel="noopener">
                    Book with {b.name} <span class="arrow" aria-hidden="true">→</span>
                  </a>
                  {b.instagram && (
                    <a class="brbr__ig" href={b.instagram} target="_blank" rel="noopener" aria-label={`${b.name} on Instagram`}>
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="4"/>
                        <circle cx="12" cy="12" r="4"/>
                        <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor"/>
                      </svg>
                      <span>Instagram</span>
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="brbr-foot" aria-labelledby="brbr-foot-heading">
      <div class="container brbr-foot__inner" data-reveal>
        <h2 id="brbr-foot-heading" class="brbr-foot__h">
          Not sure who to <span class="italic-accent">book with?</span>
        </h2>
        <p class="lede" style="text-align:center; margin-inline:auto;">
          Book the <strong>New Customer</strong> service and we'll match you with the
          chair that fits your style — extra consult time is built in.
        </p>
        <div class="brbr-foot__ctas">
          <a class="btn" href={BOOK_URL} target="_blank" rel="noopener">
            Book a Visit <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a class="btn btn--ghost" href={`${base}/services`}>
            See Full Service Menu
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <MobileBookCTA />
</BaseLayout>

<style>
  /* ---------- Hero ---------- */
  .brbr-hero {
    position: relative;
    padding-block: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3rem);
    isolation: isolate;
    overflow: hidden;
  }
  .brbr-hero__ornaments { position: absolute; inset: 0; pointer-events: none; z-index: -1; }
  .brbr-hero__glow {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: min(880px, 90%);
    height: 320px;
    background: radial-gradient(ellipse at center, rgba(201, 163, 92, 0.14), transparent 65%);
    filter: blur(28px);
  }
  .brbr-hero__inner {
    display: grid;
    gap: 1rem;
    text-align: center;
    justify-items: center;
    max-width: 56rem;
    margin-inline: auto;
  }
  .brbr-hero__h1 { display: grid; gap: 0.05em; }
  .brbr-hero__line {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
  }
  .brbr-hero__h1 .italic-accent { font-style: italic; font-weight: 300; }

  /* ---------- Grid ---------- */
  .brbr-grid-wrap { padding-block: clamp(2rem, 4vw, 4rem) clamp(3rem, 6vw, 5rem); }
  .brbr-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, 1fr);
  }
  /* Single barber: center the lone card. */
  .brbr-grid--n1 { grid-template-columns: minmax(0, 32rem); justify-content: center; }
  /* Two barbers: even split. */
  .brbr-grid--n2 { grid-template-columns: repeat(2, 1fr); max-width: 52rem; margin-inline: auto; }
  @media (max-width: 880px) {
    .brbr-grid { grid-template-columns: 1fr; max-width: 32rem; margin-inline: auto; }
  }

  /* ---------- Card ---------- */
  .brbr {
    display: grid;
    gap: 1.25rem;
    padding: clamp(1.5rem, 2.4vw, 2rem);
    background: linear-gradient(180deg, var(--color-surface), var(--color-bg-soft));
    border: 1px solid var(--color-border);
    border-radius: 2px;
    transition: border-color var(--dur) var(--ease),
                transform var(--dur) var(--ease),
                box-shadow var(--dur) var(--ease);
    position: relative;
  }
  .brbr::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px; right: -1px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-gold), var(--color-gold-dark), transparent);
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .brbr:hover {
    border-color: rgba(201, 163, 92, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 14px 40px -20px rgba(0, 0, 0, 0.7);
  }
  .brbr:hover::before { opacity: 1; }

  .brbr__photo {
    position: relative;
    aspect-ratio: 4 / 5;
    background:
      radial-gradient(circle at 50% 35%, rgba(201, 163, 92, 0.10), transparent 65%),
      linear-gradient(180deg, var(--color-surface-2), var(--color-bg));
    border: 1px solid var(--color-rule-soft);
    border-radius: 2px;
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .brbr__svg { width: 80%; height: 80%; }

  .brbr__body { display: grid; gap: 0.55rem; }
  .brbr__role {
    color: var(--color-gold);
    font-size: 0.74rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin: 0;
  }
  .brbr__name {
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 1.4rem + 1.2vw, 2.4rem);
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1;
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
  }
  .brbr__years {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .brbr__bio {
    color: var(--color-text-muted);
    font-size: 0.96rem;
    line-height: 1.6;
    margin: 0.4rem 0 0;
  }
  .brbr__specs {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .brbr__specs li {
    padding: 0.32em 0.7em;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    color: var(--color-gold);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }
  .brbr__ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
    margin-top: 0.6rem;
  }
  .brbr__ig {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-gold);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 2px;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .brbr__ig:hover {
    color: var(--color-gold-light);
    border-bottom-color: var(--color-gold-light);
  }

  /* ---------- Foot ---------- */
  .brbr-foot {
    background:
      radial-gradient(900px 360px at 50% 0%, rgba(201, 163, 92, 0.10), transparent 70%),
      linear-gradient(180deg, var(--color-bg-soft), var(--color-bg));
    border-top: 1px solid var(--color-border-soft);
  }
  .brbr-foot__inner {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1rem;
  }
  .brbr-foot__h { font-size: clamp(2rem, 1.5rem + 3vw, 3.25rem); }
  .brbr-foot__inner strong { color: var(--color-gold-light); font-weight: 600; }
  .brbr-foot__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.75rem;
  }
</style>
