---
export const prerender = false;

import { getBarberSession } from '../../lib/auth/barberMiddleware';
import { getAccount } from '../../lib/barber/accountStore';
import '../../styles/barber.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const session = getBarberSession(Astro.request);
if (!session) {
  return new Response(null, {
    status: 302,
    headers: { Location: `${base}/barber/sign-in` },
  });
}
const account = await getAccount(session.barberId);
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Account — Modern Classic</title>
  </head>
  <body class="bb-page">
    <div class="bb-wrap">
      <header class="bb-head">
        <div>
          <p class="bb-eyebrow">Account</p>
          <h1>{session.username}</h1>
          {account?.mustChangePassword && (
            <p class="bb-auth__lede">
              You're still on a temporary password — set your own below.
            </p>
          )}
        </div>
        <nav class="bb-head__nav">
          <a href={`${base}/barber/dashboard`}>← Dashboard</a>
          <button type="button" class="bb-link" id="signout-btn">Sign out</button>
        </nav>
      </header>

      <section>
        <h2>Change password</h2>
        <form class="bb-form" id="cp-form" novalidate>
          <label class="bb-field">
            <span class="bb-field__label">Current password</span>
            <input type="password" name="currentPassword" autocomplete="current-password" required />
          </label>
          <label class="bb-field">
            <span class="bb-field__label">New password</span>
            <input type="password" name="newPassword" autocomplete="new-password" minlength="8" required />
          </label>
          <label class="bb-field">
            <span class="bb-field__label">Confirm new password</span>
            <input type="password" name="confirmPassword" autocomplete="new-password" minlength="8" required />
          </label>
          <p class="bb-form__error" id="cp-error" hidden></p>
          <p class="bb-form__ok" id="cp-ok" hidden>Password updated.</p>
          <button type="submit" class="bb-btn" id="cp-submit">Save</button>
        </form>
      </section>
    </div>

    <script is:inline>
      (function () {
        const form = document.getElementById('cp-form');
        const errorEl = document.getElementById('cp-error');
        const okEl = document.getElementById('cp-ok');
        const submit = document.getElementById('cp-submit');
        const signout = document.getElementById('signout-btn');
        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorEl.hidden = true;
            okEl.hidden = true;
            const data = new FormData(form);
            const newP = String(data.get('newPassword') ?? '');
            const conf = String(data.get('confirmPassword') ?? '');
            if (newP !== conf) {
              errorEl.textContent = 'Confirmation does not match.';
              errorEl.hidden = false;
              return;
            }
            submit.disabled = true;
            const original = submit.textContent;
            submit.textContent = 'Saving…';
            try {
              const res = await fetch('/api/barber/auth/change-password', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  currentPassword: data.get('currentPassword'),
                  newPassword: newP,
                }),
              });
              const body = await res.json();
              if (!body.ok) {
                errorEl.textContent =
                  body?.error?.detail || 'Could not change password.';
                errorEl.hidden = false;
                submit.disabled = false;
                submit.textContent = original;
                return;
              }
              okEl.hidden = false;
              form.reset();
              submit.disabled = false;
              submit.textContent = original;
            } catch (_err) {
              errorEl.textContent = 'Network error. Try again.';
              errorEl.hidden = false;
              submit.disabled = false;
              submit.textContent = original;
            }
          });
        }
        if (signout) {
          signout.addEventListener('click', async () => {
            signout.disabled = true;
            try {
              await fetch('/api/barber/auth/logout', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
              });
            } catch {}
            window.location.href = '/barber/sign-in';
          });
        }
      })();
    </script>
  </body>
</html>
