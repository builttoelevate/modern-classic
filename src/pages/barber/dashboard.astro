---
export const prerender = false;

import { getBarberSession, refreshBarberSessionCookie } from '../../lib/auth/barberMiddleware';
import { getAccount } from '../../lib/barber/accountStore';
import {
  listBlocks as listBarberBlocks,
  type OneOffBlock,
  type RecurringBlock,
} from '../../lib/barber/timeBlocks';
import { listBookings } from '../../lib/square/bookings';
import { getBarbers } from '../../lib/square/team';
import { getServices } from '../../lib/square/catalog';
import { getCustomerById } from '../../lib/square/customers';
import {
  listWaitlistEntries,
  getEntryBarberPicks,
  type WaitlistEntry,
} from '../../lib/marketing/waitlistLog';
import {
  formatWaitlistDays,
  formatWaitlistTimes,
  formatWaitlistWindow,
} from '../../lib/marketing/waitlistFormat';
import { SquareApiError } from '../../lib/square/client';
import type { Booking, Customer } from '../../lib/square/types';
import '../../styles/barber.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const session = getBarberSession(Astro.request);
if (!session) {
  return new Response(null, {
    status: 302,
    headers: { Location: `${base}/barber/sign-in` },
  });
}

// If the account is flagged must-change-password, route through the
// change-password page before showing the dashboard. Anyone with a
// fresh password lands here directly.
const account = await getAccount(session.barberId);
if (!account) {
  // Account was removed by admin while session was live — clear & bounce.
  return new Response(null, {
    status: 302,
    headers: { Location: `${base}/barber/sign-in` },
  });
}
if (account.mustChangePassword) {
  return new Response(null, {
    status: 302,
    headers: { Location: `${base}/barber/change-password` },
  });
}

const SHOP_TZ = 'America/New_York';
const TERMINAL = new Set<Booking['status']>([
  'CANCELLED_BY_CUSTOMER',
  'CANCELLED_BY_SELLER',
  'NO_SHOW',
  'DECLINED',
]);

// Which tab is active. Defaults to appointments — the day view is the
// daily-driver use case; waitlist is the secondary "who's waiting"
// tab. URL param so back/forward navigation works and so a barber can
// bookmark the waitlist tab directly if they want.
type Tab = 'appointments' | 'waitlist' | 'time-off';
const tabParam = Astro.url.searchParams.get('tab');
const activeTab: Tab =
  tabParam === 'waitlist'
    ? 'waitlist'
    : tabParam === 'time-off'
      ? 'time-off'
      : 'appointments';

function shopDateKey(date: Date = new Date()): string {
  return new Intl.DateTimeFormat('en-CA', {
    timeZone: SHOP_TZ,
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(date);
}

function shopMidnightUtcFor(y: number, m: number, d: number): Date {
  let utc = new Date(Date.UTC(y, m - 1, d, 0, 0, 0));
  for (let i = 0; i < 2; i++) {
    const ps = new Intl.DateTimeFormat('en-US', {
      timeZone: SHOP_TZ,
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    }).formatToParts(utc);
    const g = (t: string) => ps.find((p) => p.type === t)?.value ?? '0';
    const localAsUtc = Date.UTC(
      Number(g('year')),
      Number(g('month')) - 1,
      Number(g('day')),
      Number(g('hour') === '24' ? '00' : g('hour')),
      Number(g('minute')),
      0,
    );
    const target = Date.UTC(y, m - 1, d, 0, 0, 0);
    const diff = target - localAsUtc;
    if (diff === 0) break;
    utc = new Date(utc.getTime() + diff);
  }
  return utc;
}

const ISO_DATE = /^\d{4}-\d{2}-\d{2}$/;
const todayKey = shopDateKey();
const tomorrowKey = shopDateKey(new Date(Date.now() + 86_400_000));
const requestedDate = Astro.url.searchParams.get('date');
const filterDateKey = requestedDate && ISO_DATE.test(requestedDate) ? requestedDate : todayKey;
const [dy, dm, dd] = filterDateKey.split('-').map(Number);
const startUtc = shopMidnightUtcFor(dy, dm, dd);
const endUtc = shopMidnightUtcFor(dy, dm, dd + 1);

let bookings: Booking[] = [];
let customers = new Map<string, Customer>();
let loadError: string | null = null;
const barberNames = new Map<string, string>();
const serviceNames = new Map<string, string>();
let waitlist: WaitlistEntry[] = [];
let isOwner = false;

let timeBlocks: { oneOff: OneOffBlock[]; recurring: RecurringBlock[] } = {
  oneOff: [],
  recurring: [],
};
try {
  const [list, barbers, services, allWaitlist, blocks] = await Promise.all([
    listBookings({ startAtMin: startUtc.toISOString(), startAtMax: endUtc.toISOString(), limit: 200 }),
    getBarbers(),
    getServices(),
    listWaitlistEntries({ limit: 200 }).catch(() => [] as WaitlistEntry[]),
    listBarberBlocks(session.barberId).catch(() => ({ oneOff: [], recurring: [] })),
  ]);
  timeBlocks = blocks;
  bookings = list.bookings
    .filter((b) => !TERMINAL.has(b.status))
    .filter((b) => b.appointment_segments?.[0]?.team_member_id === session.barberId);
  for (const b of barbers) barberNames.set(b.id, b.displayName);
  for (const s of services) {
    for (const v of s.variations) serviceNames.set(v.id, s.name);
  }

  // Owner (Michael) sees the shop-wide waitlist; every other barber
  // sees only entries where they were specifically requested. Role
  // is sourced from src/lib/square/team.ts → ROLE_BY_ID, so adding a
  // new owner there automatically propagates here.
  const self = barbers.find((b) => b.id === session.barberId);
  isOwner = self?.role === 'Owner';

  // Active statuses only — booked + archived shouldn't clutter the
  // dashboard.
  const activeWaitlist = allWaitlist.filter(
    (e) => e.status === 'new' || e.status === 'contacted',
  );
  waitlist = isOwner
    ? activeWaitlist
    : activeWaitlist.filter((e) => {
        const picks = getEntryBarberPicks(e);
        return picks.some((p) => p.id === session.barberId);
      });

  const customerIds = Array.from(
    new Set(bookings.map((b) => b.customer_id).filter(Boolean) as string[]),
  );
  const customerEntries = await Promise.all(
    customerIds.map(async (id) => {
      try {
        const c = await getCustomerById(id);
        return c ? ([id, c] as const) : null;
      } catch {
        return null;
      }
    }),
  );
  customers = new Map(customerEntries.filter((e): e is readonly [string, Customer] => e !== null));
} catch (err) {
  if (err instanceof SquareApiError) {
    loadError = `${err.code}: ${err.detail}`;
  } else {
    loadError = err instanceof Error ? err.message : 'Unknown error';
  }
}

interface Row {
  bookingId: string;
  bookingVersion: number;
  startUtc: Date;
  startLocal: string;
  startInputValue: string;
  service: string;
  customerName: string;
  customerPhone: string;
  customerPhoneE164: string;
  customerEmail: string;
  note: string;
  status: Booking['status'];
}

const inputFmt = new Intl.DateTimeFormat('en-CA', {
  timeZone: SHOP_TZ,
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
});

function toInputValue(utc: Date): string {
  // datetime-local needs "YYYY-MM-DDTHH:mm" in the user's local clock,
  // which here means the shop's local clock — that's the picker barbers
  // will reason about. The reschedule API converts back to UTC using
  // the same SHOP_TZ.
  const parts = inputFmt.formatToParts(utc);
  const g = (t: string) => parts.find((p) => p.type === t)?.value ?? '';
  const hour = g('hour') === '24' ? '00' : g('hour');
  return `${g('year')}-${g('month')}-${g('day')}T${hour}:${g('minute')}`;
}

const rows: Row[] = bookings
  .map((b) => {
    const seg = b.appointment_segments?.[0];
    const c = b.customer_id ? customers.get(b.customer_id) : undefined;
    const startUtc = new Date(b.start_at);
    const phoneRaw = c?.phone_number?.trim() ?? '';
    return {
      bookingId: b.id,
      bookingVersion: b.version,
      startUtc,
      startLocal: new Intl.DateTimeFormat('en-US', {
        timeZone: SHOP_TZ,
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
      }).format(startUtc),
      startInputValue: toInputValue(startUtc),
      service: seg ? (serviceNames.get(seg.service_variation_id) ?? '—') : '—',
      customerName: c
        ? `${c.given_name ?? ''} ${c.family_name ?? ''}`.trim() || '—'
        : '—',
      customerPhone: phoneRaw,
      customerPhoneE164: phoneRaw.replace(/[^0-9+]/g, ''),
      customerEmail: c?.email_address?.trim() ?? '',
      note: b.customer_note?.trim() ?? '',
      status: b.status,
    };
  })
  .sort((a, b) => a.startUtc.getTime() - b.startUtc.getTime());

const fmtDate = new Intl.DateTimeFormat('en-US', {
  timeZone: SHOP_TZ,
  weekday: 'long',
  month: 'long',
  day: 'numeric',
});

const isToday = filterDateKey === todayKey;
const isTomorrow = filterDateKey === tomorrowKey;
const dateHeading = isToday ? 'Today' : isTomorrow ? 'Tomorrow' : fmtDate.format(startUtc);
const dateSubLabel = fmtDate.format(startUtc);

function formatPhone(raw: string): string {
  const d = raw.replace(/[^0-9]/g, '');
  if (d.length === 11 && d.startsWith('1')) {
    return `(${d.slice(1, 4)}) ${d.slice(4, 7)}-${d.slice(7)}`;
  }
  if (d.length === 10) {
    return `(${d.slice(0, 3)}) ${d.slice(3, 6)}-${d.slice(6)}`;
  }
  return raw;
}

function statusClass(status: string): string {
  if (status === 'ACCEPTED') return 'ok';
  if (status === 'PENDING') return 'pending';
  return 'cancelled';
}

interface WaitlistRow {
  id: string;
  customerName: string;
  customerPhone: string;
  customerPhoneE164: string;
  customerEmail: string;
  serviceName: string;
  /** Square service-variation id resolved at customer submit-time.
   *  Null on legacy entries pre-PR 8 — the Schedule button hides
   *  for those (the barber can text the customer and book the
   *  old way until the entry expires). */
  serviceVariationId: string | null;
  /** Display names of every barber this entry requested. Empty array
   *  means "any barber" — only shown on the owner view since
   *  individual barbers don't see no-preference entries. */
  requestedBarbers: string[];
  /** Square team-member ids parallel to requestedBarbers — used to
   *  gate the Schedule button to the calling barber's own chair. */
  requestedBarberIds: string[];
  preferredDate?: string;
  /** Customer's available-window dates from the join form. Surfaced
   *  on the card as the "When" row so the barber sees the actual
   *  date the customer wants, not just the day-of-week digest. */
  dateFrom?: string;
  dateTo?: string;
  daysOfWeek: string[];
  timesOfDay: string[];
  note: string;
  adminNote: string;
  status: 'new' | 'contacted';
  submittedAt: string;
}

const waitlistRows: WaitlistRow[] = waitlist
  .map((e): WaitlistRow => {
    const picks = getEntryBarberPicks(e);
    return {
      id: e.id,
      customerName: e.customerName,
      customerPhone: e.customerPhone,
      customerPhoneE164: (e.customerPhone || '').replace(/[^0-9+]/g, ''),
      customerEmail: e.customerEmail,
      serviceName: e.serviceName,
      serviceVariationId: e.serviceVariationId,
      requestedBarbers: picks.map((p) => p.displayName),
      requestedBarberIds: picks.map((p) => p.id),
      preferredDate: e.preferredDate,
      dateFrom: e.dateFrom,
      dateTo: e.dateTo,
      daysOfWeek: e.daysOfWeek ?? [],
      timesOfDay: e.timesOfDay ?? [],
      note: e.note ?? '',
      adminNote: e.adminNote ?? '',
      status: e.status === 'contacted' ? 'contacted' : 'new',
      submittedAt: e.submittedAt,
    };
  })
  .sort((a, b) => b.submittedAt.localeCompare(a.submittedAt));

const displayName = barberNames.get(session.barberId) ?? session.username;

// Sliding refresh on each authed render.
Astro.response.headers.append('Set-Cookie', refreshBarberSessionCookie(session));
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Your chair — Modern Classic</title>
  </head>
  <body class="bb-page">
    <div class="bb-wrap">
      <header class="bb-head">
        <div>
          <p class="bb-eyebrow">Welcome back</p>
          <h1>{displayName}'s chair</h1>
        </div>
        <nav class="bb-head__nav">
          <a href={`${base}/barber/account`}>Account</a>
          <button type="button" class="bb-link" id="signout-btn">Sign out</button>
        </nav>
      </header>

      {!account.email && (
        <div class="bb-banner">
          <p>
            <strong>Set your notification email</strong> so waitlist customers who
            ask for you reach you directly.
          </p>
          <a class="bb-btn bb-btn--ghost bb-btn--sm" href={`${base}/barber/account`}>
            Add email →
          </a>
        </div>
      )}

      {/* Self-serve photo upload. Posts JPEG-encoded (client-side
          resized) images to /api/barber/photos/upload, which puts
          them in Vercel Blob under gallery/{barberId}/...  The
          public /gallery page lists them newest-first on the next
          render (no rebuild needed). */}
      <section class="bb-photo-upload" aria-labelledby="bb-photo-upload-heading">
        <header class="bb-photo-upload__head">
          <h2 id="bb-photo-upload-heading">Add a gallery photo</h2>
          <p class="bb-photo-upload__sub">
            Snap a cut, fade, or beard from your chair. It appears at the top
            of <a class="bb-link" href={`${base}/gallery`} target="_blank" rel="noopener">/gallery</a> right away — no rebuild needed.
          </p>
        </header>
        <form id="bb-photo-form" class="bb-photo-upload__form">
          <label class="bb-photo-upload__picker">
            {/* No `capture` — iOS treats the attribute as a force-
                to-camera hint, which hides the Photo Library option.
                With just `accept="image/*"`, iOS shows the standard
                three-way sheet (Photo Library / Take Photo / Choose
                File) so a barber can either snap a new one or grab
                an existing photo from their roll. */}
            <input
              type="file"
              id="bb-photo-input"
              accept="image/*"
              multiple
            />
            <span class="bb-btn bb-btn--ghost bb-btn--sm">
              Choose photo(s)
            </span>
          </label>
          <button type="submit" class="bb-btn bb-btn--sm" id="bb-photo-submit" disabled>
            Upload
          </button>
        </form>
        <ul class="bb-photo-upload__queue" id="bb-photo-queue" hidden></ul>
        <p class="bb-photo-upload__status" id="bb-photo-status" hidden></p>
      </section>

      <nav class="bb-tabs" role="tablist" aria-label="Dashboard sections">
        <a
          class={`bb-tab ${activeTab === 'appointments' ? 'is-active' : ''}`}
          role="tab"
          aria-selected={activeTab === 'appointments'}
          href={`${base}/barber/dashboard?date=${filterDateKey}&tab=appointments`}
        >
          Appointments
          {rows.length > 0 && <span class="bb-tab__count">{rows.length}</span>}
        </a>
        <a
          class={`bb-tab ${activeTab === 'waitlist' ? 'is-active' : ''}`}
          role="tab"
          aria-selected={activeTab === 'waitlist'}
          href={`${base}/barber/dashboard?date=${filterDateKey}&tab=waitlist`}
        >
          Waitlist
          {waitlistRows.length > 0 && <span class="bb-tab__count">{waitlistRows.length}</span>}
        </a>
        <a
          class={`bb-tab ${activeTab === 'time-off' ? 'is-active' : ''}`}
          role="tab"
          aria-selected={activeTab === 'time-off'}
          href={`${base}/barber/dashboard?date=${filterDateKey}&tab=time-off`}
        >
          Time off
          {(timeBlocks.oneOff.length + timeBlocks.recurring.length) > 0 && (
            <span class="bb-tab__count">
              {timeBlocks.oneOff.length + timeBlocks.recurring.length}
            </span>
          )}
        </a>
      </nav>

      {activeTab === 'appointments' && (
        <form class="bb-filters" method="get" action="/barber/dashboard">
          <input type="hidden" name="tab" value="appointments" />
          <div class="bb-filters__quick">
            <a
              class={`bb-chip ${isToday ? 'is-active' : ''}`}
              href={`${base}/barber/dashboard?date=${todayKey}&tab=appointments`}
            >Today</a>
            <a
              class={`bb-chip ${isTomorrow ? 'is-active' : ''}`}
              href={`${base}/barber/dashboard?date=${tomorrowKey}&tab=appointments`}
            >Tomorrow</a>
          </div>
          <label class="bb-field bb-field--inline">
            <span class="bb-field__label">Date</span>
            <input type="date" name="date" value={filterDateKey} />
          </label>
          <button type="submit" class="bb-btn bb-btn--ghost">Show</button>
        </form>
      )}

      {loadError && <p class="bb-err">Couldn't load: {loadError}</p>}

      {activeTab === 'appointments' && (
      <section>
        <h2>
          {dateHeading}
          <span class="bb-sub">
            {!isToday && !isTomorrow ? '' : `${dateSubLabel} · `}
            {rows.length} {rows.length === 1 ? 'appointment' : 'appointments'}
          </span>
        </h2>
        {rows.length === 0 ? (
          <p class="bb-empty">No appointments scheduled.</p>
        ) : (
          <ul class="bb-list">
            {rows.map((r) => (
              <li class="bb-card" data-booking-id={r.bookingId}>
                <div class="bb-card__row">
                  <span class="bb-card__time">{r.startLocal}</span>
                  <span class={`bb-pill bb-pill--${statusClass(r.status)}`}>
                    {r.status.replace(/_/g, ' ')}
                  </span>
                </div>
                <div class="bb-card__customer">
                  <strong>{r.customerName}</strong>
                  <div class="bb-card__contact">
                    {r.customerPhone && (
                      <>
                        <a class="bb-card__phone" href={`tel:${r.customerPhoneE164}`}>
                          {formatPhone(r.customerPhone)}
                        </a>
                        <a
                          class="bb-btn bb-btn--ghost bb-btn--sm"
                          href={`sms:${r.customerPhoneE164}`}
                        >
                          Text customer
                        </a>
                      </>
                    )}
                  </div>
                </div>
                <dl class="bb-card__details">
                  <div><dt>Service</dt><dd>{r.service}</dd></div>
                  {r.note && <div><dt>Note</dt><dd>{r.note}</dd></div>}
                  {r.customerEmail && <div><dt>Email</dt><dd>{r.customerEmail}</dd></div>}
                </dl>
                <div class="bb-card__actions">
                  <button type="button" class="bb-btn bb-btn--ghost" data-cancel-btn>Cancel</button>
                  <button type="button" class="bb-btn bb-btn--ghost" data-reschedule-btn>Reschedule</button>
                </div>
                <div class="bb-card__reschedule" data-reschedule-panel hidden>
                  <label class="bb-field bb-field--inline">
                    <span class="bb-field__label">New date &amp; time</span>
                    <input
                      type="datetime-local"
                      data-reschedule-input
                      value={r.startInputValue}
                      step="900"
                    />
                  </label>
                  <div class="bb-card__reschedule-actions">
                    <button type="button" class="bb-btn bb-btn--ghost" data-reschedule-cancel>Back</button>
                    <button type="button" class="bb-btn" data-reschedule-submit>Save</button>
                  </div>
                </div>
                <p class="bb-card__msg" data-msg hidden></p>
              </li>
            ))}
          </ul>
        )}
      </section>
      )}

      {activeTab === 'waitlist' && (
      <section>
        <h2>
          {isOwner ? 'Shop-wide waitlist' : 'Your waitlist'}
          <span class="bb-sub">
            {waitlistRows.length} {waitlistRows.length === 1 ? 'entry' : 'entries'}
            {isOwner ? ' · all barbers' : ''}
          </span>
        </h2>
        {waitlistRows.length === 0 ? (
          <p class="bb-empty">
            {isOwner
              ? 'No active waitlist entries right now.'
              : 'No active waitlist entries that asked for you.'}
          </p>
        ) : (
          <ul class="bb-list">
            {waitlistRows.map((w) => {
              // "Schedule" is available only when this entry can be
              // booked under the CALLING barber's chair: either it
              // asked for no specific barber (any-barber entry) OR
              // the calling barber is one of the requested ones.
              // Legacy entries without a resolved serviceVariationId
              // are hidden too — see the field comment.
              const canSchedule =
                !!w.serviceVariationId &&
                (w.requestedBarberIds.length === 0 ||
                  w.requestedBarberIds.includes(session.barberId));
              const firstName = w.customerName.trim().split(/\s+/)[0] || w.customerName;
              return (
              <li class="bb-card" data-waitlist-row={w.id}>
                <div class="bb-card__row">
                  <strong>{w.customerName}</strong>
                  <span class={`bb-pill bb-pill--${w.status === 'contacted' ? 'pending' : 'ok'}`}>
                    {w.status}
                  </span>
                </div>
                <div class="bb-card__contact">
                  {w.customerPhone && (
                    <>
                      <a class="bb-card__phone" href={`tel:${w.customerPhoneE164}`}>
                        {formatPhone(w.customerPhone)}
                      </a>
                      <a
                        class="bb-btn bb-btn--ghost bb-btn--sm"
                        href={`sms:${w.customerPhoneE164}`}
                      >
                        Text customer
                      </a>
                    </>
                  )}
                  {canSchedule && (
                    <button
                      type="button"
                      class="bb-btn bb-btn--sm"
                      data-schedule-btn
                      data-entry-id={w.id}
                      data-service-variation-id={w.serviceVariationId}
                      data-service-name={w.serviceName}
                      data-customer-first-name={firstName}
                      data-date-from={w.dateFrom ?? ''}
                      data-date-to={w.dateTo ?? ''}
                    >
                      Schedule
                    </button>
                  )}
                </div>
                <dl class="bb-card__details">
                  <div><dt>Service</dt><dd>{w.serviceName}</dd></div>
                  {isOwner && (
                    <div>
                      <dt>Asked for</dt>
                      <dd>{w.requestedBarbers.length > 0 ? w.requestedBarbers.join(', ') : 'Any barber'}</dd>
                    </div>
                  )}
                  {w.preferredDate && <div><dt>Preferred</dt><dd>{w.preferredDate}</dd></div>}
                  {(() => {
                    const window = formatWaitlistWindow(w.dateFrom, w.dateTo);
                    return window ? <div><dt>When</dt><dd>{window}</dd></div> : null;
                  })()}
                  <div><dt>Days</dt><dd>{formatWaitlistDays(w.daysOfWeek)}</dd></div>
                  <div><dt>Times</dt><dd>{formatWaitlistTimes(w.timesOfDay)}</dd></div>
                  {w.note && <div><dt>Note</dt><dd>{w.note}</dd></div>}
                  {w.adminNote && <div><dt>Shop note</dt><dd>{w.adminNote}</dd></div>}
                  {w.customerEmail && <div><dt>Email</dt><dd>{w.customerEmail}</dd></div>}
                </dl>
                {canSchedule && (
                  <div class="bb-schedule-panel" data-schedule-panel hidden>
                    <p class="bb-schedule-panel__head">
                      <strong>Choose a slot</strong> to schedule {firstName} for {w.serviceName}.
                    </p>
                    <p class="bb-schedule-panel__hint">
                      Customer prefers: {formatWaitlistTimes(w.timesOfDay)} · {formatWaitlistDays(w.daysOfWeek)}
                    </p>
                    <div class="bb-schedule-panel__slots" data-slots>
                      <p class="bb-schedule-panel__loading">Loading openings…</p>
                    </div>
                    <p class="bb-schedule-panel__status" data-schedule-status hidden></p>
                    <div class="bb-schedule-panel__actions">
                      <button type="button" class="bb-btn bb-btn--ghost bb-btn--sm" data-extend hidden>
                        Show next 14 days →
                      </button>
                      <button type="button" class="bb-btn bb-btn--ghost bb-btn--sm" data-cancel-schedule>
                        Cancel
                      </button>
                    </div>
                  </div>
                )}
              </li>
              );
            })}
          </ul>
        )}
      </section>
      )}

      {activeTab === 'time-off' && (
      <section class="bb-timeoff">
        <h2>
          Time off
          <span class="bb-sub">block times so customers can't book</span>
        </h2>

        <form class="bb-timeoff__form" id="bb-timeoff-one-off">
          <h3 class="bb-timeoff__form-head">Add a one-off block</h3>
          <label class="bb-timeoff__all-day">
            <input type="checkbox" data-all-day name="allDay" />
            <span>All day</span>
          </label>
          <div class="bb-timeoff__row">
            <label class="bb-timeoff__field">
              <span>Date</span>
              <input type="date" name="date" required />
            </label>
            <label class="bb-timeoff__field">
              <span>From</span>
              <input type="time" name="startTime" required />
            </label>
            <label class="bb-timeoff__field">
              <span>To</span>
              <input type="time" name="endTime" required />
            </label>
          </div>
          <label class="bb-timeoff__field">
            <span>Note (optional)</span>
            <input type="text" name="note" maxlength="200" placeholder="e.g. Dentist" />
