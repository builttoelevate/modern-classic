          <div class="bb-timeoff__actions">
            <button type="submit" class="bb-btn bb-btn--sm">Add block</button>
          </div>
          <p class="bb-timeoff__status" data-status hidden></p>
        </form>

        <form class="bb-timeoff__form" id="bb-timeoff-recurring">
          <h3 class="bb-timeoff__form-head">Add weekly recurring</h3>
          <fieldset class="bb-timeoff__days">
            <legend>Days</legend>
            <label><input type="checkbox" name="dow" value="mon" /> Mon</label>
            <label><input type="checkbox" name="dow" value="tue" /> Tue</label>
            <label><input type="checkbox" name="dow" value="wed" /> Wed</label>
            <label><input type="checkbox" name="dow" value="thu" /> Thu</label>
            <label><input type="checkbox" name="dow" value="fri" /> Fri</label>
            <label><input type="checkbox" name="dow" value="sat" /> Sat</label>
          </fieldset>
          <label class="bb-timeoff__all-day">
            <input type="checkbox" data-all-day name="allDay" />
            <span>All day</span>
          </label>
          <div class="bb-timeoff__row">
            <label class="bb-timeoff__field">
              <span>From</span>
              <input type="time" name="startTime" required />
            </label>
            <label class="bb-timeoff__field">
              <span>To</span>
              <input type="time" name="endTime" required />
            </label>
          </div>
          <div class="bb-timeoff__row">
            <label class="bb-timeoff__field">
              <span>Starts</span>
              <input type="date" name="startsOn" required />
            </label>
            <label class="bb-timeoff__field">
              <span>Ends (optional)</span>
              <input type="date" name="endsOn" />
            </label>
          </div>
          <label class="bb-timeoff__field">
            <span>Note (optional)</span>
            <input type="text" name="note" maxlength="200" placeholder="e.g. Lunch" />
          </label>
          <div class="bb-timeoff__actions">
            <button type="submit" class="bb-btn bb-btn--sm">Add recurring block</button>
          </div>
          <p class="bb-timeoff__status" data-status hidden></p>
        </form>

        <div class="bb-timeoff__list">
          <h3 class="bb-timeoff__form-head">Active blocks</h3>
          {timeBlocks.oneOff.length + timeBlocks.recurring.length === 0 ? (
            <p class="bb-empty">No blocks yet. Add one above.</p>
          ) : (
            <ul class="bb-list" id="bb-timeoff-active">
              {timeBlocks.oneOff
                .slice()
                .sort((a, b) => a.startUtc.localeCompare(b.startUtc))
                .map((b) => {
                  const start = new Date(b.startUtc);
                  const end = new Date(b.endUtc);
                  const dateLabel = new Intl.DateTimeFormat('en-US', {
                    timeZone: SHOP_TZ,
                    weekday: 'short',
                    month: 'short',
                    day: 'numeric',
                  }).format(start);
                  const startLabel = new Intl.DateTimeFormat('en-US', {
                    timeZone: SHOP_TZ,
                    hour: 'numeric',
                    minute: '2-digit',
                    hour12: true,
                  }).format(start);
                  const endLabel = new Intl.DateTimeFormat('en-US', {
                    timeZone: SHOP_TZ,
                    hour: 'numeric',
                    minute: '2-digit',
                    hour12: true,
                  }).format(end);
                  return (
                    <li class="bb-card bb-timeoff__row-card" data-block-id={b.id}>
                      <div class="bb-card__row">
