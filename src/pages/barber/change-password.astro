---
export const prerender = false;

import { getBarberSession } from '../../lib/auth/barberMiddleware';
import '../../styles/barber.css';

const session = getBarberSession(Astro.request);
if (!session) {
  return new Response(null, {
    status: 302,
    headers: { Location: '/barber/sign-in' },
  });
}
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Change password — Modern Classic</title>
  </head>
  <body class="bb-page">
    <main class="bb-auth">
      <header class="bb-auth__head">
        <p class="bb-eyebrow">Hello, {session.username}</p>
        <h1>Set a new password</h1>
        <p class="bb-auth__lede">
          Pick something you'll remember — at least 8 characters. After this
          you'll head straight to your dashboard.
        </p>
      </header>
      <form class="bb-form" id="cp-form" novalidate>
        <label class="bb-field">
          <span class="bb-field__label">Current password</span>
          <input type="password" name="currentPassword" autocomplete="current-password" required />
        </label>
        <label class="bb-field">
          <span class="bb-field__label">New password</span>
          <input type="password" name="newPassword" autocomplete="new-password" minlength="8" required />
        </label>
        <label class="bb-field">
          <span class="bb-field__label">Confirm new password</span>
          <input type="password" name="confirmPassword" autocomplete="new-password" minlength="8" required />
        </label>
        <p class="bb-form__error" id="cp-error" hidden></p>
        <button type="submit" class="bb-btn" id="cp-submit">Save and continue</button>
      </form>
    </main>

    <script is:inline>
      (function () {
        const form = document.getElementById('cp-form');
        const errorEl = document.getElementById('cp-error');
        const submit = document.getElementById('cp-submit');
        if (!form) return;
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          errorEl.hidden = true;
          const data = new FormData(form);
          const newP = String(data.get('newPassword') ?? '');
          const conf = String(data.get('confirmPassword') ?? '');
          if (newP !== conf) {
            errorEl.textContent = 'Confirmation does not match.';
            errorEl.hidden = false;
            return;
          }
          submit.disabled = true;
          const original = submit.textContent;
          submit.textContent = 'Saving…';
          try {
            const res = await fetch('/api/barber/auth/change-password', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                currentPassword: data.get('currentPassword'),
                newPassword: newP,
              }),
            });
            const body = await res.json();
            if (!body.ok) {
              errorEl.textContent =
                body?.error?.detail || 'Could not change password.';
              errorEl.hidden = false;
              submit.disabled = false;
              submit.textContent = original;
              return;
            }
            window.location.href = '/barber/dashboard';
          } catch (_err) {
            errorEl.textContent = 'Network error. Try again.';
            errorEl.hidden = false;
            submit.disabled = false;
            submit.textContent = original;
          }
        });
      })();
    </script>
  </body>
</html>
