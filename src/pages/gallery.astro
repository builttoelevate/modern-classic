---
// SSR — so barber uploads (Vercel Blob) appear on the next page
// render without a rebuild. Bundled curated photos still render
// alongside dynamic uploads; blob uploads are listed newest-first,
// curated come after as the stable visual anchor.
export const prerender = false;

import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileBookCTA from '../components/MobileBookCTA.astro';
import {
  listBundledTombstones,
  listGalleryPhotos,
  type GalleryBlobPhoto,
} from '../lib/gallery/blobPhotos';

const imageModules = import.meta.glob<ImageMetadata>(
  '../assets/gallery/*.jpg',
  { eager: true, import: 'default' }
);

const bundledPhotosAll = Object.entries(imageModules)
  .map(([path, src]) => ({
    src,
    id: path.split('/').pop()!.replace(/\.jpg$/, ''),
    filename: path.split('/').pop()!,
  }))
  .sort((a, b) => a.id.localeCompare(b.id));

// Blob photos (curated + per-barber). Cached in Redis (60s) so the
// /gallery render doesn't hit Vercel Blob on every request; upload
// + delete endpoints invalidate the cache so the surface stays
// fresh. Falls back to [] on any failure — page still renders the
// bundled curated photos.
//
// Tombstones: bundled-asset filenames the operator has explicitly
// hidden via /admin/gallery. Without these, a bundled photo whose
// Blob curated copy was deleted would silently re-surface. See
// src/lib/gallery/blobPhotos.ts.
let blobPhotos: GalleryBlobPhoto[] = [];
let tombstones: Set<string> = new Set();
try {
  [blobPhotos, tombstones] = await Promise.all([
    listGalleryPhotos().catch(() => [] as GalleryBlobPhoto[]),
    listBundledTombstones().catch(() => new Set<string>()),
  ]);
} catch {
  blobPhotos = [];
  tombstones = new Set();
}

// Dedup bundled vs Blob. After the admin runs the one-time migrate
// (PR #112), every bundled photo also lives in Blob under
// `gallery/curated/{filename}.jpg`. Without this filter both
// would render and the gallery would double. Skipping any
// bundled whose filename appears as a curated Blob makes the
// pre-migration → post-migration → bundled-removed transition
// visually seamless. The tombstone set extends that: once an
// operator hides a bundled filename, it stays hidden even if no
// Blob copy is currently masking it.
const curatedBlobBasenames = new Set<string>(
  blobPhotos
    .filter((p) => p.kind === 'curated')
    .map((p) => {
      const i = p.pathname.lastIndexOf('/');
      return i === -1 ? p.pathname : p.pathname.slice(i + 1);
    }),
);
const bundledPhotos = bundledPhotosAll.filter(
  (p) => !curatedBlobBasenames.has(p.filename) && !tombstones.has(p.filename),
);

// Use our local /book wizard on Vercel/prod; only fall back to the
// legacy Square site on the gh-pages preview where SSR doesn't exist.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isGhPages = import.meta.env.BASE_URL && import.meta.env.BASE_URL !== '/';
const bookUrl = isGhPages ? 'https://modern-classic.square.site' : `${base}/book`;

const totalCount = blobPhotos.length + bundledPhotos.length;
---
<BaseLayout
  title="Gallery — Modern Classic Barbershop & Shave Parlor"
  description="A look at recent cuts, fades, beards, and shaves from the chairs at Modern Classic Barbershop in Zanesville, Ohio."
>
  <Header />
  <main id="main">
    <section class="gallery-hero" aria-labelledby="gallery-heading">
      <div class="gallery-hero__ornaments" aria-hidden="true">
        <div class="gallery-hero__glow"></div>
      </div>
      <div class="container gallery-hero__inner">
        <p class="eyebrow">Recent Work</p>
        <h1 id="gallery-heading" class="gallery-hero__h1">
          <span class="gallery-hero__line">The Modern Classic</span>
          <span class="gallery-hero__line italic-accent">look.</span>
        </h1>
        <p class="lede">
          Cuts, fades, beard work and traditional shaves — straight from the
          chairs at 819 Linden Avenue.
        </p>
        <hr class="rule" />
      </div>
    </section>

    <section class="gallery" aria-label="Photo gallery">
      <div class="container">
        <div class="gallery__grid" id="galleryGrid">
          {blobPhotos.map((photo, i) => (
            <button
              type="button"
              class="gallery__item"
              data-index={i}
              data-full={photo.url}
              aria-label={`Open photo ${i + 1} of ${totalCount}`}
            >
              <img
                class="gallery__img"
                src={photo.url}
                alt={`Modern Classic barbershop work — photo ${i + 1}`}
                loading={i < 6 ? 'eager' : 'lazy'}
                decoding="async"
              />
              <span class="gallery__overlay" aria-hidden="true">
                <span class="gallery__view">View</span>
              </span>
            </button>
          ))}
          {bundledPhotos.map((photo, j) => {
            const i = blobPhotos.length + j;
            return (
              <button
                type="button"
                class="gallery__item"
                data-index={i}
                aria-label={`Open photo ${i + 1} of ${totalCount}`}
              >
                <Image
                  src={photo.src}
                  alt={`Modern Classic barbershop work — photo ${i + 1}`}
                  widths={[320, 480, 640, 800]}
                  sizes="(min-width: 1100px) 360px, (min-width: 720px) 45vw, 92vw"
                  loading={i < 6 ? 'eager' : 'lazy'}
                  class="gallery__img"
                />
                <span class="gallery__overlay" aria-hidden="true">
                  <span class="gallery__view">View</span>
                </span>
              </button>
            );
          })}
        </div>

        <div class="gallery__cta">
          <p class="gallery__cta-text">
            <span class="italic-accent">Book now.</span>
          </p>
          <a
            class="btn"
            href={bookUrl}
            {...(isGhPages ? { target: '_blank', rel: 'noopener' } : {})}
          >
            Book a Visit <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Lightbox -->
    <div
      class="lightbox"
      id="lightbox"
      role="dialog"
      aria-modal="true"
      aria-label="Gallery image viewer"
      aria-hidden="true"
    >
      <button type="button" class="lightbox__close" aria-label="Close gallery viewer" data-action="close">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M5 5 L19 19 M19 5 L5 19" />
        </svg>
      </button>

      <button type="button" class="lightbox__nav lightbox__nav--prev" aria-label="Previous photo" data-action="prev">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 6 L9 12 L15 18" />
        </svg>
      </button>

      <figure class="lightbox__stage">
        <img class="lightbox__img" id="lightboxImg" alt="" />
        <figcaption class="lightbox__caption" id="lightboxCaption"></figcaption>
      </figure>

      <button type="button" class="lightbox__nav lightbox__nav--next" aria-label="Next photo" data-action="next">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 6 L15 12 L9 18" />
        </svg>
      </button>
    </div>
  </main>
  <Footer />
  <MobileBookCTA />
</BaseLayout>

<script>
  type Photo = { full: string; alt: string };

  const grid = document.getElementById('galleryGrid');
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightboxImg') as HTMLImageElement | null;
  const lbCaption = document.getElementById('lightboxCaption');

  if (grid && lightbox && lbImg && lbCaption) {
    const items = Array.from(grid.querySelectorAll<HTMLButtonElement>('.gallery__item'));
    const photos: Photo[] = items.map((btn) => {
      const img = btn.querySelector<HTMLImageElement>('img.gallery__img');
      // Blob uploads carry the full URL on data-full (they're already
      // delivered at upload-time resolution, no srcset). Bundled
      // curated photos render via Astro Image with a srcset; pick
      // the largest entry for the lightbox.
      const dataFull = btn.dataset.full;
      if (dataFull) return { full: dataFull, alt: img?.alt ?? '' };
      let full = img?.currentSrc || img?.src || '';
      if (img?.srcset) {
        const candidates = img.srcset
          .split(',')
          .map((s) => s.trim())
          .map((entry) => {
            const [url, descriptor] = entry.split(/\s+/);
            const w = descriptor && descriptor.endsWith('w')
              ? parseInt(descriptor, 10)
              : 0;
            return { url, w };
          })
          .sort((a, b) => b.w - a.w);
        if (candidates.length && candidates[0].url) full = candidates[0].url;
      }
      return { full, alt: img?.alt ?? '' };
    });

    let current = 0;
    let lastFocused: HTMLElement | null = null;

    const open = (i: number) => {
      current = (i + photos.length) % photos.length;
      const p = photos[current];
      lbImg.src = p.full;
      lbImg.alt = p.alt;
      lbCaption.textContent = `${current + 1} / ${photos.length}`;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      lastFocused = document.activeElement as HTMLElement | null;
      const closeBtn = lightbox.querySelector<HTMLButtonElement>('[data-action="close"]');
      closeBtn?.focus();
    };

    const close = () => {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lbImg.src = '';
      lastFocused?.focus();
    };

    const next = () => open(current + 1);
    const prev = () => open(current - 1);

    items.forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.dataset.index);
        if (!Number.isNaN(idx)) open(idx);
      });
    });

    lightbox.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const action = target.closest<HTMLElement>('[data-action]')?.dataset.action;
      if (action === 'close') close();
      else if (action === 'next') next();
      else if (action === 'prev') prev();
      else if (target === lightbox) close();
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowRight') next();
      else if (e.key === 'ArrowLeft') prev();
    });

    // Touch swipe
    let touchStartX = 0;
    let touchStartY = 0;
    lightbox.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });
    lightbox.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        dx < 0 ? next() : prev();
      }
    }, { passive: true });
  }

  // Reveal-on-scroll
  if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      }
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });

    document.querySelectorAll('.gallery__item').forEach((el) => io.observe(el));
  } else {
    document.querySelectorAll('.gallery__item').forEach((el) => el.classList.add('is-visible'));
  }
</script>

<style>
  /* ---------- Page hero ---------- */
  .gallery-hero {
    position: relative;
    padding-block: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3rem);
    isolation: isolate;
    overflow: hidden;
  }
  .gallery-hero__ornaments {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }
  .gallery-hero__glow {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: min(880px, 90%);
    height: 320px;
    background: radial-gradient(ellipse at center,
      rgba(201, 163, 92, 0.14), transparent 65%);
    filter: blur(28px);
  }
  .gallery-hero__inner {
    display: grid;
    gap: 1.1rem;
    text-align: center;
    justify-items: center;
  }
  .gallery-hero__h1 {
    display: grid;
    gap: 0.05em;
    margin-top: 0.25rem;
  }
  .gallery-hero__line {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
  }
  .gallery-hero__h1 .italic-accent {
    font-style: italic;
    font-weight: 300;
  }
  .gallery-hero .rule {
    width: min(420px, 70%);
    margin-top: 1.25rem;
  }

  /* ---------- Gallery grid (CSS columns masonry) ---------- */
  .gallery { padding-block: clamp(2rem, 4vw, 3.5rem) clamp(4rem, 8vw, 7rem); }

  .gallery__grid {
    column-count: 3;
    column-gap: 1rem;
  }
  @media (max-width: 980px) { .gallery__grid { column-count: 2; } }
  @media (max-width: 540px) { .gallery__grid { column-count: 1; } }

  .gallery__item {
    display: block;
    position: relative;
    width: 100%;
    margin: 0 0 1rem;
    padding: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius);
    overflow: hidden;
    cursor: zoom-in;
    break-inside: avoid;
    transition:
      transform var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      opacity 600ms var(--ease);
    opacity: 0;
    transform: translateY(14px);
  }
  .gallery__item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .gallery__item:hover,
  .gallery__item:focus-visible {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-gold);
    transform: translateY(-2px);
  }
  .gallery__img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 700ms var(--ease), filter var(--dur) var(--ease);
    filter: saturate(0.95) contrast(1.02);
  }
  .gallery__item:hover .gallery__img {
    transform: scale(1.04);
    filter: saturate(1.05) contrast(1.05);
  }

  .gallery__overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: end center;
    padding: 1rem;
    background: linear-gradient(to top,
      rgba(11, 10, 8, 0.85) 0%,
      rgba(11, 10, 8, 0.25) 35%,
      transparent 60%);
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
    pointer-events: none;
  }
  .gallery__item:hover .gallery__overlay,
  .gallery__item:focus-visible .gallery__overlay {
    opacity: 1;
  }
  .gallery__view {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    padding: 0.5em 1em;
    border: 1px solid var(--color-gold);
    border-radius: 2px;
    background: rgba(11, 10, 8, 0.55);
    backdrop-filter: blur(4px);
  }

  /* ---------- Footer CTA below grid ---------- */
  .gallery__cta {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    justify-items: center;
    gap: 1rem;
    text-align: center;
  }
  .gallery__cta-text {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1rem + 1.6vw, 2.25rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    color: var(--color-text);
    margin: 0;
  }

  /* ---------- Lightbox ---------- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    background: rgba(7, 6, 5, 0.94);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
  }
  .lightbox.is-open {
    display: flex;
    animation: lb-fade 220ms var(--ease);
  }
  @keyframes lb-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .lightbox__stage {
    position: relative;
    max-width: min(1100px, 92vw);
    max-height: 86vh;
    margin: 0;
    display: grid;
    place-items: center;
    gap: 0.75rem;
  }
  .lightbox__img {
    max-width: 100%;
    max-height: 80vh;
    width: auto;
    height: auto;
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.8),
                0 0 0 1px rgba(201, 163, 92, 0.15);
    background: var(--color-bg);
    animation: lb-pop 320ms var(--ease);
  }
  @keyframes lb-pop {
    from { opacity: 0; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1); }
  }
  .lightbox__caption {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .lightbox__close {
    position: absolute;
    top: clamp(0.75rem, 2vw, 1.5rem);
    right: clamp(0.75rem, 2vw, 1.5rem);
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(11, 10, 8, 0.6);
    transition: color var(--dur) var(--ease),
                border-color var(--dur) var(--ease),
                background var(--dur) var(--ease);
  }
  .lightbox__close:hover {
    color: var(--color-gold-light);
    border-color: var(--color-gold);
    background: rgba(11, 10, 8, 0.85);
  }

  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(11, 10, 8, 0.6);
    transition: color var(--dur) var(--ease),
                border-color var(--dur) var(--ease),
                background var(--dur) var(--ease),
                transform var(--dur) var(--ease);
  }
  .lightbox__nav:hover {
    color: var(--color-gold-light);
    border-color: var(--color-gold);
    background: rgba(11, 10, 8, 0.85);
  }
  .lightbox__nav--prev {
    left: clamp(0.5rem, 2vw, 1.5rem);
  }
  .lightbox__nav--next {
    right: clamp(0.5rem, 2vw, 1.5rem);
  }
  .lightbox__nav--prev:hover { transform: translate(-3px, -50%); }
  .lightbox__nav--next:hover { transform: translate(3px, -50%); }

  @media (max-width: 540px) {
    .lightbox__nav { width: 44px; height: 44px; }
  }
</style>
