---
export const prerender = false;

import { checkBasicAuth } from '../../lib/admin/auth';
import { getLastReviewCronRun, getReviewStats } from '../../lib/marketing/reviewLog';

const auth = checkBasicAuth(Astro.request);
if (!auth.ok) {
  return auth.challenge;
}

let last30: Awaited<ReturnType<typeof getReviewStats>> | null = null;
let last90: Awaited<ReturnType<typeof getReviewStats>> | null = null;
let lastRun: Awaited<ReturnType<typeof getLastReviewCronRun>> | null = null;
let loadError: string | null = null;

try {
  [last30, last90, lastRun] = await Promise.all([
    getReviewStats({ daysBack: 30, recentLimit: 50 }),
    getReviewStats({ daysBack: 90, recentLimit: 50 }),
    getLastReviewCronRun(),
  ]);
} catch (err) {
  loadError = err instanceof Error ? err.message : String(err);
}

// Sum every skip category to figure out the headline reason. The
// dashboard shows the breakdown either way, but a single "nothing sent
// because: 12 customers haven't opted in" line tells Michael at a
// glance what's actually happening.
function summariseSkip(run: NonNullable<typeof lastRun>): string | null {
  const s = run.skipped;
  const entries: Array<[string, number]> = [
    ['not yet a completed appointment', s.notAccepted],
    ['already emailed for this booking', s.alreadySent],
    ['no email / unknown customer', s.customerMissing],
    ['customer opted out of review emails', s.optedOut],
    ['recently emailed (180-day cooldown)', s.recentRequest],
    ['service or barber lookup failed', s.serviceMissing + s.barberMissing],
  ];
  const top = entries.filter(([, n]) => n > 0).sort((a, b) => b[1] - a[1])[0];
  if (!top) return null;
  return `${top[1]} ${top[1] === 1 ? 'booking' : 'bookings'} skipped — ${top[0]}.`;
}

const lastRunHeadline = lastRun && lastRun.sent === 0 && !lastRun.error
  ? summariseSkip(lastRun)
  : null;

function fmtPct(rate: number): string {
  if (!isFinite(rate) || rate < 0) return '0%';
  return `${(rate * 100).toFixed(1)}%`;
}

function fmtDate(iso: string | null | undefined): string {
  if (!iso) return '—';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso ?? '—';
  return new Intl.DateTimeFormat('en-US', {
    timeZone: 'America/New_York',
    month: 'short',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    hour12: true,
  }).format(d);
}

const recent = last30?.recent ?? [];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Reviews — Modern Classic Admin</title>
    <style>
      :root {
        --bg: #0b0a08;
        --surface: #161311;
        --surface-2: #1d1916;
        --border: #2a2520;
        --text: #f3ece0;
        --muted: #b0a695;
        --dim: #80776a;
        --gold: #c9a35c;
      }
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font: 16px/1.5 ui-sans-serif, system-ui, sans-serif;
      }
      .wrap { max-width: 72rem; margin: 0 auto; padding: 32px 24px; }
      .topnav {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        align-items: center;
        padding-bottom: 18px;
        margin-bottom: 24px;
        border-bottom: 1px solid var(--border);
        font-size: 0.78rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .topnav a {
        color: var(--muted);
        text-decoration: none;
        padding-bottom: 4px;
      }
      .topnav a.active {
        color: var(--gold);
        border-bottom: 2px solid var(--gold);
      }
      .topnav a:hover { color: var(--gold); }
      h1 { font-family: Georgia, serif; font-weight: 400; font-size: 1.8rem; margin: 0 0 6px; }
      .sub { color: var(--muted); font-size: 0.95rem; margin-bottom: 28px; }
      .err {
        background: rgba(220, 80, 60, 0.08);
        border: 1px solid rgba(220, 80, 60, 0.4);
        color: #f0a37a;
        padding: 12px 16px;
        border-radius: 6px;
      }
      .stat-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-bottom: 32px;
      }
      @media (max-width: 600px) { .stat-grid { grid-template-columns: 1fr; } }
      .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px 22px;
      }
      .stat-eyebrow {
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 8px;
      }
      .stat-headline {
        font-family: Georgia, serif;
        font-size: 1.4rem;
        margin: 0 0 4px;
      }
      .stat-detail {
        color: var(--muted);
        font-size: 0.92rem;
      }
      .stat-detail strong {
        color: var(--text);
      }
      h2 {
        font-family: Georgia, serif;
        font-weight: 400;
        font-size: 1.25rem;
        margin: 0 0 12px;
      }
      .table-scroll {
        /* On narrow viewports, let the table scroll horizontally
           instead of wrapping every cell to four lines. */
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--surface);
      }
      table {
        width: 100%;
        min-width: 720px; /* keeps columns readable; scroll kicks in below this */
        border-collapse: collapse;
        font-size: 0.92rem;
      }
      th, td {
        padding: 10px 12px;
        text-align: left;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
        white-space: nowrap;
      }
      /* The customer-email column can wrap if needed; everything
         else stays one-line. */
      td.meta--wrap { white-space: normal; word-break: break-all; }
      th {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--surface);
      }
      tr:hover td { background: var(--surface-2); }
      .pill {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .pill.clicked { background: rgba(122, 184, 110, 0.15); color: #a4d091; }
      .pill.unclicked { background: rgba(128, 119, 106, 0.15); color: var(--dim); }
      .meta { color: var(--dim); font-family: ui-monospace, Menlo, monospace; font-size: 0.8rem; }

      /* Diagnostics panel */
      .panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 18px 22px;
        margin-bottom: 32px;
      }
      .panel--warn {
        background: rgba(201, 163, 92, 0.06);
        border-color: rgba(201, 163, 92, 0.4);
      }
      .panel--err {
        background: rgba(220, 80, 60, 0.08);
        border-color: rgba(220, 80, 60, 0.4);
      }
      .panel__title {
        font-family: Georgia, serif;
        font-size: 1.15rem;
        margin: 0 0 8px;
      }
      .panel__lede { color: var(--muted); font-size: 0.92rem; margin: 0 0 14px; }
      .panel__lede strong { color: var(--text); }
      .panel__skip-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 10px;
        margin: 14px 0 18px;
      }
      .panel__skip {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 10px 12px;
        font-size: 0.88rem;
      }
      .panel__skip-label {
        font-size: 0.68rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--dim);
        margin-bottom: 4px;
      }
      .panel__skip-value { font-size: 1.2rem; color: var(--text); }
      .panel__skip-value strong { color: var(--gold); }
      .panel__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 14px;
      }
      .btn {
        appearance: none;
        background: var(--gold);
        color: #1a140a;
        border: 1px solid var(--gold);
        padding: 9px 16px;
        font: inherit;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        border-radius: 4px;
        cursor: pointer;
      }
      .btn:disabled { opacity: 0.55; cursor: not-allowed; }
      .btn--ghost {
        background: transparent;
        color: var(--text);
        border-color: var(--border);
      }
      .btn--ghost:hover { border-color: var(--gold); color: var(--gold); }
      .panel__output {
        margin-top: 14px;
        padding: 12px 14px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        font-family: ui-monospace, Menlo, monospace;
        font-size: 0.85rem;
        white-space: pre-wrap;
        word-break: break-word;
        color: var(--text);
      }
      .panel__output[hidden] { display: none; }

      /* Run-now progress indicator. Replaces the raw JSON dump while
         the cron is running so the admin sees movement, and stays
         visible when the fetch times out client-side (function may
         keep running in the background — we auto-refresh to catch
         the result). */
      .run-progress {
        margin-top: 14px;
        padding: 14px 16px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        display: flex;
        align-items: center;
        gap: 14px;
        color: var(--text);
      }
      .run-progress[hidden] { display: none; }
      .run-progress[data-state='error'] { border-color: rgba(220, 80, 60, 0.5); }
      .run-progress[data-state='done'] { border-color: rgba(122, 184, 110, 0.5); }
      .run-progress__spinner {
        flex: 0 0 auto;
        width: 22px;
        height: 22px;
        border: 2px solid rgba(201, 163, 92, 0.25);
        border-top-color: var(--gold);
        border-radius: 999px;
        animation: spin 720ms linear infinite;
      }
      .run-progress[data-state='done'] .run-progress__spinner {
        border-color: rgba(122, 184, 110, 0.3);
        border-top-color: #a4d091;
        animation: none;
      }
      .run-progress[data-state='error'] .run-progress__spinner {
        border-color: rgba(220, 80, 60, 0.3);
        border-top-color: #f0a37a;
        animation: none;
      }
      .run-progress__text { display: grid; gap: 4px; font-size: 0.9rem; }
      .run-progress__text strong { color: var(--gold-light); font-weight: 600; }
      .run-progress[data-state='done'] .run-progress__text strong { color: #a4d091; }
      .run-progress[data-state='error'] .run-progress__text strong { color: #f0a37a; }
      .run-progress__text button {
        margin-top: 6px;
        align-self: flex-start;
      }
      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      .run-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        vertical-align: middle;
      }
      .run-badge--dry {
        background: rgba(120, 160, 220, 0.15);
        color: #9bb5dc;
        border: 1px solid rgba(120, 160, 220, 0.4);
      }
      .run-badge--live {
        background: rgba(201, 163, 92, 0.15);
        color: var(--gold);
        border: 1px solid rgba(201, 163, 92, 0.4);
      }

      .test-form {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: flex-end;
      }
      .test-form__field {
        flex: 1 1 240px;
        min-width: 0;
        display: grid;
        gap: 4px;
        font-size: 0.85rem;
        color: var(--muted);
      }
      .test-form__field input {
        padding: 8px 10px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: rgba(0, 0, 0, 0.25);
        color: var(--text);
        font: inherit;
      }
      .status {
        margin: 10px 0 0;
        padding: 8px 10px;
        border-radius: 6px;
        font-size: 0.88rem;
      }
      .status--ok {
        background: rgba(122, 184, 110, 0.15);
        color: #a4d091;
      }
      .status--error {
        background: rgba(220, 80, 80, 0.15);
        color: #f0a37a;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <nav class="topnav">
        <a href="/admin">Admin</a>
        <a href="/admin/today">Today</a>
        <a href="/admin/bookings">Bookings</a>
        <a href="/admin/customers">Customers</a>
        <a href="/admin/waitlist">Waitlist</a>
        <a href="/admin/gallery">Gallery</a>
        <a href="/admin/reviews" class="active">Reviews</a>
      </nav>
      <h1>Review request stats</h1>
      <p class="sub">Automated review-request emails sent by the daily cron at 10 AM ET.</p>

      {loadError && (
        <p class="err">Failed to load stats: {loadError}</p>
      )}

      {!loadError && (
        <div class={`panel ${lastRun?.error ? 'panel--err' : lastRun && lastRun.sent === 0 ? 'panel--warn' : ''}`}>
          <h2 class="panel__title">Last cron run</h2>
          {!lastRun && (
            <p class="panel__lede">
              The review-request cron hasn't recorded a run yet. Click <strong>Run now</strong> below to trigger it manually and see what happens. (The scheduled run happens daily at 10 AM ET via Vercel.)
            </p>
          )}
          {lastRun?.error && (
            <p class="panel__lede">
              <strong>Last run failed:</strong> {lastRun.error.code} — {lastRun.error.detail}<br />
              Ran at {fmtDate(lastRun.ranAt)}{lastRun.manuallyTriggered ? ' (manual)' : ' (scheduled)'}.
            </p>
          )}
          {lastRun && !lastRun.error && (
            <>
              <p class="panel__lede">
                Ran at <strong>{fmtDate(lastRun.ranAt)}</strong>
                {lastRun.manuallyTriggered ? ' (manual)' : ' (scheduled)'}.
                {lastRun.dryRun ? (
                  <> <span class="run-badge run-badge--dry">Dry run — no emails sent</span></>
                ) : (
                  <> <span class="run-badge run-badge--live">Live — emails sent</span></>
                )}
                <br />
                Scanned <strong>{lastRun.processed}</strong> bookings in the 2–5 day window,
                {lastRun.dryRun ? ' would have sent ' : ' sent '}
                <strong>{lastRun.sent}</strong>.
                {lastRunHeadline && (
                  <><br /><strong>Why 0 sent:</strong> {lastRunHeadline}</>
                )}
              </p>
              <div class="panel__skip-grid">
                <div class="panel__skip">
                  <div class="panel__skip-label">Opted out of reviews</div>
                  <div class="panel__skip-value"><strong>{lastRun.skipped.optedOut}</strong></div>
                </div>
                <div class="panel__skip">
                  <div class="panel__skip-label">Already sent</div>
                  <div class="panel__skip-value"><strong>{lastRun.skipped.alreadySent}</strong></div>
                </div>
                <div class="panel__skip">
                  <div class="panel__skip-label">Recent (cooldown)</div>
                  <div class="panel__skip-value"><strong>{lastRun.skipped.recentRequest}</strong></div>
                </div>
                <div class="panel__skip">
                  <div class="panel__skip-label">Not yet ACCEPTED</div>
                  <div class="panel__skip-value"><strong>{lastRun.skipped.notAccepted}</strong></div>
                </div>
                <div class="panel__skip">
                  <div class="panel__skip-label">Customer/email missing</div>
                  <div class="panel__skip-value"><strong>{lastRun.skipped.customerMissing}</strong></div>
                </div>
                <div class="panel__skip">
                  <div class="panel__skip-label">Service/barber lookup</div>
                  <div class="panel__skip-value"><strong>{lastRun.skipped.serviceMissing + lastRun.skipped.barberMissing}</strong></div>
                </div>
                <div class="panel__skip">
                  <div class="panel__skip-label">Failures</div>
                  <div class="panel__skip-value"><strong>{lastRun.failures}</strong></div>
                </div>
              </div>
            </>
          )}
          <div class="panel__actions">
            <button type="button" class="btn" id="run-live-btn">Run now</button>
            <button type="button" class="btn btn--ghost" id="run-dry-btn">Run dry (no emails)</button>
          </div>
          <div class="run-progress" id="run-progress" hidden>
            <div class="run-progress__spinner" aria-hidden="true"></div>
            <div class="run-progress__text">
              <strong id="run-progress-headline">Running…</strong>
              <span id="run-progress-detail">This can take up to a minute. The page will refresh automatically when it finishes.</span>
            </div>
          </div>
          <pre class="panel__output" id="run-output" hidden></pre>
        </div>
      )}

      {!loadError && (
        <div class="panel">
          <h2 style="margin-top: 0;">Send a test email</h2>
          <p class="panel__lede">
            Send a real-looking review-request email to any inbox so you can
            preview what customers receive. The test send doesn't touch any
            customer record or dedupe state — it won't change tomorrow's cron
            behaviour.
          </p>
          <form id="test-form" class="test-form">
            <label class="test-form__field">
              <span>Send to</span>
              <input
                type="email"
                id="test-email"
                placeholder="you@example.com"
                autocomplete="email"
                required
              />
            </label>
            <label class="test-form__field">
              <span>Customer first name <em style="color: var(--dim); font-style: normal;">(optional)</em></span>
              <input
                type="text"
                id="test-name"
                placeholder="Bill"
                autocomplete="off"
              />
            </label>
            <button type="submit" class="btn btn--ghost" id="test-send-btn">
              Send test email
            </button>
          </form>
          <p class="status" id="test-status" hidden></p>
        </div>
      )}

      {!loadError && (
        <>
          <div class="stat-grid">
            <div class="stat-card">
              <div class="stat-eyebrow">Last 30 days</div>
              <p class="stat-headline">
                {last30?.sent ?? 0} sent · {last30?.clicked ?? 0} clicked
              </p>
              <p class="stat-detail">
                <strong>{fmtPct(last30?.clickRate ?? 0)}</strong> click-through rate
              </p>
            </div>
            <div class="stat-card">
              <div class="stat-eyebrow">Last 90 days</div>
              <p class="stat-headline">
                {last90?.sent ?? 0} sent · {last90?.clicked ?? 0} clicked
              </p>
              <p class="stat-detail">
                <strong>{fmtPct(last90?.clickRate ?? 0)}</strong> click-through rate
              </p>
            </div>
          </div>

          <h2>Recent review requests</h2>
          {recent.length === 0 && <p class="sub">No review requests sent yet.</p>}
          {recent.length > 0 && (
            <div class="table-scroll">
            <table>
              <thead>
                <tr>
                  <th>Sent</th>
                  <th>Customer</th>
                  <th>Service</th>
                  <th>Barber</th>
                  <th>Click</th>
                  <th>Booking</th>
                </tr>
              </thead>
              <tbody>
                {recent.map((r) => (
                  <tr>
                    <td>{fmtDate(r.sentAt)}</td>
                    <td class="meta">{r.customerEmailRedacted || '—'}</td>
                    <td>{r.serviceName || '—'}</td>
                    <td>{r.barberName || '—'}</td>
                    <td>
                      {r.clickedAt ? (
                        <span class="pill clicked">Clicked {fmtDate(r.clickedAt)}</span>
                      ) : (
                        <span class="pill unclicked">No click</span>
                      )}
                    </td>
                    <td class="meta">{r.bookingId}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            </div>
          )}
        </>
      )}
    </div>

    <script is:inline>
      (function () {
        const live = document.getElementById('run-live-btn');
        const dry = document.getElementById('run-dry-btn');
        const out = document.getElementById('run-output');
        const progress = document.getElementById('run-progress');
        const headline = document.getElementById('run-progress-headline');
        const detail = document.getElementById('run-progress-detail');
        if (!live || !dry || !out || !progress || !headline || !detail) return;

        function setProgress(state, head, msg, extraNode) {
          progress.hidden = false;
          progress.setAttribute('data-state', state);
          headline.textContent = head;
          // Replace any prior detail node (plain text or a node).
          detail.textContent = msg || '';
          if (extraNode) detail.appendChild(extraNode);
        }

        async function run(dryRun) {
          live.disabled = true;
          dry.disabled = true;
          out.hidden = true;
          out.textContent = '';
          setProgress(
            'running',
            dryRun ? 'Dry run in progress…' : 'Running review-request cron…',
            'This can take up to a minute. The page will refresh automatically when it finishes.',
          );

          try {
            // Live runs require BOTH dryRun:false AND confirmLive:true
            // server-side — see run-now.ts comment. Anything else
            // (including a body lost in transit on iOS Safari) defaults
            // to dry on the server. Send the explicit pair here.
            const payload = dryRun
              ? { dryRun: true }
              : { dryRun: false, confirmLive: true };
            const res = await fetch('/api/admin/reviews/run-now', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const body = await res.json();
            if (body && body.ok) {
              setProgress('done', 'Done. Reloading…', '');
              setTimeout(() => window.location.reload(), 700);
              return;
            }
            // Server returned a response but ok=false — show it so
            // the admin can read the error code/detail.
            setProgress(
              'error',
              dryRun ? 'Dry run finished with an error' : 'Run finished with an error',
              'See the response below.',
            );
            out.hidden = false;
            out.textContent = JSON.stringify(body, null, 2);
            live.disabled = false;
            dry.disabled = false;
          } catch (err) {
            // Most common cause: the fetch timed out client-side
            // (iOS Safari kills idle fetches around 30–60s) but the
            // Vercel function is still running in the background.
            // Auto-refresh in 60s to catch the result, but give the
            // admin a manual refresh button too.
            const refreshBtn = document.createElement('button');
            refreshBtn.type = 'button';
            refreshBtn.className = 'btn btn--ghost';
            refreshBtn.textContent = 'Refresh now';
            refreshBtn.style.fontSize = '0.78rem';
            refreshBtn.style.padding = '6px 12px';
            refreshBtn.addEventListener('click', () => window.location.reload());
            setProgress(
              'running',
              'Still running…',
              'Your browser lost patience but the cron likely kept running. Refreshing in 60 seconds to check the result. ',
              refreshBtn,
            );
            setTimeout(() => window.location.reload(), 60_000);
          }
        }

        live.addEventListener('click', () => {
          if (!confirm('Run the review-request cron now? Eligible customers will be emailed.')) return;
          run(false);
        });
        dry.addEventListener('click', () => run(true));
      })();

      // ---------- Test-email form ----------
      (function () {
        const form = document.getElementById('test-form');
        const input = document.getElementById('test-email');
        const nameInput = document.getElementById('test-name');
        const btn = document.getElementById('test-send-btn');
        const status = document.getElementById('test-status');
        if (!form || !input || !btn || !status) return;

        function showStatus(msg, kind) {
          status.textContent = msg || '';
          status.className = 'status' + (kind ? ' status--' + kind : '');
          status.hidden = !msg;
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const to = (input.value || '').trim();
          const customerName = nameInput ? (nameInput.value || '').trim() : '';
          if (!to) {
            showStatus('Enter an email address.', 'error');
            return;
          }
          btn.disabled = true;
          const originalLabel = btn.textContent;
          btn.textContent = 'Sending…';
          showStatus('');
          try {
            const res = await fetch('/api/admin/reviews/send-test', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ to, customerName }),
            });
            const data = await res.json();
            if (!res.ok || !data.ok) {
              showStatus(
                (data && data.error && data.error.detail) || 'Send failed.',
                'error',
              );
              btn.disabled = false;
              btn.textContent = originalLabel;
              return;
            }
            showStatus(
              'Sent! Check ' + to + ' (Resend id: ' + data.resendId + ').',
              'ok',
            );
            btn.disabled = false;
            btn.textContent = originalLabel;
          } catch {
            showStatus('Network error. Try again.', 'error');
            btn.disabled = false;
            btn.textContent = originalLabel;
          }
        });
      })();
    </script>
  </body>
</html>
