---
export const prerender = false;

import {
  findCustomerByEmail,
  findCustomersByName,
  findCustomersByPhone,
  getCustomerById,
} from '../../lib/square/customers';
import { getCustomerBookings, type CustomerBookings } from '../../lib/square/customerBookings';
import { getBarbers } from '../../lib/square/team';
import { getBookingCardRecords, type BookingCardRecord } from '../../lib/booking/cardIndex';
import { checkBasicAuth } from '../../lib/admin/auth';
import { SquareApiError } from '../../lib/square/client';
import {
  getLinkedParent,
  listLinkedPeople,
  type LinkedPerson,
} from '../../lib/customer/profileLinks';
import type { Customer } from '../../lib/square/types';

const auth = checkBasicAuth(Astro.request);
if (!auth.ok) {
  return auth.challenge;
}

const url = new URL(Astro.request.url);
const rawQuery = (url.searchParams.get('q') ?? '').trim();
const focusId = (url.searchParams.get('id') ?? '').trim();

function looksLikeEmail(s: string): boolean {
  return /^\S+@\S+\.\S+$/.test(s.trim());
}
function looksLikePhone(s: string): boolean {
  const d = s.replace(/[^0-9]/g, '');
  return d.length >= 7 && d.length <= 16;
}
function looksLikeName(s: string): boolean {
  // After ruling out email + phone, treat any query with at least
  // 2 alphabetic chars as a name. Allows hyphens/apostrophes for
  // names like O'Brien or Smith-Jones. Single letters won't trigger.
  return /^[A-Za-z][A-Za-z\s'\-.]{1,}$/.test(s.trim());
}

let customer: Customer | null = null;
let searchError: string | null = null;
let notFound = false;
let lookupMethod: 'email' | 'phone' | 'name' | null = null;
let bookings: CustomerBookings | null = null;
let bookingsError: string | null = null;
// When the focused customer is linked as someone's kid, the parent's
// customer record so we can render "Linked as a kid of <Name>" with
// an unlink button. null when there's no link.
let linkedParent: Customer | null = null;
// Reverse direction: when the focused customer is themselves a
// parent, the kids/dependents linked under them. Empty array when
// they're not parenting anyone. Diagnostic for "I linked them but
// they're not showing up" — operator can scan this list and verify
// the link wrote correctly.
let linkedKids: LinkedPerson[] = [];
// Square customer records for each linked kid, fetched in parallel
// with everything else. Used to render email + created-date under
// each kid's name so the operator can tell two same-name kids
// apart — without this, "Briar Bone" and "Briar Bone" look
// identical in the list even though one's the wife and one's the
// daughter. Keyed by customerId; missing entries (the record was
// deleted or Square errored) leave the row with name-only.
const linkedKidsById: Map<string, Customer> = new Map();
let cardRecords = new Map<string, BookingCardRecord>();
let barbers: Array<{ id: string; displayName: string }> = [];
// When a phone lookup hits multiple records (test accounts, pre-dedup
// duplicates), we render a chooser so the operator can see all of them
// at once. The single-record path stays the dominant case.
let phoneMatches: Customer[] = [];

// For each multi-match result, the parent's name + email when that
// record is linked as a kid in our profile-links graph. Lets the
// chooser surface "Linked to Bill Chicha (bilsonxnc@gmail.com)" as
// a sub-line under each name — critical when two records share a
// first+last (e.g. two "Briar Bone" entries) and you need to know
// at a glance which parent each one belongs to.
interface ParentTag {
  name: string;
  email: string | null;
}
const searchResultParents: Map<string, ParentTag> = new Map();

if (focusId) {
  // ?id=... is the direct-fetch path, set when the operator clicks
  // "Manage" from the multi-match list. Skip search entirely.
  try {
    customer = await getCustomerById(focusId);
    if (!customer) notFound = true;
  } catch (err) {
    if (err instanceof SquareApiError) {
      searchError = `${err.code}: ${err.detail}`;
    } else {
      searchError = err instanceof Error ? err.message : 'Lookup failed.';
    }
  }
} else if (rawQuery) {
  const isEmail = looksLikeEmail(rawQuery);
  const isPhone = !isEmail && looksLikePhone(rawQuery);
  const isName = !isEmail && !isPhone && looksLikeName(rawQuery);
  try {
    if (isEmail) {
      customer = await findCustomerByEmail(rawQuery);
      lookupMethod = 'email';
    } else if (isPhone) {
      const matches = await findCustomersByPhone(rawQuery);
      lookupMethod = 'phone';
      if (matches.length > 1) {
        phoneMatches = matches;
      } else if (matches.length === 1) {
        customer = matches[0];
      }
    } else if (isName) {
      // Name search reuses the same chooser UI as the phone path —
      // any multi-match surfaces a list of records the operator
      // can pick from. Single-result lands on the edit form.
      const matches = await findCustomersByName(rawQuery);
      lookupMethod = 'name';
      if (matches.length > 1) {
        phoneMatches = matches;
      } else if (matches.length === 1) {
        customer = matches[0];
      }
    } else {
      searchError = "That doesn't look like an email, phone number, or name.";
    }
    if (!searchError && !customer && phoneMatches.length === 0) notFound = true;
  } catch (err) {
    if (err instanceof SquareApiError) {
      searchError = `${err.code}: ${err.detail}`;
    } else {
      searchError = err instanceof Error ? err.message : 'Lookup failed.';
    }
  }
}

// Hydrate parent tags for the multi-match chooser so each result row
// can show who it's linked to. Per-row failures are swallowed — a
// missing tag just leaves the row without the "Linked to" sub-line.
if (phoneMatches.length > 1) {
  const parentIds = await Promise.all(
    phoneMatches.map((c) =>
      getLinkedParent(c.id)
        .then((pid) => ({ kidId: c.id, parentId: pid }))
        .catch(() => ({ kidId: c.id, parentId: null })),
    ),
  );
  const uniqueParentIds = [
    ...new Set(parentIds.map((p) => p.parentId).filter((id): id is string => !!id)),
  ];
  const parentRecords = await Promise.all(
    uniqueParentIds.map((pid) =>
      getCustomerById(pid)
        .then((rec) => ({ id: pid, rec }))
        .catch(() => ({ id: pid, rec: null as Customer | null })),
    ),
  );
  const parentById = new Map<string, Customer>();
  for (const { id, rec } of parentRecords) {
    if (rec) parentById.set(id, rec);
  }
  for (const { kidId, parentId } of parentIds) {
    if (!parentId) continue;
    const rec = parentById.get(parentId);
    if (!rec) continue;
    const name =
      `${rec.given_name ?? ''} ${rec.family_name ?? ''}`.trim() || '(no name)';
    searchResultParents.set(kidId, {
      name,
      email: rec.email_address?.trim() || null,
    });
  }
}

// Once we have a customer, hydrate everything needed to render the
// bookings panel: their bookings (upcoming + past), the barbers list
// for the reschedule barber picker, and the card-on-file index for the
// no-show charge action. Fetch in parallel and degrade gracefully on
// failure — the customer card itself stays useful even if Square's
// bookings endpoint is having a bad minute.
if (customer) {
  const customerId = customer.id;
  // Look up the parent link in parallel with bookings/barbers so the
  // Family-link row can render without an extra render cycle. Failure
  // is non-fatal — the row just shows "— none —".
  const [bookingsResult, barbersResult, parentIdResult, kidsResult] = await Promise.allSettled([
    getCustomerBookings(customerId),
    getBarbers(),
    getLinkedParent(customerId),
    listLinkedPeople(customerId),
  ]);
  if (kidsResult.status === 'fulfilled') {
    linkedKids = kidsResult.value;
    // Hydrate each kid's Square record so the list can render
    // email + created-date disambiguators. Parallel fetch with
    // graceful per-kid degradation — a deleted/missing kid just
    // shows name-only.
    if (linkedKids.length > 0) {
      const records = await Promise.all(
        linkedKids.map((kid) =>
          getCustomerById(kid.customerId).catch(() => null),
        ),
      );
      for (const rec of records) {
        if (rec) linkedKidsById.set(rec.id, rec);
      }
    }
  }
  if (parentIdResult.status === 'fulfilled' && parentIdResult.value) {
    try {
      linkedParent = await getCustomerById(parentIdResult.value);
    } catch {
      // If the parent record is gone, fall back to null — the Family
      // link row will still show "linked to (deleted)" semantics.
      linkedParent = null;
    }
  }
  if (bookingsResult.status === 'fulfilled') {
    bookings = bookingsResult.value;
    try {
      const allIds = [
        ...bookings.upcoming.map((b) => b.id),
        ...bookings.past.map((b) => b.id),
      ];
      if (allIds.length > 0) {
        cardRecords = await getBookingCardRecords(allIds);
      }
    } catch {
      // KV hiccup — the no-show charge button just won't render.
      cardRecords = new Map();
    }
  } else {
    const err = bookingsResult.reason;
    if (err instanceof SquareApiError) {
      bookingsError = `${err.code}: ${err.detail}`;
    } else {
      bookingsError = err instanceof Error ? err.message : 'Could not load bookings.';
    }
  }
  if (barbersResult.status === 'fulfilled') {
    barbers = barbersResult.value.map((b) => ({ id: b.id, displayName: b.displayName }));
  }
}

function fmtPhone(raw: string): string {
  const d = raw.replace(/[^0-9]/g, '');
  if (d.length === 11 && d.startsWith('1')) {
    return `(${d.slice(1, 4)}) ${d.slice(4, 7)}-${d.slice(7)}`;
  }
  if (d.length === 10) {
    return `(${d.slice(0, 3)}) ${d.slice(3, 6)}-${d.slice(6)}`;
  }
  return raw;
}

function fmtTimestamp(iso: string | undefined): string {
  if (!iso) return '—';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  return new Intl.DateTimeFormat('en-US', {
    timeZone: 'America/New_York',
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(d);
}

function statusPillClass(status: string): string {
  if (status === 'ACCEPTED') return 'ok';
  if (status === 'PENDING') return 'pending';
  return 'cancelled';
}

function describeChargeStatus(record: BookingCardRecord | undefined): string {
  if (!record) return '';
  if (record.chargeStatus === 'pending') return 'Card on file';
  if (record.chargeStatus === 'late-cancel')
    return `Late-cancel charged $${(record.servicePriceCents / 100).toFixed(2)}`;
  if (record.chargeStatus === 'no-show')
    return `No-show charged $${(record.servicePriceCents / 100).toFixed(2)}`;
  if (record.chargeStatus === 'failed')
    return `Charge failed — ${record.chargeFailureReason ?? 'unknown'}`;
  return '';
}

function canChargeNoShow(startAtUtc: string, record: BookingCardRecord | undefined): boolean {
  if (!record) return false;
  if (record.chargeStatus !== 'pending' && record.chargeStatus !== 'failed') return false;
  return new Date(startAtUtc).getTime() < Date.now();
}

// Default value for the "new date" picker — tomorrow in NY time, in
// YYYY-MM-DD form ready for an <input type="date">.
function tomorrowInNyDate(): string {
  const now = new Date(Date.now() + 24 * 60 * 60 * 1000);
  const parts = new Intl.DateTimeFormat('en-CA', {
    timeZone: 'America/New_York',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).formatToParts(now);
  const get = (type: string) => parts.find((p) => p.type === type)?.value ?? '';
  return `${get('year')}-${get('month')}-${get('day')}`;
}
const defaultRescheduleDate = tomorrowInNyDate();
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Customers — Modern Classic Admin</title>
    <style>
      :root {
        --bg: #0b0a08;
        --surface: #161311;
        --surface-2: #1d1916;
        --border: #2a2520;
        --text: #f3ece0;
        --muted: #b0a695;
        --dim: #80776a;
        --gold: #c9a35c;
        --gold-light: #e6c785;
        --danger: #d88a8a;
      }
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font: 16px/1.5 ui-sans-serif, system-ui, sans-serif;
      }
      .wrap { max-width: 56rem; margin: 0 auto; padding: 32px 24px; }
      h1 { font-family: Georgia, serif; font-weight: 400; font-size: 1.8rem; margin: 0 0 6px; }
      .sub { color: var(--muted); font-size: 0.95rem; margin-bottom: 24px; }
      .topnav {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        align-items: center;
        padding-bottom: 18px;
        margin-bottom: 24px;
        border-bottom: 1px solid var(--border);
        font-size: 0.78rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .topnav a { color: var(--muted); text-decoration: none; padding-bottom: 4px; }
      .topnav a.active { color: var(--gold); border-bottom: 2px solid var(--gold); }
      .topnav a:hover { color: var(--gold); }
      .err {
        background: rgba(220, 80, 60, 0.08);
        border: 1px solid rgba(220, 80, 60, 0.4);
        color: #f0a37a;
        padding: 12px 16px;
        border-radius: 6px;
        margin-bottom: 18px;
      }
      .info {
        background: rgba(201, 163, 92, 0.06);
        border: 1px solid rgba(201, 163, 92, 0.3);
        color: var(--muted);
        padding: 12px 16px;
        border-radius: 6px;
        margin-bottom: 18px;
      }

      form.search {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
        margin-bottom: 8px;
      }
      input[type='text'], input[type='email'], input[type='tel'] {
        width: 100%;
        padding: 10px 12px;
        background: var(--surface-2);
        border: 1px solid var(--border);
        color: var(--text);
        border-radius: 6px;
        font-size: 1rem;
        font-family: inherit;
      }
      input:focus {
        outline: 2px solid rgba(201, 163, 92, 0.4);
        outline-offset: 1px;
        border-color: var(--gold);
      }
      button {
        padding: 10px 18px;
        background: var(--gold);
        color: var(--bg);
        font-weight: 700;
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        border: 0;
        border-radius: 4px;
        cursor: pointer;
        font-family: inherit;
      }
      button:hover { background: var(--gold-light); }
      button[disabled] { opacity: 0.55; cursor: not-allowed; }
      button.ghost {
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--border);
      }
      button.ghost:hover { border-color: var(--gold); color: var(--text); }
      .helper { color: var(--dim); font-size: 0.85rem; margin: 4px 0 24px; }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 22px 24px;
        margin-top: 18px;
      }
      .card h2 {
        font-family: Georgia, serif;
        font-weight: 400;
        font-size: 1.3rem;
        margin: 0 0 4px;
      }
      .card .meta {
        color: var(--dim);
        font-size: 0.82rem;
        font-family: ui-monospace, Menlo, monospace;
        margin-bottom: 18px;
        word-break: break-all;
      }
      .grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      @media (max-width: 540px) { .grid2 { grid-template-columns: 1fr; } }
      label {
        display: block;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 4px;
      }
      .row + .row { margin-top: 14px; }
      .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 22px;
        padding-top: 18px;
        border-top: 1px solid var(--border);
      }
      .status {
        margin-top: 12px;
        font-size: 0.9rem;
      }
      .status.ok { color: #a4d091; }
      .status.error { color: var(--danger); }
      .status[hidden] { display: none; }
      .original {
        display: block;
        font-size: 0.78rem;
        color: var(--dim);
        margin-top: 4px;
      }
      .empty {
        margin-top: 14px;
        padding: 18px 20px;
        background: var(--surface);
        border: 1px dashed var(--border);
        border-radius: 8px;
        color: var(--muted);
      }

      h3 {
        font-family: Georgia, serif;
        font-weight: 400;
        font-size: 1.1rem;
        margin: 28px 0 12px;
      }
      /* Tables sit in a horizontal-scroll wrapper so a phone-narrow
         viewport doesn't squeeze cell contents one character per line.
         Cards keep their normal layout; only the table scrolls. */
      .bookings-wrap {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        max-width: 100%;
        margin: 0 0 6px;
      }
      table.bookings { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
      table.bookings th, table.bookings td {
        padding: 9px 10px;
        text-align: left;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }
      /* Keep date/time strings and action buttons on a single line so
         "Friday, June 26, 2026 at 12:00 PM" doesn't break into seven
         vertical fragments on mobile. The horizontal scroll wrapper
         catches the overflow. */
      table.bookings td:first-child,
      table.bookings td .table-actions {
        white-space: nowrap;
      }
      /* Multi-line sub-content (parent tag, group badge, free-text
         notes) inside a nowrap first cell must opt back into wrapping
         or it'll render in a single overflow line. */
      table.bookings td:first-child .meta--tag,
      table.bookings td:first-child .group-badge {
        white-space: normal;
      }
      table.bookings th {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--surface);
      }
      .pill {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        white-space: nowrap;
      }
      .pill.ok { background: rgba(122, 184, 110, 0.15); color: #a4d091; }
      .pill.pending { background: rgba(201, 163, 92, 0.15); color: var(--gold); }
      .pill.cancelled { background: rgba(220, 80, 60, 0.15); color: #f0a37a; }
      .row-actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }
      .row-actions button {
        padding: 6px 10px;
        font-size: 0.72rem;
        letter-spacing: 0.06em;
        background: transparent;
        color: var(--gold);
        border: 1px solid var(--gold);
      }
      .row-actions button:hover:not(:disabled) {
        background: var(--gold);
        color: var(--bg);
      }
      .row-actions button.danger {
        color: #f0a37a;
        border-color: rgba(220, 80, 60, 0.6);
      }
      .row-actions button.danger:hover:not(:disabled) {
        background: rgba(220, 80, 60, 0.6);
        color: var(--bg);
      }
      .row-status {
        margin-top: 6px;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .row-status.error { color: var(--danger); }
      .row-status.ok { color: #a4d091; }
      .row-status[hidden] { display: none; }
      .charge-tag {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 2px 8px;
        border-radius: 999px;
      }
      .charge-tag--none { color: var(--dim); }
      .charge-tag--pending { background: rgba(201, 163, 92, 0.15); color: var(--gold); }
      .charge-tag--late-cancel,
      .charge-tag--no-show { background: rgba(122, 184, 110, 0.15); color: #a4d091; }
      .charge-tag--failed { background: rgba(220, 80, 60, 0.15); color: #f0a37a; }

      .group-badge {
        display: inline-block;
        margin-left: 6px;
        padding: 1px 7px;
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: var(--gold);
        background: rgba(201, 163, 92, 0.1);
        border: 1px solid rgba(201, 163, 92, 0.45);
        border-radius: 999px;
        white-space: nowrap;
      }

      .resched-row {
        background: var(--surface-2);
      }
      .resched-row[hidden] { display: none; }
      .resched-form {
        display: grid;
        gap: 10px;
        padding: 14px 4px;
      }
      .resched-form .grid {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 8px;
        align-items: end;
      }
      @media (max-width: 600px) { .resched-form .grid { grid-template-columns: 1fr; } }
      .resched-form input[type='date'],
      .resched-form select {
        width: 100%;
        padding: 8px 10px;
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--text);
        border-radius: 6px;
        font: inherit;
      }
      .slot-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        max-height: 200px;
        overflow-y: auto;
      }
      .slot-list[hidden] { display: none; }
      .slot-list button {
        padding: 6px 10px;
        font-size: 0.78rem;
        background: transparent;
        color: var(--text);
        border: 1px solid var(--border);
      }
      .slot-list button:hover:not(:disabled) {
        border-color: var(--gold);
        color: var(--gold);
      }
      .slot-list button.selected {
        background: var(--gold);
        color: var(--bg);
        border-color: var(--gold);
      }
      .resched-confirm-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
      }
      .resched-confirm-row .picked {
        color: var(--muted);
        font-size: 0.85rem;
      }

      .family-link {
        margin-top: 32px;
        padding: 18px 20px;
        border: 1px solid rgba(201, 163, 92, 0.4);
        background: rgba(201, 163, 92, 0.05);
        border-radius: 8px;
        display: grid;
        gap: 0.75rem;
      }
      .family-link h3 {
        margin: 0;
        color: #c9a35c;
        font-family: Georgia, serif;
        font-weight: 400;
        font-size: 1rem;
      }
      .family-link .helper { margin: 0; }
      .family-link__form {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.5rem;
      }
      .family-link__form input[type='tel'] {
        padding: 0.55rem 0.75rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: inherit;
        border-radius: 4px;
        font: inherit;
        font-size: 0.95rem;
      }
      .primary-btn,
      .ghost-btn {
        padding: 0.55rem 1rem;
        font-weight: 700;
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        border-radius: 4px;
        cursor: pointer;
        font-family: inherit;
      }
      .primary-btn {
        background: #c9a35c;
        color: #1c1814;
        border: 0;
      }
      .primary-btn:hover:not(:disabled) { background: #d4af6e; }
      .primary-btn:disabled { opacity: 0.55; cursor: not-allowed; }
      .ghost-btn {
        background: transparent;
        color: #c9a35c;
        border: 1px solid rgba(201, 163, 92, 0.5);
        justify-self: start;
      }
      .ghost-btn:hover:not(:disabled) {
        background: rgba(201, 163, 92, 0.12);
        border-color: #c9a35c;
      }
      .ghost-btn:disabled { opacity: 0.55; cursor: not-allowed; }

      .family-link__kids {
        margin-top: 0.85rem;
        padding-top: 0.85rem;
        border-top: 1px solid rgba(201, 163, 92, 0.22);
        display: grid;
        gap: 0.55rem;
      }
      .family-link__kids h4 {
        margin: 0;
        font-family: Georgia, serif;
        font-weight: 400;
        font-size: 0.92rem;
        color: #c9a35c;
      }
      .helper.helper--dim { opacity: 0.75; }
      .family-link__kids-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.4rem;
      }
      .family-link__kids-list li {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 4px;
      }
      .family-link__kid-info {
        display: grid;
        gap: 0.15rem;
        min-width: 0;
      }
      .family-link__kid-name {
        font-size: 0.95rem;
      }
      .family-link__kid-sub {
        font-size: 0.78rem;
        color: var(--muted, #b0a695);
        font-family: ui-monospace, Menlo, monospace;
        word-break: break-all;
      }
      .family-link__kid-noemail {
        font-style: italic;
        color: var(--dim, #80776a);
      }
      .family-link__kid-missing {
        color: #f0a37a;
      }
      .family-link__kid-link {
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #c9a35c;
        text-decoration: none;
      }
      .family-link__kid-link:hover { text-decoration: underline; }

      .danger-zone {
        margin-top: 32px;
        padding: 18px 20px;
        border: 1px solid rgba(220, 80, 60, 0.4);
        background: rgba(220, 80, 60, 0.04);
        border-radius: 8px;
      }
      .danger-zone h3 {
        margin: 0 0 8px;
        color: #f0a37a;
        font-family: Georgia, serif;
        font-weight: 400;
        font-size: 1rem;
      }
      .danger-btn {
        margin-top: 8px;
        padding: 9px 16px;
        background: transparent;
        color: #f0a37a;
        border: 1px solid rgba(220, 80, 60, 0.6);
        font-weight: 700;
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        border-radius: 4px;
        cursor: pointer;
        font-family: inherit;
      }
      .danger-btn:hover:not(:disabled) {
        background: rgba(220, 80, 60, 0.6);
        color: var(--bg);
      }
      .danger-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <nav class="topnav">
        <a href="/admin">Admin</a>
        <a href="/admin/today">Today</a>
        <a href="/admin/bookings">Bookings</a>
        <a href="/admin/customers" class="active">Customers</a>
        <a href="/admin/waitlist">Waitlist</a>
        <a href="/admin/reviews">Reviews</a>
      </nav>

      <h1>Customer lookup &amp; edit</h1>
      <p class="sub">
        Search by email or phone. Use this to add a missing email so a phone-only
        customer can sign in to <code>/my-bookings</code>.
      </p>

      <form class="search" method="get" action="/admin/customers">
        <input
          type="text"
          name="q"
          value={rawQuery}
          placeholder="Email, phone, or name — e.g. jane@example.com / (740) 555-0123 / Briar"
          autocapitalize="none"
          spellcheck="false"
          autocomplete="off"
        />
        <button type="submit">Search</button>
      </form>
      <p class="helper">Lookup is exact then fuzzy on Square. Phone digits only matter (formatting ignored). Name search is fuzzy — type "Briar" or "Briar Chicha" to see every match.</p>

      {searchError && <p class="err">Search failed: {searchError}</p>}

      {notFound && (
        <p class="empty">
          No customer found for <strong>{rawQuery || focusId}</strong>. Try the other field — e.g.
          if you searched the email and it's not in Square, search the phone instead.
        </p>
      )}

      {phoneMatches.length > 1 && (
        <div class="card">
          <h2>{phoneMatches.length} customers matched</h2>
          <p class="sub">
            <strong>{rawQuery}</strong> matches multiple records. Pick one to manage.
            If they're duplicates, manage one to update or delete the other.
          </p>
          <div class="bookings-wrap">
          <table class="bookings">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Created</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {phoneMatches.map((c) => {
                const parentTag = searchResultParents.get(c.id);
                return (
                  <tr>
                    <td>
                      {`${c.given_name ?? ''} ${c.family_name ?? ''}`.trim() || '(no name)'}
                      {parentTag && (
                        <div class="meta meta--tag">
                          Linked to <strong>{parentTag.name}</strong>
                          {parentTag.email && ` (${parentTag.email})`}
                        </div>
                      )}
                    </td>
                    <td>{c.email_address || <span class="meta">— no email —</span>}</td>
                    <td>{fmtTimestamp(c.created_at)}</td>
                    <td>
                      <a href={`/admin/customers?q=${encodeURIComponent(rawQuery)}&id=${encodeURIComponent(c.id)}`}>
                        Manage →
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
          </div>
        </div>
      )}

      {customer && (
        <div class="card">
          <h2>{`${customer.given_name ?? ''} ${customer.family_name ?? ''}`.trim() || '(no name on file)'}</h2>
          <p class="meta">
            {customer.id} · matched by {lookupMethod}
            {customer.created_at && ` · created ${fmtTimestamp(customer.created_at)}`}
          </p>

          <form id="edit-form" data-customer-id={customer.id}>
            <div class="grid2">
              <div class="row">
                <label for="givenName">First name</label>
                <input
                  type="text"
                  id="givenName"
                  name="givenName"
                  value={customer.given_name ?? ''}
                  data-original={customer.given_name ?? ''}
                />
              </div>
              <div class="row">
                <label for="familyName">Last name</label>
                <input
                  type="text"
                  id="familyName"
                  name="familyName"
                  value={customer.family_name ?? ''}
                  data-original={customer.family_name ?? ''}
                />
              </div>
            </div>

            <div class="row">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                value={customer.email_address ?? ''}
                data-original={customer.email_address ?? ''}
                autocapitalize="none"
                spellcheck="false"
              />
              {!customer.email_address && (
                <span class="original">⚠ No email on file — they can't sign in until you add one.</span>
              )}
            </div>

            <div class="row">
              <label for="phone">Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                value={customer.phone_number ? fmtPhone(customer.phone_number) : ''}
                data-original={customer.phone_number ?? ''}
              />
            </div>

            <div class="actions">
              <button type="submit">Save changes</button>
              <button type="button" class="ghost" data-reset>Reset</button>
            </div>
            <p class="status" id="edit-status" hidden></p>
          </form>

          {bookingsError && <p class="err" style="margin-top: 22px">Failed to load bookings: {bookingsError}</p>}

          {bookings && (
            <>
              <h3>Upcoming bookings ({bookings.upcoming.length})</h3>
              {bookings.upcoming.length === 0 ? (
                <p class="empty">No upcoming bookings.</p>
              ) : (
                <div class="bookings-wrap">
                <table class="bookings">
                  <thead>
                    <tr>
                      <th>When</th>
                      <th>Service</th>
                      <th>Barber</th>
                      <th>Card</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {bookings.upcoming.flatMap((b) => {
                      const record = cardRecords.get(b.id);
                      const chargeLabel = describeChargeStatus(record);
                      return [
                        <tr data-booking-id={b.id} data-booking-version={b.version} data-service-id={b.serviceVariationId} data-service-version={b.serviceVariationVersion} data-duration={b.durationMinutes} data-barber-id={b.barberId}>
                          <td>{b.startAtLocal}</td>
                          <td>
                            {b.serviceName} <span class="meta">· {b.priceDisplay}</span>
                            {b.groupId && (
                              <span class="group-badge" title={b.groupId}>
                                Group {b.groupPosition}/{b.groupTotal}
                                {b.groupMode === 'back-to-back' ? ' · back-to-back' : ' · all-at-once'}
                              </span>
                            )}
                          </td>
                          <td>{b.barberName}</td>
                          <td>
                            {chargeLabel ? (
                              <span class={`charge-tag charge-tag--${record?.chargeStatus ?? 'none'}`}>{chargeLabel}</span>
                            ) : (
                              <span class="charge-tag charge-tag--none">—</span>
                            )}
                          </td>
                          <td>
                            <div class="row-actions">
                              <button type="button" data-action="reschedule" data-booking-id={b.id}>Reschedule</button>
                              <button type="button" class="danger" data-action="cancel" data-booking-id={b.id}>Cancel</button>
                            </div>
                            <p class="row-status" data-status-for={b.id} hidden></p>
                          </td>
                        </tr>,
                        <tr class="resched-row" data-resched-for={b.id} hidden>
                          <td colspan="5">
                            <form class="resched-form" data-resched-form-for={b.id}>
                              <div class="grid">
                                <div>
                                  <label>New date</label>
                                  <input type="date" name="date" value={defaultRescheduleDate} required />
                                </div>
                                <div>
                                  <label>Barber</label>
                                  <select name="teamMemberId">
                                    {barbers.map((br) => (
                                      <option value={br.id} selected={br.id === b.barberId}>{br.displayName}</option>
                                    ))}
                                  </select>
                                </div>
                                <button type="button" data-load-slots>Load times</button>
                              </div>
                              <div class="slot-list" data-slot-list hidden></div>
                              <div class="resched-confirm-row">
                                <span class="picked" data-picked-label></span>
                                <button type="submit" disabled>Confirm reschedule</button>
                                <button type="button" class="ghost" data-cancel-resched>Close</button>
                              </div>
                            </form>
                          </td>
                        </tr>,
                      ];
                    })}
                  </tbody>
                </table>
                </div>
              )}

              <h3>Past bookings ({bookings.past.length})</h3>
              {bookings.past.length === 0 ? (
                <p class="empty">No past bookings on file (last 6 months).</p>
              ) : (
                <div class="bookings-wrap">
                <table class="bookings">
                  <thead>
                    <tr>
                      <th>When</th>
                      <th>Status</th>
                      <th>Service</th>
                      <th>Barber</th>
                      <th>Card / charge</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {bookings.past.map((b) => {
                      const record = cardRecords.get(b.id);
                      const chargeLabel = describeChargeStatus(record);
                      const canCharge = canChargeNoShow(b.startAtUtc, record);
                      return (
                        <tr data-booking-id={b.id}>
                          <td>{b.startAtLocal}</td>
                          <td><span class={`pill ${statusPillClass(b.status)}`}>{b.status.replace(/_/g, ' ')}</span></td>
                          <td>
                            {b.serviceName}
                            {b.groupId && (
                              <span class="group-badge" title={b.groupId}>
                                Group {b.groupPosition}/{b.groupTotal}
                              </span>
                            )}
                          </td>
                          <td>{b.barberName}</td>
                          <td>
                            {chargeLabel ? (
                              <span class={`charge-tag charge-tag--${record?.chargeStatus ?? 'none'}`}>{chargeLabel}</span>
                            ) : (
                              <span class="charge-tag charge-tag--none">—</span>
                            )}
                          </td>
                          <td>
                            {canCharge ? (
                              <div class="row-actions">
                                <button
                                  type="button"
                                  data-action="no-show-charge"
                                  data-booking-id={b.id}
                                  data-amount-cents={record!.servicePriceCents}
                                >
                                  Mark no-show &amp; charge ${(record!.servicePriceCents / 100).toFixed(2)}
                                </button>
                              </div>
                            ) : (
                              <span class="meta">—</span>
                            )}
                            <p class="row-status" data-status-for={b.id} hidden></p>
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
                </div>
              )}

              <div class="family-link" data-customer-id={customer.id}>
                <h3>Family link</h3>
                {linkedParent ? (
                  <>
                    <p class="helper">
                      Linked as a kid of <strong>{`${linkedParent.given_name ?? ''} ${linkedParent.family_name ?? ''}`.trim() || 'Customer'}</strong>
                      {linkedParent.email_address?.trim() && (
                        <> (<code>{linkedParent.email_address.trim()}</code>)</>
                      )}
                      {linkedParent.created_at && (
                        <span class="meta"> · created {fmtTimestamp(linkedParent.created_at)}</span>
                      )}.
                      {' '}
                      Their <code>/my-bookings</code> view will pull this customer's appointments
                      into the merged list and group banner.
                    </p>
                    <button type="button" class="ghost-btn" data-unlink-person>
                      Unlink from parent
                    </button>
                  </>
                ) : (
                  <>
                    <p class="helper">
                      Not currently linked. Enter the parent's <strong>email</strong> to link
                      this customer as their kid — the parent will start seeing this
                      customer's appointments on <code>/my-bookings</code>. Email rather than
                      phone because parent and kid usually share a phone, which would be
                      ambiguous.
                    </p>
                    <div class="family-link__form">
                      <input
                        type="email"
                        id="family-link-email"
                        placeholder="parent@example.com"
                        autocomplete="off"
                        autocapitalize="none"
                        spellcheck="false"
                      />
                      <button type="button" class="primary-btn" data-link-person>
                        Link
                      </button>
                    </div>
                  </>
                )}
                <p class="row-status" id="family-link-status" hidden></p>

                <div class="family-link__kids">
                  <h4>
                    Linked kids ({linkedKids.length})
                  </h4>
                  {linkedKids.length === 0 ? (
                    <p class="helper helper--dim">
                      No kids linked to this customer. (Use the form on a kid's
                      record to link them <em>to</em> this customer as their parent.)
                    </p>
                  ) : (
                    <ul class="family-link__kids-list">
                      {linkedKids.map((kid) => {
                        const rec = linkedKidsById.get(kid.customerId);
                        const email = rec?.email_address?.trim();
                        const createdLabel = fmtTimestamp(rec?.created_at);
                        return (
                        <li>
                          <div class="family-link__kid-info">
                            <span class="family-link__kid-name">
                              {kid.displayName}
                              {kid.relationship ? <span class="meta"> · {kid.relationship}</span> : null}
                            </span>
                            <span class="family-link__kid-sub">
                              {email ? email : <span class="family-link__kid-noemail">— no email —</span>}
                              {rec?.created_at && <> · created {createdLabel}</>}
                              {!rec && <> · <span class="family-link__kid-missing">record deleted from Square</span></>}
                            </span>
                          </div>
                          <a
                            href={`/admin/customers?id=${encodeURIComponent(kid.customerId)}`}
                            class="family-link__kid-link"
                          >
                            Manage →
                          </a>
                        </li>
                        );
                      })}
                    </ul>
                  )}
                </div>
              </div>

              <div class="danger-zone">
                <h3>Danger zone</h3>
                {bookings.upcoming.length + bookings.past.length > 0 ? (
                  <p class="helper">
                    Delete is disabled — this customer has {bookings.upcoming.length} upcoming
                    and {bookings.past.length} past booking(s) on file. Cancel any upcoming
                    bookings first, then we still keep the record for audit history.
                  </p>
                ) : (
                  <>
                    <p class="helper">
                      No bookings on file. You can hard-delete this Square record. There is
                      no undo — the record is gone from Square.
                    </p>
                    <button
                      type="button"
                      class="danger-btn"
                      data-delete-customer
                      data-customer-id={customer.id}
                    >
                      Delete this customer
                    </button>
                    <p class="row-status" id="delete-status" hidden></p>
                  </>
                )}
              </div>
            </>
          )}
        </div>
      )}

      {!customer && !notFound && !rawQuery && (
        <p class="empty">
          Enter an email or phone above. Useful for fixing sign-in issues — phone-only
          customers (booked at the chair, no email) can't access /my-bookings until
          you add an email here.
        </p>
      )}
    </div>

    <script is:inline>
      (function () {
        const form = document.getElementById('edit-form');
        if (!form) return;
        const status = document.getElementById('edit-status');
        const submitBtn = form.querySelector('button[type="submit"]');
        const resetBtn = form.querySelector('[data-reset]');

        const showStatus = (msg, kind) => {
          status.textContent = msg;
          status.className = 'status ' + kind;
          status.hidden = false;
        };
        const hideStatus = () => {
          status.hidden = true;
        };

        if (resetBtn) {
          resetBtn.addEventListener('click', () => {
            form.querySelectorAll('input').forEach((input) => {
              const original = input.dataset.original ?? '';
              if (input.name === 'phone' && original) {
                // Re-format phone like the server-rendered initial value
                const d = original.replace(/[^0-9]/g, '');
                if (d.length === 11 && d.startsWith('1')) {
                  input.value = '(' + d.slice(1, 4) + ') ' + d.slice(4, 7) + '-' + d.slice(7);
                } else if (d.length === 10) {
                  input.value = '(' + d.slice(0, 3) + ') ' + d.slice(3, 6) + '-' + d.slice(6);
                } else {
                  input.value = original;
                }
              } else {
                input.value = original;
              }
            });
            hideStatus();
          });
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          hideStatus();
          submitBtn.disabled = true;
          submitBtn.textContent = 'Saving…';
          const customerId = form.dataset.customerId;
          const payload = {
            customerId,
            givenName: form.givenName.value.trim(),
            familyName: form.familyName.value.trim(),
            email: form.email.value.trim(),
            phone: form.phone.value.trim(),
          };
          try {
            const res = await fetch('/api/admin/update-customer', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const data = await res.json();
            if (!res.ok || !data.ok) {
              showStatus(data?.error?.detail || 'Update failed.', 'error');
              submitBtn.disabled = false;
              submitBtn.textContent = 'Save changes';
              return;
            }
            if (data.changed === false) {
              showStatus('No changes to save.', 'ok');
            } else {
              showStatus('Saved. Updated: ' + (data.fields || []).join(', ') + '.', 'ok');
              // Update originals so a second submit doesn't think they changed.
              form.querySelectorAll('input').forEach((input) => {
                input.dataset.original = input.value;
              });
            }
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save changes';
          } catch (err) {
            showStatus('Network error. Please try again.', 'error');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save changes';
          }
        });
      })();

      // Bookings panel — cancel, reschedule, no-show charge.
      (function () {
        function setRowStatus(bookingId, msg, kind) {
          const el = document.querySelector('[data-status-for="' + bookingId + '"]');
          if (!el) return;
          el.textContent = msg || '';
          el.className = 'row-status ' + (kind || '');
          el.hidden = !msg;
        }

        // Convert a YYYY-MM-DD picked in NY local time into a UTC
        // start/end window covering that NY day exactly (24h). We probe
        // the NY hour at noon UTC to discover the offset (handles DST).
        function nyDayUtcBounds(dateStr) {
          const probe = new Date(dateStr + 'T12:00:00Z');
          const nyHourStr = new Intl.DateTimeFormat('en-US', {
            timeZone: 'America/New_York',
            hour: '2-digit',
            hour12: false,
          }).format(probe);
          const nyHour = parseInt(nyHourStr, 10);
          const offsetHours = 12 - nyHour;
          const start = new Date(dateStr + 'T00:00:00Z');
          start.setUTCHours(offsetHours);
          const end = new Date(start.getTime() + 24 * 60 * 60 * 1000);
          return { startAt: start.toISOString(), endAt: end.toISOString() };
        }

        function fmtSlotLocal(utcIso) {
          return new Intl.DateTimeFormat('en-US', {
            timeZone: 'America/New_York',
            weekday: 'short',
            hour: 'numeric',
            minute: '2-digit',
            hour12: true,
          }).format(new Date(utcIso));
        }

        // Cancel — confirm, then POST.
        document.querySelectorAll('button[data-action="cancel"]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const bookingId = btn.dataset.bookingId;
            if (!bookingId) return;
            if (!window.confirm('Cancel this booking? The customer will not be charged.')) return;
            btn.disabled = true;
            const original = btn.textContent;
            btn.textContent = 'Cancelling…';
            setRowStatus(bookingId, '', '');
            try {
              const res = await fetch('/api/admin/bookings/cancel', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ bookingId }),
              });
              const data = await res.json();
              if (!res.ok || !data.ok) {
                setRowStatus(bookingId, (data && data.error && data.error.detail) || 'Cancel failed.', 'error');
                btn.disabled = false;
                btn.textContent = original;
                return;
              }
              setRowStatus(bookingId, 'Cancelled. Refreshing…', 'ok');
              setTimeout(() => window.location.reload(), 600);
            } catch (err) {
              setRowStatus(bookingId, 'Network error. Try again.', 'error');
              btn.disabled = false;
              btn.textContent = original;
            }
          });
        });

        // Reschedule — toggle inline form.
        document.querySelectorAll('button[data-action="reschedule"]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const bookingId = btn.dataset.bookingId;
            const row = document.querySelector('[data-resched-for="' + bookingId + '"]');
            if (!row) return;
            row.hidden = !row.hidden;
          });
        });

        document.querySelectorAll('[data-cancel-resched]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const form = btn.closest('.resched-form');
            const bookingId = form?.dataset.reschedFormFor;
            if (!bookingId) return;
            const row = document.querySelector('[data-resched-for="' + bookingId + '"]');
            if (row) row.hidden = true;
          });
        });

        // Reschedule — load slots for the picked date + barber.
        document.querySelectorAll('[data-load-slots]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const form = btn.closest('.resched-form');
            if (!form) return;
            const bookingId = form.dataset.reschedFormFor;
            const bookingRow = document.querySelector('tr[data-booking-id="' + bookingId + '"]');
            if (!bookingRow) return;
            const serviceVariationId = bookingRow.dataset.serviceId;
            const teamMemberId = form.querySelector('select[name="teamMemberId"]').value;
            const date = form.querySelector('input[name="date"]').value;
            const slotList = form.querySelector('[data-slot-list]');
            const submitBtn = form.querySelector('button[type="submit"]');
            const pickedLabel = form.querySelector('[data-picked-label]');
            if (!date) {
              setRowStatus(bookingId, 'Pick a date first.', 'error');
              return;
            }
            setRowStatus(bookingId, '', '');
            slotList.hidden = false;
            slotList.innerHTML = '<span class="meta">Loading times…</span>';
            submitBtn.disabled = true;
            pickedLabel.textContent = '';
            form.dataset.pickedSlot = '';
            const { startAt, endAt } = nyDayUtcBounds(date);
            const params = new URLSearchParams({
              serviceVariationId: serviceVariationId,
              startAt,
              endAt,
            });
            if (teamMemberId) params.set('teamMemberId', teamMemberId);
            try {
              const res = await fetch('/api/square/availability?' + params.toString(), {
                credentials: 'same-origin',
              });
              const data = await res.json();
              if (!res.ok || !data.ok) {
                slotList.innerHTML = '';
                slotList.hidden = true;
                setRowStatus(bookingId, (data && data.error && data.error.detail) || 'Could not load times.', 'error');
                return;
              }
              const slots = (data.slots || []);
              if (slots.length === 0) {
                slotList.innerHTML = '<span class="meta">No openings that day.</span>';
                return;
              }
              slotList.innerHTML = '';
              slots.forEach((s) => {
                const startUtc = s.startAt || s.start_at;
                if (!startUtc) return;
                const b = document.createElement('button');
                b.type = 'button';
                b.textContent = fmtSlotLocal(startUtc);
                b.dataset.slotUtc = startUtc;
                b.addEventListener('click', () => {
                  slotList.querySelectorAll('button').forEach((x) => x.classList.remove('selected'));
                  b.classList.add('selected');
                  form.dataset.pickedSlot = startUtc;
                  pickedLabel.textContent = 'Picked: ' + fmtSlotLocal(startUtc);
                  submitBtn.disabled = false;
                });
                slotList.appendChild(b);
              });
            } catch (err) {
              slotList.innerHTML = '';
              slotList.hidden = true;
              setRowStatus(bookingId, 'Network error. Try again.', 'error');
            }
          });
        });

        // Reschedule — submit.
        document.querySelectorAll('.resched-form').forEach((form) => {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const bookingId = form.dataset.reschedFormFor;
            const slotUtc = form.dataset.pickedSlot;
            const teamMemberId = form.querySelector('select[name="teamMemberId"]').value;
            if (!bookingId || !slotUtc) return;
            const submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            const original = submitBtn.textContent;
            submitBtn.textContent = 'Rescheduling…';
            setRowStatus(bookingId, '', '');
            try {
              const res = await fetch('/api/admin/bookings/reschedule', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  oldBookingId: bookingId,
                  newStartAtUtc: slotUtc,
                  teamMemberId,
                }),
              });
              const data = await res.json();
              if (!res.ok || !data.ok) {
                setRowStatus(bookingId, (data && data.error && data.error.detail) || 'Reschedule failed.', 'error');
                submitBtn.disabled = false;
                submitBtn.textContent = original;
                return;
              }
              const msg = data.warning ? 'Rescheduled (with warning: ' + data.warning + ')' : 'Rescheduled. Refreshing…';
              setRowStatus(bookingId, msg, 'ok');
              setTimeout(() => window.location.reload(), 800);
            } catch (err) {
              setRowStatus(bookingId, 'Network error. Try again.', 'error');
              submitBtn.disabled = false;
              submitBtn.textContent = original;
            }
          });
        });

        // Family link — bind this customer to a parent (Bill ↔ kid).
        // Phone-based parent lookup handled server-side. Refreshes
        // the page on success so the row re-renders with "Linked
        // to <Name>" + the unlink button.
        const familyLinkContainer = document.querySelector('.family-link');
        const familyLinkStatus = document.getElementById('family-link-status');
        const setFamilyLinkStatus = (msg, kind) => {
          if (!familyLinkStatus) return;
          familyLinkStatus.textContent = msg || '';
          familyLinkStatus.className = 'row-status ' + (kind || '');
          familyLinkStatus.hidden = !msg;
        };
        const linkBtn = document.querySelector('[data-link-person]');
        if (linkBtn && familyLinkContainer) {
          linkBtn.addEventListener('click', async () => {
            const emailInput = document.getElementById('family-link-email');
            const parentEmail = emailInput ? emailInput.value.trim() : '';
            const customerId = familyLinkContainer.dataset.customerId;
            if (!parentEmail) {
              setFamilyLinkStatus("Enter the parent's email first.", 'error');
              return;
            }
            if (!customerId) return;
            linkBtn.disabled = true;
            const originalLabel = linkBtn.textContent;
            linkBtn.textContent = 'Linking…';
            setFamilyLinkStatus('', '');
            try {
              const res = await fetch('/api/admin/link-person', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ customerId, parentEmail }),
              });
              const data = await res.json();
              if (!res.ok || !data.ok) {
                setFamilyLinkStatus((data && data.error && data.error.detail) || 'Link failed.', 'error');
                linkBtn.disabled = false;
                linkBtn.textContent = originalLabel;
                return;
              }
              setFamilyLinkStatus(`Linked to ${data.parent.displayName}. Refreshing…`, 'ok');
              setTimeout(() => window.location.reload(), 600);
            } catch (err) {
              setFamilyLinkStatus('Network error. Try again.', 'error');
              linkBtn.disabled = false;
              linkBtn.textContent = originalLabel;
            }
          });
        }
        const unlinkBtn = document.querySelector('[data-unlink-person]');
        if (unlinkBtn && familyLinkContainer) {
          unlinkBtn.addEventListener('click', async () => {
            const customerId = familyLinkContainer.dataset.customerId;
            if (!customerId) return;
            if (!window.confirm('Unlink this customer from their parent? Their appointments will stop showing on the parent\'s /my-bookings page.')) {
              return;
            }
            unlinkBtn.disabled = true;
            const originalLabel = unlinkBtn.textContent;
            unlinkBtn.textContent = 'Unlinking…';
            setFamilyLinkStatus('', '');
            try {
              const res = await fetch('/api/admin/unlink-person', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ customerId }),
              });
              const data = await res.json();
              if (!res.ok || !data.ok) {
                setFamilyLinkStatus((data && data.error && data.error.detail) || 'Unlink failed.', 'error');
                unlinkBtn.disabled = false;
                unlinkBtn.textContent = originalLabel;
                return;
              }
              setFamilyLinkStatus('Unlinked. Refreshing…', 'ok');
              setTimeout(() => window.location.reload(), 600);
            } catch (err) {
              setFamilyLinkStatus('Network error. Try again.', 'error');
              unlinkBtn.disabled = false;
              unlinkBtn.textContent = originalLabel;
            }
          });
        }

        // Hard-delete the customer record. Two-step: confirm via prompt
        // asking the operator to retype the customer id, then POST.
        const deleteBtn = document.querySelector('[data-delete-customer]');
        if (deleteBtn) {
          deleteBtn.addEventListener('click', async () => {
            const customerId = deleteBtn.dataset.customerId;
            const status = document.getElementById('delete-status');
            const setDeleteStatus = (msg, kind) => {
              if (!status) return;
              status.textContent = msg || '';
              status.className = 'row-status ' + (kind || '');
              status.hidden = !msg;
            };
            if (!customerId) return;
            const typed = window.prompt(
              'This will hard-delete the Square customer record. There is no undo.\n\n' +
              'To confirm, paste the customer id below:\n\n' + customerId,
            );
            if (typed === null) return; // cancelled
            if (typed.trim() !== customerId) {
              setDeleteStatus('Confirmation id did not match — delete cancelled.', 'error');
              return;
            }
            deleteBtn.disabled = true;
            const original = deleteBtn.textContent;
            deleteBtn.textContent = 'Deleting…';
            setDeleteStatus('', '');
            try {
              const res = await fetch('/api/admin/delete-customer', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ customerId, confirmId: customerId }),
              });
              const data = await res.json();
              if (!res.ok || !data.ok) {
                setDeleteStatus((data && data.error && data.error.detail) || 'Delete failed.', 'error');
                deleteBtn.disabled = false;
                deleteBtn.textContent = original;
                return;
              }
              setDeleteStatus('Customer deleted. Returning to lookup…', 'ok');
              setTimeout(() => {
                window.location.href = '/admin/customers';
              }, 800);
            } catch (err) {
              setDeleteStatus('Network error. Try again.', 'error');
              deleteBtn.disabled = false;
              deleteBtn.textContent = original;
            }
          });
        }

        // No-show charge on a past booking — reuses the existing endpoint
        // /admin/bookings already calls.
        document.querySelectorAll('button[data-action="no-show-charge"]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const bookingId = btn.dataset.bookingId;
            const amountCents = parseInt(btn.dataset.amountCents || '0', 10);
            if (!bookingId) return;
            const dollars = (amountCents / 100).toFixed(2);
            const ok = window.confirm(
              'Mark this customer NO-SHOW and charge $' + dollars + ' to their card on file?\n\n' +
              'This will:\n' +
              '  • Cancel the Square booking\n' +
              '  • Charge the saved card the full service price\n\n' +
              'Refunds are handled in Square.',
            );
            if (!ok) return;
            btn.disabled = true;
            const originalLabel = btn.textContent;
            btn.textContent = 'Charging…';
            setRowStatus(bookingId, '', '');
            try {
              const res = await fetch('/api/admin/bookings/no-show-charge', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ bookingId }),
              });
              const data = await res.json();
              if (!res.ok || !data.ok) {
                setRowStatus(bookingId, (data && data.error && data.error.detail) || 'Charge failed.', 'error');
                btn.disabled = false;
                btn.textContent = originalLabel;
                return;
              }
              if (data.chargeFailed) {
                setRowStatus(bookingId, 'Booking cancelled, but card charge failed: ' + data.chargeFailed.detail, 'error');
              } else {
                setRowStatus(bookingId, 'No-show charge complete. Refreshing…', 'ok');
              }
              setTimeout(() => window.location.reload(), 1200);
            } catch (err) {
              setRowStatus(bookingId, 'Network error. Try again.', 'error');
              btn.disabled = false;
              btn.textContent = originalLabel;
            }
          });
        });
      })();
    </script>
  </body>
</html>
