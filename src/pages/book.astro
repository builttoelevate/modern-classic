---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingWizard from '../components/booking/BookingWizard.tsx';
import type { RescheduleContext, SignedInCustomer, WizardPreselectProps, BookingForOption } from '../components/booking/BookingWizard.tsx';
import { getServices } from '../lib/square/catalog';
import { getBarbers } from '../lib/square/team';
import { getLocation } from '../lib/square/locations';
import { getBooking } from '../lib/square/bookings';
import { findCustomerByEmail } from '../lib/square/customers';
import { listLinkedPeople } from '../lib/customer/profileLinks';
import { getSession } from '../lib/auth/middleware';
import { preselectFromUrl } from '../lib/booking/wizardPreselect';
import type { Barber, Location, Service } from '../lib/square/types';

import '../styles/booking.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = new URL(Astro.request.url);
const rescheduleId = url.searchParams.get('reschedule');
const urlPreselect = preselectFromUrl(url);
const preselect: WizardPreselectProps | undefined =
  urlPreselect.serviceVariationId || urlPreselect.teamMemberId
    ? {
        serviceVariationId: urlPreselect.serviceVariationId,
        teamMemberId: urlPreselect.teamMemberId,
      }
    : undefined;

let services: Service[] = [];
let barbers: Barber[] = [];
let location: Location | null = null;
let loadError: string | null = null;
let reschedule: RescheduleContext | undefined;
let rescheduleError: string | null = null;
let signedInCustomer: SignedInCustomer | undefined;
let bookingForOptions: BookingForOption[] | undefined;

try {
  const [s, b, l] = await Promise.all([getServices(), getBarbers(), getLocation()]);
  services = s;
  barbers = b;
  location = l;
} catch (err) {
  loadError = err instanceof Error ? err.message : String(err);
  // eslint-disable-next-line no-console
  console.error('[book] failed to load services/barbers/location', err);
}

// If the visitor is signed in (and not rescheduling — that path runs its
// own customer lookup below), hydrate their contact info so the wizard
// can skip Step 4 entirely, and load their linked-people list so the
// "Booking for" selector can render. Best-effort; any failure just
// falls back to the normal Step 4 details flow with no selector.
if (!rescheduleId && !loadError) {
  const session = getSession(Astro.request);
  if (session) {
    try {
      const [customer, kids] = await Promise.all([
        findCustomerByEmail(session.email),
        listLinkedPeople(session.customerId).catch(() => []),
      ]);
      if (customer) {
        signedInCustomer = {
          givenName: customer.given_name?.trim() ?? '',
          familyName: customer.family_name?.trim() ?? '',
          email: session.email,
          phone: customer.phone_number?.trim() ?? '',
        };
        // Always include "Me" plus any linked dependents. We hand the
        // wizard a single list it can render in the selector — if it has
        // length 1 (just "Me"), the selector hides itself.
        bookingForOptions = [
          {
            customerId: customer.id,
            displayName: signedInCustomer.givenName || 'Me',
            relationship: 'You',
            isSelf: true,
          },
          ...kids.map((k) => ({
            customerId: k.customerId,
            displayName: k.displayName,
            relationship: k.relationship,
            isSelf: false,
          })),
        ];
      }
    } catch {
      // Silent — Step 4 will still collect details.
    }
  }
}

if (rescheduleId && !loadError) {
  const session = getSession(Astro.request);
  if (!session) {
    return new Response(null, {
      status: 302,
      headers: {
        Location: `${base}/sign-in?redirect=${encodeURIComponent(`${base}/book?reschedule=${rescheduleId}`)}`,
      },
    });
  }

  try {
    const booking = await getBooking(rescheduleId);
    // Ownership: signed-in customer themselves, OR one of their linked
    // people (kids / group members). Mirrors the same check on the
    // /api/square/bookings/reschedule endpoint — without this, parents
    // see "doesn't belong to your account" when trying to reschedule a
    // kid's booking from /my-bookings even though the API would accept
    // the same action.
    let allowed =
      !!booking.customer_id && booking.customer_id === session.customerId;
    if (!allowed && booking.customer_id) {
      try {
        const linked = await listLinkedPeople(session.customerId);
        allowed = linked.some((p) => p.customerId === booking.customer_id);
      } catch {
        // KV hiccup — fall through to the deny branch below rather than
        // leak rescheduling rights on a transient error.
      }
    }
    if (!allowed) {
      rescheduleError = 'This booking does not belong to your account.';
    } else {
      const startMs = new Date(booking.start_at).getTime();
      if (startMs - Date.now() < 24 * 60 * 60 * 1000) {
        rescheduleError =
          'This booking is within 24 hours — please call the shop at 740-297-4462 to reschedule.';
      } else {
        const segment = booking.appointment_segments?.[0];
        if (!segment) {
          rescheduleError = "This booking can't be rescheduled.";
        } else {
          // Try to look up the customer for a personalized greeting on the
          // confirm step; not strictly required.
          let givenName: string | undefined;
          let familyName: string | undefined;
          try {
            const customer = await findCustomerByEmail(session.email);
            givenName = customer?.given_name?.trim() || undefined;
            familyName = customer?.family_name?.trim() || undefined;
          } catch {
            // Best-effort.
          }

          const dtf = new Intl.DateTimeFormat('en-US', {
            timeZone: 'America/New_York',
            weekday: 'long',
            month: 'long',
            day: 'numeric',
            year: 'numeric',
            hour: 'numeric',
            minute: '2-digit',
            hour12: true,
          });

          reschedule = {
            oldBookingId: booking.id,
            oldBookingVersion: booking.version,
            oldStartAtUtc: booking.start_at,
            oldStartAtLocal: dtf.format(new Date(booking.start_at)),
            serviceVariationId: segment.service_variation_id,
            teamMemberId: segment.team_member_id,
            customerEmail: session.email,
            customerGivenName: givenName,
            customerFamilyName: familyName,
          };
        }
      }
    }
  } catch (err) {
    const detail = err instanceof Error ? err.message : String(err);
    // eslint-disable-next-line no-console
    console.log(
      `[BOOK] ${JSON.stringify({ ts: new Date().toISOString(), phase: 'reschedule-init-failed', detail })}`,
    );
    rescheduleError = "We couldn't load the appointment to reschedule.";
  }
}
---

<BaseLayout
  title={reschedule
    ? 'Reschedule your appointment — Modern Classic Barbershop'
    : 'Book an Appointment — Modern Classic Barbershop'}
  description="Book online with Modern Classic Barbershop in Zanesville. Pick your service, your barber, and a time that works for you."
>
  <Header />
  <main id="main" class="bw-page">
    {loadError ? (
      <div class="bw">
        <div class="bw-empty">
          <strong>Booking is temporarily unavailable.</strong>
          <span>Please try again in a moment, or call us at <a class="link-gold" href="tel:+17402974462">740-297-4462</a>.</span>
        </div>
      </div>
    ) : rescheduleError ? (
      <div class="bw">
        <div class="bw-empty">
          <strong>Can't reschedule that one.</strong>
          <span>{rescheduleError}</span>
          <a class="link-gold" href={`${base}/my-bookings`}>← Back to my bookings</a>
        </div>
      </div>
    ) : (
      <>
        <BookingWizard
          client:load
          services={services}
          barbers={barbers}
          location={location}
          reschedule={reschedule}
          preselect={preselect}
          signedInCustomer={signedInCustomer}
          bookingForOptions={bookingForOptions}
        />
        {/* Entry point to the group flow. Styled as a bw-card so it
            sits visually next to the service list at the bottom of
            Step 1 — same dark surface, same gold border on hover. */}
        {!reschedule && (
          <div class="bw bw-group-card-wrap">
            <a class="bw-card bw-card--group" href={`${base}/book/group`}>
              <span class="bw-card-name">Group Booking</span>
              <span class="bw-card-price">
                2&ndash;{Math.min(4, Math.max(2, barbers.length))} people
                &middot; One transaction
              </span>
              <span class="bw-card-desc">
                Book the family or a small crew together. Pick a service for each
                person, then pick how to schedule &mdash; everyone at once with
                separate barbers, or back-to-back with one. We&apos;ll only show
                times the whole group can fit.
              </span>
              <span class="bw-card-cta">Open the group flow <span aria-hidden="true">→</span></span>
            </a>
          </div>
        )}
      </>
    )}
  </main>
  <Footer />
</BaseLayout>
