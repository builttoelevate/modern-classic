{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/rebuild",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/review-requests",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/waitlist-notify",
      "schedule": "0 * * * *"
    }
  ]
}
